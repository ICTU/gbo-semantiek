<https://lod.gbo-semantiek.nl/voertuigen/voertuig> a sh:NodeShape ;
    rdfs:comment "Een door de RDW in de Basisregistratie Voertuigen geregistreerd vervoermiddel dat met een uniek kenteken aan het verkeer kan deelnemen, met de bij dat kenteken horende technische en administratieve kerngegevens." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "Wereldwijd uniek voertuigidentificatienummer (VIN / chassisnummer) toegekend door de fabrikant." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path <https://lod.gbo-semantiek.nl/voertuigen/voertuig/voertuigidentificatienummer> ;
            sh:pattern "^[A-Za-z0-9]*$" ],
        [ sh:description "Administratieve status van het voertuig." ;
            sh:in ( "Tenaamgesteld" "Bedrijfsvoorraad" "Geschorst" "Geexporteerd" "Gesloopt" "Vermist" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 37 ;
            sh:path <https://lod.gbo-semantiek.nl/voertuigen/voertuig/voertuigstatus> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Monotone versieteller." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
