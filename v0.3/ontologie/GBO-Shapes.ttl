gbo:OnroerendeZaakOverigBezit a sh:NodeShape ;
    rdfs:comment "Een in Box 3 op te geven onroerende zaak die niet de eigen woning is, zoals een tweede woning, een verhuurd pand of grond, vastgesteld op WOZ-waarde of marktwaarde per peildatum 1 januari." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gbo:Bedrag ;
            sh:description "Marktwaarde voor zover relevant." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/OnroerendeZaakOverigBezit/marktwaardePeildatum> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Het belastingjaar van toepassing." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
