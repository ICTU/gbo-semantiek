            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/ingediendDoor> ],
        [ sh:class gbo:Bedrag ;
