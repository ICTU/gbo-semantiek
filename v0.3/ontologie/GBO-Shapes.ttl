        [ sh:datatype <xsd:string> ;
            sh:description "Primaire kleur van het voertuig." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path <https://lod.gbo-semantiek.nl/voertuigen/voertuig/eerstekleur> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Primaire kleur van het voertuig." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path <https://lod.gbo-semantiek.nl/voertuigen/voertuig/eerstekleur> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop het voertuig voor het eerst (waar ook ter wereld) tot het verkeer is toegelaten." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://lod.gbo-semantiek.nl/voertuigen/voertuig/datumeerstetoelating> ],
