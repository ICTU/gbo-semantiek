    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Onderscheidt huwelijk van geregistreerd partnerschap." ;
            sh:in ( "Huwelijk" "GeregistreerdPartnerschap" ) ;
            sh:maxCount 1 ;
