        [ sh:description "Doel waarvoor het verblijfsobject geschikt is volgens het gemeentelijk besluit." ;
            sh:in ( "Woonfunctie" "Bijeenkomstfunctie" "Celfunctie" "Gezondheidszorgfunctie" "Industriefunctie" "Kantoorfunctie" "Logiesfunctie" "Onderwijsfunctie" "Sportfunctie" "Winkelfunctie" "Overigegebruiksfunctie" ) ;
            sh:minCount 1 ;
            sh:order 20 ;
