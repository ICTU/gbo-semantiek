<https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/belanghebbende> a sh:NodeShape ;
    rdfs:comment "De geregistreerde rechtsbetrekking tussen een partij en een WOZ-object, waarbij de partij voor de Wet WOZ als eigenaar, gebruiker of beide rollen heeft en daarom de WOZ-beschikking ontvangt voor het object." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop de rol is ingegaan." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/belanghebbende/datumingang> ],
        [ sh:class <https://lod.gbo-semantiek.nl/hoofdmodel/partij> ;
            sh:description "Partij die de rol vervult; direct op Partij, niet via Tenaamstelling. Geldt ook voor de gebruiker zonder kadastraal recht." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/belanghebbende/ispartij> ],
        [ sh:description "Hoedanigheid van de belanghebbende ten aanzien van het WOZ-object." ;
            sh:in ( "Eigenaar" "EigenaarEnGebruiker" "Gebruiker" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/belanghebbende/rolbelanghebbende> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Het breukdeel waarmee de partij in de rol deelneemt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/belanghebbende/aandeel> ;
            sh:pattern "^[0-9]+/[0-9]+$" ],
        [ sh:class <https://lod.gbo-semantiek.nl/hoofdmodel/partij> ;
            sh:description "Partij die de rol vervult; direct op Partij, niet via Tenaamstelling. Geldt ook voor de gebruiker zonder kadastraal recht." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/belanghebbende/ispartij> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop de rol is geëindigd." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/belanghebbende/datumeinde> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop de rol is ingegaan." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/belanghebbende/datumingang> ],
        [ sh:class <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject> ;
            sh:description "WOZ-object waarop de rol betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/belanghebbende/vanwozobject> ],
        [ sh:description "Hoedanigheid van de belanghebbende ten aanzien van het WOZ-object." ;
