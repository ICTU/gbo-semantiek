    sh:ignoredProperties ( <https://lod.gbo-semantiek.nl/personen/Ingezetene/datumInschrijvingGemeente> <https://lod.gbo-semantiek.nl/personen/NietIngezetene/datumInschrijvingRNI> gbo:woontOp <https://lod.gbo-semantiek.nl/personen/Ingezetene/heeftBriefadres> <https://lod.gbo-semantiek.nl/personen/NietIngezetene/landVanVerblijf> <https://lod.gbo-semantiek.nl/personen/Ingezetene/indicatieGeheim> <https://lod.gbo-semantiek.nl/personen/NietIngezetene/woontOp> <https://lod.gbo-semantiek.nl/personen/Ingezetene/woontOp> <https://lod.gbo-semantiek.nl/personen/NietIngezetene/deelnemerCodeRNI> rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "Alle officiële voornamen van de persoon." ;
