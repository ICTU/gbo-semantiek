gbo:VerblijfplaatsOnbekend a sh:NodeShape ;
    rdfs:comment "Een adres-rol voor een ingeschreven persoon van wie de feitelijke verblijfplaats op een bepaalde datum onbekend is geworden, zonder dat een nieuw adres bekend is." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen sleutel voor één adres-instantie." ;
