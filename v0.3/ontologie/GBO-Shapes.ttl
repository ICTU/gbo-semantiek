            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buitenlandsadres/adresregel1> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Tweede regel van het buitenlandse adres." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buitenlandsadres/adresregel2> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Landaanduiding volgens ISO 3166." ;
