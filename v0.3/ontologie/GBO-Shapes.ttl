            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://lod.gbo-semantiek.nl/datatypes/Bedrag/valuta> ;
            sh:pattern "^[A-Z]{3}$" ] ;
    sh:targetClass gbo:Bedrag .


