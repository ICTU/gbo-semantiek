gbo:Nummeraanduiding a sh:NodeShape ;
    rdfs:comment "Een door het bevoegde gemeentelijke gezag aan een adresseerbaar object toegekende aanduiding bestaande uit een huisnummer met eventueel een huisletter, een huisnummertoevoeging en een postcode, die samen met de naam van de openbare ruimte en de woonplaats het formele adres vormt." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gbo:OpenbareRuimte ;
            sh:description "De openbare ruimte waarin de nummeraanduiding is uitgegeven." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/Nummeraanduiding/inOpenbareRuimte> ],
        [ sh:datatype <xsd:dateTime> ;
            sh:description "Formele tijdlijn: einde van de registratie; open betekent actueel." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/Voorkomen/eindRegistratie> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van het bron-document (akte)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/Datakwaliteit/documentdatum> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Monotone versieteller." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/Voorkomen/versie> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Postcode behorend bij het huisnummer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/Nummeraanduiding/postcode> ;
            sh:pattern "^[1-9][0-9]{3} ?[A-Z]{2}$" ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Numerieke aanduiding van het adres binnen de openbare ruimte." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/Nummeraanduiding/huisnummer> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Monotone versieteller." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/Voorkomen/versie> ],
        [ sh:description "Aanduiding van de vorm waarop de nummeraanduiding wijst (Verblijfsobject, Ligplaats of Standplaats)." ;
            sh:in ( "Verblijfsobject" "Ligplaats" "Standplaats" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 23 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/Nummeraanduiding/typeAdresseerbaarObject> ],
        [ sh:description "Levenscyclus-status van de nummeraanduiding." ;
            sh:in ( "NaamgevingUitgegeven" "NaamgevingIngetrokken" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 24 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/Nummeraanduiding/status> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Materiële tijdlijn: einde van de geldigheid; open betekent lopend." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/Voorkomen/eindGeldigheid> ],
