gbo:Standplaats a sh:NodeShape ;
    rdfs:comment "Een door het bevoegde gemeentelijke gezag aangewezen terrein of gedeelte daarvan dat bestemd is voor het permanent plaatsen van een niet direct en niet duurzaam met de aarde verbonden en voor woon-, bedrijfsmatige of recreatieve doeleinden geschikt bouwwerk." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Markering dat de kwaliteit in onderzoek is." ;
            sh:in ( "Ja" "Nee" "Onbekend" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 27 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/Datakwaliteit/inOnderzoek> ],
