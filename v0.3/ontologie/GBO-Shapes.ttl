gbo:Bedrag a sh:NodeShape ;
    rdfs:comment "Geldbedrag: numerieke waarde met expliciete valuta-aanduiding (ISO 4217). Voor binnenlandse toepassingen impliciet EUR; de valuta wordt expliciet bij internationale uitwisseling." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:float> ;
            sh:description "De numerieke waarde van het bedrag." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://lod.gbo-semantiek.nl/datatypes/Bedrag/waarde> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Valuta conform ISO 4217; bij afwezigheid geldt EUR." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://lod.gbo-semantiek.nl/datatypes/Bedrag/valuta> ;
            sh:pattern "^[A-Z]{3}$" ],
        [ sh:datatype <xsd:float> ;
            sh:description "De numerieke waarde van het bedrag." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://lod.gbo-semantiek.nl/datatypes/Bedrag/waarde> ],
        [ sh:datatype <xsd:string> ;
