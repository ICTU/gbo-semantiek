            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/AangifteErf/overlijdensdatum> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Bijvoorbeeld Ingediend, Aangeslagen, Bezwaar lopend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingAangifte/status> ] ;
    sh:targetClass gbo:AangifteErf .

gbo:AangifteIH a sh:NodeShape ;
    rdfs:comment "De jaaraangifte inkomstenbelasting van een natuurlijk persoon waarin het verzamelinkomen over een belastingjaar wordt opgegeven, opgebouwd uit Box 1 (werk en woning), Box 2 (aanmerkelijk belang) en Box 3 (sparen en beleggen)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:integer> ;
            sh:description "Het jaar waarop de aangifte betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/belastingjaar> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van feitelijke indiening." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingAangifte/indieningsdatum> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Bijvoorbeeld Ingediend, Aangeslagen, Bezwaar lopend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingAangifte/status> ],
        [ sh:description "Toepasselijke boxen." ;
            sh:in ( "Box1WerkEnWoning" "Box2AanmerkelijkBelang" "Box3SparenEnBeleggen" ) ;
            sh:order 17 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/AangifteIH/boxCategorie> ],
        [ sh:class gbo:Bedrag ;
            sh:description "Inkomen uit sparen en beleggen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/AangifteIH/box3Inkomen> ],
        [ sh:class gbo:NatuurlijkPersoon ;
