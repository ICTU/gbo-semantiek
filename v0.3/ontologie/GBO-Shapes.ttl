            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres/volledigadres> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Landaanduiding volgens ISO 3166." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buitenlandsadres/land> ;
            sh:pattern "^[A-Z]{2}$" ],
