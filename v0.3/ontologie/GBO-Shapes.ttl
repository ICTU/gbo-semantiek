gbo:NietIngezetene a sh:NodeShape ;
    rdfs:comment "Een ingeschreven persoon die niet als ingezetene van een Nederlandse gemeente is geregistreerd en wiens persoonslijst centraal wordt bijgehouden in de Registratie Niet-Ingezetenen." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "Adellijke titel of predicaat." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://lod.gbo-semantiek.nl/personen/NatuurlijkPersoon/adellijkeTitelPredicaat> ],
        [ sh:description "Reden waarom bijhouding van de persoonslijst is opgeschort." ;
            sh:in ( "Overlijden" "Emigratie" "Vermissing" "FoutAangelegdOfFraude" ) ;
            sh:maxCount 1 ;
            sh:order 19 ;
            sh:path <https://lod.gbo-semantiek.nl/personen/IngeschrevenPersoon/opschortingBijhouding> ],
        [ sh:datatype <xsd:string> ;
            sh:description "De datum waarop deze persoon voor het eerst in de BRP werd opgenomen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path <https://lod.gbo-semantiek.nl/personen/IngeschrevenPersoon/datumEersteInschrijving> ;
            sh:pattern "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$" ],
        [ sh:description "Aanduiding dat de persoon van het kiesrecht is uitgesloten." ;
            sh:in ( "Ja" "Nee" ) ;
            sh:maxCount 1 ;
            sh:order 20 ;
            sh:path <https://lod.gbo-semantiek.nl/personen/IngeschrevenPersoon/uitsluitingKiesrecht> ],
        [ sh:description "Aanduiding dat de persoon kiesgerechtigd is voor het Europees Parlement vanuit Nederland." ;
            sh:in ( "Ja" "Nee" ) ;
            sh:maxCount 1 ;
            sh:order 48 ;
            sh:path <https://lod.gbo-semantiek.nl/personen/IngeschrevenPersoon/europeesKiesrecht> ],
        [ sh:description "Indicatie dat een of meer gegevens van de persoonslijst onderwerp zijn van onderzoek." ;
            sh:in ( "Ja" "Nee" "Onbekend" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
