<https://lod.gbo-semantiek.nl/adressen-en-gebouwen/locatie> a sh:NodeShape ;
    rdfs:comment "Een adresseerbare plek zonder eigen Nummeraanduiding, beschreven met een vrije omschrijving en optioneel een landaanduiding." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "Landaanduiding volgens ISO 3166." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/locatie/land> ;
            sh:pattern "^[A-Z]{2}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Vrije tekstuele omschrijving van de locatie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/locatie/omschrijving> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Gedenormaliseerde, leesbare projectie van het adres." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres/volledigadres> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Gedenormaliseerde, leesbare projectie van het adres." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres/volledigadres> ],
        [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen sleutel voor één adres-instantie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres/adresid> ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Vrije tekstuele omschrijving van de locatie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/locatie/omschrijving> ],
        [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen sleutel voor één adres-instantie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres/adresid> ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Landaanduiding volgens ISO 3166." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/locatie/land> ;
            sh:pattern "^[A-Z]{2}$" ] ;
    sh:targetClass <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/locatie> .

<https://lod.gbo-semantiek.nl/adressen-en-gebouwen/standplaats> a sh:NodeShape ;
    rdfs:comment "Een door het bevoegde gemeentelijke gezag aangewezen terrein of gedeelte daarvan dat bestemd is voor het permanent plaatsen van een niet direct en niet duurzaam met de aarde verbonden en voor woon-, bedrijfsmatige of recreatieve doeleinden geschikt bouwwerk." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Markering dat de kwaliteit in onderzoek is." ;
