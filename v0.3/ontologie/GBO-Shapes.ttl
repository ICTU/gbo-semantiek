    sh:property [ sh:datatype <xsd:string> ;
            sh:description "Statutaire vestigingsplaats." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/nietnatuurlijkpersoon/zetel> ],
