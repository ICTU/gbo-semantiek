            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buitenlandsadres/adresregel3> ],
        [ sh:datatype <xsd:string> ;
