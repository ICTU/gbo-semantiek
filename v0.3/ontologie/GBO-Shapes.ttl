@prefix gbo: <https://lod.gbo-semantiek.nl/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres> a sh:NodeShape ;
    rdfs:comment "Een leesbare aanduiding van een locatie of correspondentiepunt waarmee een persoon of organisatie kan worden bereikt of waarop een rechtsbetrekking is gevestigd, samengesteld uit elementen van de bronregisters BAG, RSGB en BRP." ;
    sh:closed false ;
    sh:ignoredProperties ( <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/verblijfplaatsonbekend/datumingangonbekend> rdf:type gbo:woonplaatsnaam <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/locatie/omschrijving> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/postadres/soortpostadres> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/locatie/land> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/postadres/briefbusnummer> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/straatnaam> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buitenlandsadres/adresregel3> gbo:huisnummertoevoeging <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/wordtgevormddoor> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buitenlandsadres/adresregel1> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/postadres/plaats> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/huisletter> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/postcode> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buitenlandsadres/adresregel2> gbo:huisletter <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/postadres/postcode> gbo:huisnummer <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/huisnummer> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/huisnummertoevoeging> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/woonplaatsnaam> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buitenlandsadres/land> gbo:land gbo:postcode gbo:omschrijving ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen sleutel voor één adres-instantie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres/adresid> ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Gedenormaliseerde, leesbare projectie van het adres." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres/volledigadres> ],
        [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen sleutel voor één adres-instantie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres/adresid> ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Gedenormaliseerde, leesbare projectie van het adres." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres/volledigadres> ] ;
    sh:targetClass <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres> .

<https://lod.gbo-semantiek.nl/adressen-en-gebouwen/ligplaats> a sh:NodeShape ;
    rdfs:comment "Een door het bevoegde gemeentelijke gezag aangewezen plaats in het water, eventueel aangevuld met een op de oever aanwezig terrein of een gedeelte daarvan, bestemd voor het permanent afmeren van een voor woon-, bedrijfsmatige of recreatieve doeleinden geschikt drijvend object." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop officieel geconstateerd." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/geconstateerd> ],
        [ sh:datatype <xsd:dateTime> ;
            sh:description "Formele tijdlijn: einde van de registratie; open betekent actueel." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen/eindregistratie> ],
        [ sh:description "Aanduiding van de concrete vorm: Verblijfsobject, Ligplaats of Standplaats." ;
            sh:in ( "Verblijfsobject" "Ligplaats" "Standplaats" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 18 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adresseerbaarobject/typeadresseerbaarobject> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Identificatie van het bron-document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/documentnummer> ],
        [ sh:datatype <xsd:dateTime> ;
            sh:description "Formele tijdlijn: einde van de registratie; open betekent actueel." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen/eindregistratie> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop officieel geconstateerd." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/geconstateerd> ],
        [ sh:description "Markering dat de kwaliteit in onderzoek is." ;
            sh:in ( "Ja" "Nee" "Onbekend" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 27 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/inonderzoek> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Unieke identificatie van het adresseerbaar object volgens NEN 3610." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adresseerbaarobject/identificatie> ;
            sh:pattern "^[0-9]{16}$" ],
        [ sh:datatype <xsd:date> ;
            sh:description "Materiële tijdlijn: einde van de geldigheid; open betekent lopend." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen/eindgeldigheid> ],
        [ sh:description "Aanduiding van de concrete vorm: Verblijfsobject, Ligplaats of Standplaats." ;
            sh:in ( "Verblijfsobject" "Ligplaats" "Standplaats" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adresseerbaarobject/typeadresseerbaarobject> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Identificatie van het bron-document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/documentnummer> ],
        [ sh:description "Levenscyclus-status van de ligplaats." ;
            sh:in ( "Gerealiseerd" "NietGerealiseerd" "VerblijfsobjectInGebruikNietIngemeten" "VerblijfsobjectInGebruik" "VerbouwingVerblijfsobject" "VerblijfsobjectIngetrokken" "VerblijfsobjectBuitenGebruik" "PlaatsAangewezen" "PlaatsIngetrokken" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 15 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/ligplaats/status> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van het bron-document (akte)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/documentdatum> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Vlakke begrenzing van de ligplaats." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/ligplaats/geometrie> ],
        [ sh:class <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buurt> ;
            sh:description "Geometrische plaatsing in precies één Buurt (CBS-laag)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adresseerbaarobject/ligtinbuurt> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Monotone versieteller." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen/versie> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Monotone versieteller." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen/versie> ],
        [ sh:description "Levenscyclus-status van de ligplaats." ;
            sh:in ( "Gerealiseerd" "NietGerealiseerd" "VerblijfsobjectInGebruikNietIngemeten" "VerblijfsobjectInGebruik" "VerbouwingVerblijfsobject" "VerblijfsobjectIngetrokken" "VerblijfsobjectBuitenGebruik" "PlaatsAangewezen" "PlaatsIngetrokken" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 13 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/ligplaats/status> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Vlakke begrenzing van de ligplaats." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/ligplaats/geometrie> ],
        [ sh:class <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/nummeraanduiding> ;
            sh:description "Hoofdadres + nul of meer nevenadressen." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adresseerbaarobject/heeftnummeraanduiding> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Materiële tijdlijn: start van de geldigheid." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen/begingeldigheid> ],
        [ sh:class <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buurt> ;
            sh:description "Geometrische plaatsing in precies één Buurt (CBS-laag)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adresseerbaarobject/ligtinbuurt> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van het bron-document (akte)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/documentdatum> ],
        [ sh:description "Markering dat de kwaliteit in onderzoek is." ;
            sh:in ( "Ja" "Nee" "Onbekend" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/inonderzoek> ],
        [ sh:datatype <xsd:dateTime> ;
            sh:description "Formele tijdlijn: start van de registratie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen/tijdstipregistratie> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Materiële tijdlijn: einde van de geldigheid; open betekent lopend." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen/eindgeldigheid> ],
        [ sh:class <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/nummeraanduiding> ;
            sh:description "Hoofdadres + nul of meer nevenadressen." ;
            sh:minCount 1 ;
