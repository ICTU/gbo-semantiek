gbo:AangifteErf a sh:NodeShape ;
    rdfs:comment "De aangifte erfbelasting waarin de nalatenschap van een overledene en de verdeling daarvan over de erfgenamen wordt opgegeven." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gbo:Bedrag ;
            sh:description "Fiscale waarde van de nalatenschap." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/AangifteErf/omvangNalatenschap> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van feitelijke indiening." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingAangifte/indieningsdatum> ],
        [ sh:datatype <xsd:string> ;
            sh:description "IH, Schenk, Erf." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/belastingsoort> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Bijvoorbeeld Ingediend, Aangeslagen, Bezwaar lopend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingAangifte/status> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van feitelijke indiening." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingAangifte/indieningsdatum> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Begin van de aangifteperiode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/ingangsdatumAangifte> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Identificatie van de aangifte." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingAangifte/aangifteIdentificatie> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Het jaar waarop de aangifte betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/belastingjaar> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Het jaar waarop de aangifte betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/belastingjaar> ],
        [ sh:datatype <xsd:string> ;
            sh:description "IH, Schenk, Erf." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/belastingsoort> ],
        [ sh:datatype <xsd:string> ;
            sh:description "Identificatie van de aangifte." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingAangifte/aangifteIdentificatie> ],
        [ sh:class gbo:NatuurlijkPersoon ;
            sh:description "De natuurlijk persoon door of namens wie de aangifte is ingediend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/ingediendDoor> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Begin van de aangifteperiode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/ingangsdatumAangifte> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Einde van de aangifteperiode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/einddatumAangifte> ],
        [ sh:class gbo:NatuurlijkPersoon ;
            sh:description "De natuurlijk persoon door of namens wie de aangifte is ingediend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/ingediendDoor> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Einde van de aangifteperiode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/einddatumAangifte> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Aantal erfgenamen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/AangifteErf/aantalErfgenamen> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Aantal erfgenamen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/AangifteErf/aantalErfgenamen> ],
        [ sh:class gbo:Bedrag ;
            sh:description "Fiscale waarde van de nalatenschap." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/AangifteErf/omvangNalatenschap> ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van overlijden." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/AangifteErf/overlijdensdatum> ],
        [ sh:datatype <xsd:date> ;
