        [ sh:datatype <xsd:string> ;
            sh:description "IH, Schenk, Erf." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/BelastingjaarAangifte/belastingsoort> ],
        [ sh:description "Toepasselijke boxen." ;
            sh:in ( "Box1WerkEnWoning" "Box2AanmerkelijkBelang" "Box3SparenEnBeleggen" ) ;
            sh:order 12 ;
            sh:path <https://lod.gbo-semantiek.nl/belastingen/AangifteIH/boxCategorie> ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Het jaar waarop de aangifte betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
