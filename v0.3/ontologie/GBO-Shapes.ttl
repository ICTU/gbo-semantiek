<https://lod.gbo-semantiek.nl/adressen-en-gebouwen/buitenlandsadres> a sh:NodeShape ;
    rdfs:comment "Een adres buiten Nederland weergegeven als één tot drie vrije adresregels samen met een landaanduiding." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "Derde regel van het buitenlandse adres." ;
            sh:maxCount 1 ;
