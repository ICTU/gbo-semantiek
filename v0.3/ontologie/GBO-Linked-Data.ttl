gbo:MaatschappelijkeActiviteit a owl:Class ;
    rdfs:label "MaatschappelijkeActiviteit" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:UUID ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstCBSSBI ;
            owl:onProperty gbo:hoofdSbiCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:hoofdSbiCode ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:hoofdSbiCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Inschrijving ;
            owl:onProperty gbo:geregistreerdVia ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:geregistreerdVia ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:startdatum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:startdatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:omschrijving ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:omschrijving ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:startdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:omschrijving ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:geregistreerdVia ] ;
    skos:altLabel "MA",
        "Onderneming" ;
    skos:definition "Een onderneming binnen een niet-natuurlijke persoon, het samenhangend geheel van bedrijfsactiviteiten dat onder één economische identiteit wordt gevoerd en dat tot precies één inschrijving in het Handelsregister leidt." ;
    skos:exactMatch gbobegrip:MaatschappelijkeActiviteit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Alias MA is de GBO-afkorting; alias Onderneming geldt in de HR/KVK-context.",
        "MaatschappelijkeActiviteit is de ondernemings-eenheid binnen een niet-natuurlijke persoon. Eén niet-natuurlijke persoon voert één of meer ondernemingen (1..* MAs) en elke MA leidt tot precies één HR-Inschrijving; één Inschrijving kan dus meerdere MAs dragen wanneer een NNP via dezelfde KVK-registratie meerdere onderscheiden ondernemingen heeft. Continuïteit bij rechtsvormwijziging (eenmanszaak naar BV, fusie, splitsing) loopt via Partij en Inschrijving, niet via MA: Partij houdt de natuurlijke identiteit over rechtsvormen heen. Onderscheid met Activiteit: MA is de onderneming als geheel (\"viskraam-onderneming\"), Activiteit is een SBI-gecodeerde deelactiviteit (\"46.38.1 Detailhandel in vis\"). Eén MA kan via meerdere SBI-Activiteiten worden uitgewerkt." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "GBO; raakvlak NHR-onderneming (HRW art. 5)" ;
    mim:herkomstDefinitie "Conceptueel verwant met het wettelijk onderneming-begrip uit Handelsregisterwet 2007 art. 5; aanvulling uit KVK Basisprofiel-API (onderneming-attributen onder een inschrijving)." ;
    mim:populatie "Alle ondernemingen die in Nederland door niet-natuurlijke personen worden gevoerd en die tot een NHR-inschrijving leiden." ;
    mim:uniekeAanduiding "identificatie" .

gbo:TypePubliekrechtelijkeBeperking a owl:Class ;
    rdfs:label "TypePubliekrechtelijkeBeperking" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/TypePubliekrechtelijkeBeperking#BodemBescherming> <https://lod.gbo-semantiek.nl/TypePubliekrechtelijkeBeperking#Erfgoedwet> <https://lod.gbo-semantiek.nl/TypePubliekrechtelijkeBeperking#Monumentenwet> <https://lod.gbo-semantiek.nl/TypePubliekrechtelijkeBeperking#Onteigening> <https://lod.gbo-semantiek.nl/TypePubliekrechtelijkeBeperking#Overig> <https://lod.gbo-semantiek.nl/TypePubliekrechtelijkeBeperking#Wro_Voorkeursrecht> ) ;
    skos:definition "Type van een publiekrechtelijke beperking op een kadastraal onroerende zaak, bepalend voor de wettelijke grondslag en de aard van de beperking." ;
