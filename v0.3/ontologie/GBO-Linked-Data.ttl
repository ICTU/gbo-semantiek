            owl:minCardinality 1 ;
            owl:onProperty gbo:geometrie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:buurtnaam ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:buurtcode ],
        [ a owl:Restriction ;
