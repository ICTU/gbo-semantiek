        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/belastingjaaraangifte/einddatumaangifte> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/belastingjaaraangifte/ingangsdatumaangifte> ],
        [ owl:unionOf ( <https://lod.gbo-semantiek.nl/belastingen/aangifteerf> <https://lod.gbo-semantiek.nl/belastingen/aangifteih> <https://lod.gbo-semantiek.nl/belastingen/aangifteschenk> ) ],
