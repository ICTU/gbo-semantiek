        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:kredietlimiet ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:achterstandstermijn ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:meldingsdrempel ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:kredietlimiet ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:kredietvormCode ],
