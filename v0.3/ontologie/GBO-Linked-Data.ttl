    skos:definition "Een in Box 3 op te geven vermogensbestanddeel dat bestaat uit aandelen, obligaties, beleggingsfondsen, derivaten of vergelijkbare effecten, vastgesteld op marktwaarde per peildatum 1 januari." ;
    skos:exactMatch gbobegrip:Belegging ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SBR-NT NT20" ;
    mim:herkomstDefinitie "Wet IB 2001 art. 5.3; SBR-NT NT20." ;
    mim:notation "BE" ;
    mim:populatie "Alle in Box 3 opgegeven beleggingen van een natuurlijk persoon op peildatum 1 januari, in de vorm van aandelen, obligaties, beleggingsfondsen of derivaten." .

gbo:BeroepspraktijkvormingPeriode a owl:Class ;
    rdfs:label "BeroepspraktijkvormingPeriode" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:omvangInUren ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:periodeId ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:binnen ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty gbo:omvangInUren ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:OpleidingDeelname ;
            owl:onProperty gbo:binnen ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:periodeId ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:begindatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:begindatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:begindatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:leerbedrijfIdentificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:omvangInUren ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:binnen ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:leerbedrijfIdentificatie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:periodeId ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:leerbedrijfIdentificatie ] ;
    owl:hasKey ( gbo:binnen gbo:periodeId ) ;
    skos:definition "Een afgebakende periode waarin een MBO-student bij een erkend leerbedrijf het beroepspraktijkvorming-deel van een MBO-opleiding doorloopt." ;
    skos:exactMatch gbobegrip:BeroepspraktijkvormingPeriode ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "BeroepspraktijkvormingPeriode hangt als component aan een lopende MBO-OpleidingDeelname. In de beroepsopleidende leerweg (BOL) ligt het aandeel BPV doorgaans tussen twintig en zestig procent van de studielast; in de beroepsbegeleidende leerweg (BBL) bedraagt het ten minste zestig procent. Het onderscheid BOL/BBL zit op de moederinschrijving (OpleidingDeelname.leerweg), niet op de BPV-periode zelf. Erkenning van leerbedrijven verloopt via SBB (Samenwerkingsorganisatie Beroepsonderwijs Bedrijfsleven)." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Register Onderwijsdeelnemers, cluster MBO" ;
    mim:herkomstDefinitie "Wet educatie en beroepsonderwijs (WEB) art. 7.2.8 en art. 7.2.9 (beroepspraktijkvorming en BPV-overeenkomst); WEB art. 1.5.5 (erkenning leerbedrijf door SBB)." ;
    mim:kwaliteit "MBO-instelling levert; geldigheid van de BPV-overeenkomst wordt geborgd door SBB-erkenning van het leerbedrijf en door registratie in ROD." ;
    mim:populatie "Alle BPV-perioden voor MBO-studenten met een lopende OpleidingDeelname in BOL of BBL." ;
    mim:uniekeAanduiding "periodeId binnen OpleidingDeelname" .

gbo:BuitenlandseEntiteit a owl:Class ;
    rdfs:label "BuitenlandseEntiteit" ;
    rdfs:subClassOf [ a owl:Restriction ;
