        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/belastingjaaraangifte/belastingsoort> ],
        [ a owl:Restriction ;
