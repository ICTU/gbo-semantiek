            owl:onProperty gbo:gekoppeldAan ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:gekoppeldAan ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:marktwaardePeildatum ],
        gbo:VermogensBestanddeel ;
    skos:definition "Een in Box 3 op te geven onroerende zaak die niet de eigen woning is, zoals een tweede woning, een verhuurd pand of grond, vastgesteld op WOZ-waarde of marktwaarde per peildatum 1 januari." ;
    skos:exactMatch gbobegrip:OnroerendeZaakOverigBezit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Waardering doorgaans op WOZ-waarde voor woningen. Voor verhuurde objecten gelden leegwaarde-ratios. Onderscheid met EigenWoning gaat op grond van bewoning door de belastingplichtige." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SBR-NT NT20" ;
    mim:herkomstDefinitie "Wet IB 2001 art. 5.3; SBR-NT NT20." ;
    mim:notation "OZ-overig" ;
    mim:populatie "Alle in Box 3 opgegeven onroerende zaken die niet de eigen woning zijn: tweede woningen, verhuurde panden, grond en vergelijkbare bezittingen, gewaardeerd op WOZ- of marktwaarde per peildatum 1 januari." .

