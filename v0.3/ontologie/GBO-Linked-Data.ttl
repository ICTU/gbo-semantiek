        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/belastingen/codeaardarbeidsverhouding> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/codeaardarbeidsverhouding> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/einddatumikv> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/begindatumikv> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/belastingen/coderedeneindearbeidsverhouding> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/coderedeneinde> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/nummerinkomstenverhouding> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/tussenwerkgever> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/einddatumikv> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/tussenwerkgever> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/belastingen/codesoortinkomstenverhouding> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/codesoortinkomstenverhouding> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/begindatumikv> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/codeaardarbeidsverhouding> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/personen/natuurlijkpersoon> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding/tussenpersoon> ],
