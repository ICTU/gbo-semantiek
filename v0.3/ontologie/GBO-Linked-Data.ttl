    mim:herkomstDefinitie "Wet IB 2001 art. 5.3; SBR-NT NT20." ;
    mim:notation "BS" ;
    mim:populatie "Alle in Box 3 opgegeven bank- en spaartegoeden van een natuurlijk persoon op peildatum 1 januari, bij Nederlandse of buitenlandse financiele instellingen." .

gbo:Bedrijf a owl:Class ;
    rdfs:label "Bedrijf" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:rechtsvorm ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstKVKBedrijf ;
            owl:onProperty gbo:rechtsvorm ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:rechtsvorm ],
        gbo:NietNatuurlijkPersoon ;
    skos:definition "Privaatrechtelijke commerciële entiteit die als ondernemer in het Handelsregister staat ingeschreven. Omvat rechtspersonen (BV, NV, coöperatie, OWM) en niet-rechtspersonen (eenmanszaak, VOF, CV, maatschap)." ;
    skos:exactMatch gbobegrip:Bedrijf ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Bedrijf is één van de vier functionele vormen van niet-natuurlijke persoon en groepeert commerciële entiteiten ongeacht of ze eigen rechtspersoonlijkheid hebben. De eenmanszaak hoort hier ook bij (rechtsvorm Eenmanszaak): het is administratief een niet-natuurlijke persoon, terwijl het eigenaarschap formeel via een natuurlijke persoon loopt die aan dezelfde inschrijving gekoppeld is." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR" ;
    mim:herkomstDefinitie "Handelsregisterwet 2007 art. 5 (inschrijving van ondernemingen) en Burgerlijk Wetboek boek 2 voor de privaatrechtelijke rechtspersonen. Rechtsvormen volgen de KVK Catalogus Basisprofiel." ;
    mim:populatie "Alle privaatrechtelijke commerciële entiteiten ingeschreven in het Handelsregister, met een rechtsvorm uit Codelijst~KVK_Bedrijf." ;
    mim:uniekeAanduiding "ID (geërfd)" .

gbo:BelastingAangifte a owl:Class ;
    rdfs:label "BelastingAangifte" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:aangifteIdentificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:indieningsdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:aangifteIdentificatie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:aangifteIdentificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:indieningsdatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:indieningsdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:status ],
        gbo:BelastingjaarAangifte ;
    skos:definition "Een door of namens een belastingplichtige aan de Belastingdienst ingediende opgave waarmee de grondslag voor een specifieke belastingsoort en periode wordt vastgesteld." ;
    skos:exactMatch gbobegrip:BelastingAangifte ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Dit is de algemene categorie die alle aangifteconcepten groepeert. De jaargang-gebonden variant is BelastingjaarAangifte; aangiften zonder vaste jaargang (zoals BTW) zijn voor toekomstige uitbreiding." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "AWR; SBR-NT NT20" ;
    mim:herkomstDefinitie "Algemene wet inzake rijksbelastingen art. 6 tot en met 9; SBR-NT NT20." ;
    mim:populatie "Alle door of namens belastingplichtigen ingediende aangiften voor een specifieke belastingsoort en periode." .

gbo:Belegging a owl:Class ;
