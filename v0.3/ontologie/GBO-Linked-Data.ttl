    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    mim:kardinaliteit "1 -> 0..*" .

<https://lod.gbo-semantiek.nl/krediet/zakelijkeoverigefinancieleverplichting> a owl:Class ;
