gbo:CodelijstKVKInstelling a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

gbo:CodelijstKadaster a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

gbo:CodelijstLT38 a rdfs:Datatype ;
