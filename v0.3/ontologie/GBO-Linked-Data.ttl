        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenopgave/loonsvbedrag> ],
        [ a owl:Restriction ;
