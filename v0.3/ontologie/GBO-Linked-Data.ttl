<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit> a owl:Class ;
    rdfs:label "MaatschappelijkeActiviteit" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/hoofdsbicode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/inschrijving> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/geregistreerdvia> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/einddatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:UUID ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/identificatie> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/identificatie> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/omschrijving> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/einddatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/omschrijving> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstCBSSBI ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/hoofdsbicode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/startdatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/startdatum> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit/geregistreerdvia> ] ;
    skos:altLabel "MA",
        "Onderneming" ;
    skos:definition "Een onderneming binnen een niet-natuurlijke persoon, het samenhangend geheel van bedrijfsactiviteiten dat onder één economische identiteit wordt gevoerd en dat tot precies één inschrijving in het Handelsregister leidt." ;
    skos:exactMatch gbobegrip:MaatschappelijkeActiviteit,
        gbo:MaatschappelijkeActiviteit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Alias MA is de GBO-afkorting; alias Onderneming geldt in de HR/KVK-context.",
        "MaatschappelijkeActiviteit is de ondernemings-eenheid binnen een niet-natuurlijke persoon. Eén niet-natuurlijke persoon voert één of meer ondernemingen (1..* MAs) en elke MA leidt tot precies één HR-Inschrijving; één Inschrijving kan dus meerdere MAs dragen wanneer een NNP via dezelfde KVK-registratie meerdere onderscheiden ondernemingen heeft. Continuïteit bij rechtsvormwijziging (eenmanszaak naar BV, fusie, splitsing) loopt via Partij en Inschrijving, niet via MA: Partij houdt de natuurlijke identiteit over rechtsvormen heen. Onderscheid met Activiteit: MA is de onderneming als geheel (\"viskraam-onderneming\"), Activiteit is een SBI-gecodeerde deelactiviteit (\"46.38.1 Detailhandel in vis\"). Eén MA kan via meerdere SBI-Activiteiten worden uitgewerkt." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "GBO; raakvlak NHR-onderneming (HRW art. 5)" ;
    mim:herkomstDefinitie "Conceptueel verwant met het wettelijk onderneming-begrip uit Handelsregisterwet 2007 art. 5; aanvulling uit KVK Basisprofiel-API (onderneming-attributen onder een inschrijving)." ;
    mim:populatie "Alle ondernemingen die in Nederland door niet-natuurlijke personen worden gevoerd en die tot een NHR-inschrijving leiden." ;
    mim:uniekeAanduiding "identificatie" .

<https://lod.gbo-semantiek.nl/belastingen/aftrekpostcategorie> a owl:Class ;
    rdfs:label "AftrekpostCategorie" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/belastingen/aftrekpostcategorie#Hypotheekrenteaftrek> <https://lod.gbo-semantiek.nl/belastingen/aftrekpostcategorie#Partneralimentatie> <https://lod.gbo-semantiek.nl/belastingen/aftrekpostcategorie#Lijfrente> <https://lod.gbo-semantiek.nl/belastingen/aftrekpostcategorie#Giften> <https://lod.gbo-semantiek.nl/belastingen/aftrekpostcategorie#Zorgkosten> <https://lod.gbo-semantiek.nl/belastingen/aftrekpostcategorie#WeekenduitgavenGehandicaptKind> ) ;
    skos:definition "De categorieen van aftrekposten die op grond van Wet IB 2001 in de IH-aangifte kunnen worden opgevoerd." ;
    skos:exactMatch gbobegrip:AftrekpostCategorie ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Circa 20 categorieen; opgenomen is een top-selectie van de meest voorkomende." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Wet IB 2001 + SBR-NT" ;
    mim:herkomstDefinitie "Wet IB 2001 hoofdstuk 6 (persoonsgebonden aftrek) en hoofdstuk 3 (eigenwoning); SBR-NT NT20." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/belastingen/aftrekpostcategorie#Giften>,
