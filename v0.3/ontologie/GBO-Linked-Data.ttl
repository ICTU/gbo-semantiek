            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/belastingjaaraangifte/ingangsdatumaangifte> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/personen/natuurlijkpersoon> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/belastingjaaraangifte/ingedienddoor> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/belastingjaaraangifte/ingedienddoor> ],
