            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/gezagsverhouding/indicatiecuratele> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/gezagsverhouding/indicatiegezagminderjarige> ],
        [ a owl:Restriction ;
