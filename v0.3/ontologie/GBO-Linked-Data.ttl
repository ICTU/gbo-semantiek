        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstISO3166 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/natuurlijkpersoon/landoverlijden> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:DatumIncompleet ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/natuurlijkpersoon/datumoverlijden> ],
