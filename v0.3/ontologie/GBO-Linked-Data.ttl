            owl:onProperty gbo:box3Inkomen ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:box2Inkomen ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BoxCategorie ;
            owl:onProperty gbo:boxCategorie ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:boxCategorie ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:verzamelinkomen ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:box1Inkomen ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:verzamelinkomen ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:verzamelinkomen ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:box2Inkomen ],
