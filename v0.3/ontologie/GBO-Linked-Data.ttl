            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/zekerheidsrecht/datumvestiging> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/zekerheidsrecht/aardbeslag> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/zekerheidsrecht/bedrag> ],
        [ a owl:Restriction ;
