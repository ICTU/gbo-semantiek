<https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/beschikkingstatus> a owl:Class ;
    rdfs:label "BeschikkingStatus" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/beschikkingstatus#Beroep> <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/beschikkingstatus#Bezwaar> <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/beschikkingstatus#ConceptBeschikking> <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/beschikkingstatus#DefinitieveBeschikking> <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/beschikkingstatus#HogerBeroep> <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/beschikkingstatus#Onherroepelijk> ) ;
    skos:definition "Chronologische statussen die een WOZ-beschikking doorloopt vanaf concept tot onherroepelijk worden." ;
    skos:exactMatch gbobegrip:BeschikkingStatus ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/waarde-onroerende-zaken> ;
    skos:note "De keten legt het procesverloop per WOZ-waarde vast, zodat naast de actuele status ook eerdere stadia traceerbaar blijven. Een nieuwe beschikkingsstatus voegt een rij toe aan de keten en vervangt geen eerdere waarde." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "WOZ" ;
    mim:herkomstDefinitie "Wet WOZ art. 22 en art. 24 e.v. (beschikking en bekendmaking), Algemene wet bestuursrecht hoofdstuk 6 en 7 (bezwaar en beroep) en de LV-WOZ-catalogus." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/beschikkingstatus#Beroep>,
        <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/beschikkingstatus#Bezwaar>,
