            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/beroepspraktijkvormingperiode/omvanginuren> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/beroepspraktijkvormingperiode/begindatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/beroepspraktijkvormingperiode/periodeid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/beroepspraktijkvormingperiode/leerbedrijfidentificatie> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/beroepspraktijkvormingperiode/einddatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/beroepspraktijkvormingperiode/begindatum> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/beroepspraktijkvormingperiode/leerbedrijfidentificatie> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/beroepspraktijkvormingperiode/binnen> ] ;
    owl:hasKey ( gbo:binnen <https://lod.gbo-semantiek.nl/onderwijs/beroepspraktijkvormingperiode/periodeid> ) ;
    skos:definition "Een afgebakende periode waarin een MBO-student bij een erkend leerbedrijf het beroepspraktijkvorming-deel van een MBO-opleiding doorloopt." ;
    skos:exactMatch gbobegrip:BeroepspraktijkvormingPeriode,
        gbo:BeroepspraktijkvormingPeriode ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "BeroepspraktijkvormingPeriode hangt als component aan een lopende MBO-OpleidingDeelname. In de beroepsopleidende leerweg (BOL) ligt het aandeel BPV doorgaans tussen twintig en zestig procent van de studielast; in de beroepsbegeleidende leerweg (BBL) bedraagt het ten minste zestig procent. Het onderscheid BOL/BBL zit op de moederinschrijving (OpleidingDeelname.leerweg), niet op de BPV-periode zelf. Erkenning van leerbedrijven verloopt via SBB (Samenwerkingsorganisatie Beroepsonderwijs Bedrijfsleven)." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Register Onderwijsdeelnemers, cluster MBO" ;
    mim:herkomstDefinitie "Wet educatie en beroepsonderwijs (WEB) art. 7.2.8 en art. 7.2.9 (beroepspraktijkvorming en BPV-overeenkomst); WEB art. 1.5.5 (erkenning leerbedrijf door SBB)." ;
    mim:kwaliteit "MBO-instelling levert; geldigheid van de BPV-overeenkomst wordt geborgd door SBB-erkenning van het leerbedrijf en door registratie in ROD." ;
    mim:populatie "Alle BPV-perioden voor MBO-studenten met een lopende OpleidingDeelname in BOL of BBL." ;
    mim:uniekeAanduiding "periodeId binnen OpleidingDeelname" .

<https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving> a owl:Class ;
