        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:aantalErfgenamen ],
        gbo:BelastingjaarAangifte ;
    skos:definition "De aangifte erfbelasting waarin de nalatenschap van een overledene en de verdeling daarvan over de erfgenamen wordt opgegeven." ;
    skos:exactMatch gbobegrip:AangifteErf ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Aangifte per nalatenschap; een aangifte beschrijft de verdeling over meerdere erfgenamen plus de toepasselijke vrijstellingen." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SBR-NT NT20" ;
    mim:herkomstDefinitie "Successiewet 1956; SBR-NT NT20 1e extensie." ;
    mim:notation "Erf" ;
    mim:populatie "Alle ingediende aangiften erfbelasting per nalatenschap, met de verdeling van die nalatenschap over de erfgenamen." .

gbo:AangifteIH a owl:Class ;
