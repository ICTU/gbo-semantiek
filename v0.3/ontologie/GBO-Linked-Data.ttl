gbo:Gemeente a owl:Class ;
    rdfs:label "Gemeente" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:Vlak ;
            owl:onProperty gbo:geometrie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:geometrie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstLT33 ;
            owl:onProperty gbo:gemeentecode ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:gemeentecode ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:geometrie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:gemeentenaam ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:gemeentecode ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:gemeentenaam ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:gemeentenaam ] ;
    skos:definition "Een door of krachtens de wet ingestelde territoriale openbare bestuurslaag binnen Nederland, met een eigen volksvertegenwoordiging en bevoegdheden over een afgebakend grondgebied." ;
    skos:exactMatch gbobegrip:Gemeente ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Eén gemeente kan meerdere woonplaatsen bevatten; gemeentegrenzen wijzigen sporadisch via herindeling. Codelijst LT33 wordt door BRP onderhouden en kent een einddatum-veld voor opgeheven gemeenten." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP-LT33 / CBS Kadaster (geometrie)" ;
    mim:herkomstDefinitie "Grondwet art. 123 (instelling van gemeenten); Gemeentewet; BRP-Landelijke Tabel LT33 (gemeentecodes)." ;
    mim:populatie "Alle Nederlandse gemeenten zoals vastgesteld door de Rijksoverheid en bijgehouden in BRP-LT33, inclusief historische gemeenten met einddatum." ;
    mim:uniekeAanduiding "gemeentecode" .

