            owl:onProperty gbo:wordtGevormdDoor ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:woonplaatsnaam ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:woonplaatsnaam ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:woonplaatsnaam ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:wordtGevormdDoor ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:huisletter ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty gbo:huisnummer ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:straatnaam ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:huisnummertoevoeging ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Nummeraanduiding ;
            owl:onProperty gbo:wordtGevormdDoor ],
        gbo:Adres ;
    skos:definition "Een Nederlands adres dat via een BAG-Nummeraanduiding en de bijbehorende openbare ruimte en woonplaats wordt opgebouwd." ;
    skos:exactMatch gbobegrip:Binnenlandsadres ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "BAG-gekoppeld adres met een eigen instantie per Nummeraanduiding (geen afgeleide view), geconstrueerd uit de Nummeraanduiding en de bovenliggende keten op moment van vorming." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BAG (afgeleid uit de Nummeraanduiding-keten)" ;
    mim:herkomstDefinitie "Wet BAG art. 1 (Nummeraanduiding, OpenbareRuimte, Woonplaats); Catalogus BAG 2018; RSGB-Kern Binnenlandsadres." ;
    mim:populatie "Alle Nederlandse adressen waarvoor een Nummeraanduiding is uitgegeven en die als woon-, bezoek- of correspondentieadres voor een afnemer relevant zijn." ;
    mim:uniekeAanduiding "adresId (geërfd)" .

gbo:CodelijstLT33 a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[0-9]{4}$" ] ) ] ) ] .

gbo:EuropeesKiesrecht a owl:Class ;
    rdfs:label "EuropeesKiesrecht" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/EuropeesKiesrecht#Ja> <https://lod.gbo-semantiek.nl/EuropeesKiesrecht#Nee> ) ;
    skos:definition "Indicatie of een EU-burger in Nederland is geregistreerd voor het kiesrecht voor het Europees Parlement." ;
    skos:exactMatch gbobegrip:EuropeesKiesrecht ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "Geldt alleen voor EU-burgers met andere nationaliteit dan de Nederlandse die in Nederland wonen. Opgezet als Ja/Nee-keuzelijst zodat \"geen waarde\" (niet geregistreerd of niet van toepassing) onderscheidbaar blijft van \"Nee\"." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP cat 13 Kiesrecht" ;
    mim:herkomstDefinitie "Kieswet hoofdstuk Y (kiesrecht Europees Parlement, registratie EU-burgers in andere lidstaat); Logisch Ontwerp BRP v4.3.0 cat 13." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/EuropeesKiesrecht#Ja>,
        <https://lod.gbo-semantiek.nl/EuropeesKiesrecht#Nee> .

gbo:Herkomst a owl:Class ;
    rdfs:label "Herkomst" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/Herkomst#Binnenland> <https://lod.gbo-semantiek.nl/Herkomst#Buitenland> ) ;
    skos:definition "Aanduiding of een niet-natuurlijke persoon van Nederlandse of buitenlandse herkomst is, gemeten naar de plaats van oprichting of statutaire zetel." ;
    skos:exactMatch gbobegrip:Herkomst ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "De waarde is een GBO-eigen samenvatting op NietNatuurlijkPersoon. Hij maakt filteren op binnenlandse versus buitenlandse wederpartij mogelijk zonder dat afnemers het hele subtype-onderscheid hoeven te kennen." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "GBO" ;
    mim:herkomstDefinitie "GBO-classificatie, afgeleid uit het subtype (BuitenlandseEntiteit levert Buitenland) en uit landVanOprichting." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/Herkomst#Binnenland>,
        <https://lod.gbo-semantiek.nl/Herkomst#Buitenland> .

gbo:HypothecairKredietEigenWoning a owl:Class ;
    rdfs:label "HypothecairKredietEigenWoning" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:gevestigdOp ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:achterstandstermijn ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:duration ;
            owl:onProperty gbo:achterstandstermijn ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:achterstandstermijn ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:kredietvormCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:KredietVormCode ;
            owl:onProperty gbo:kredietvormCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:kredietvormCode ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:gevestigdOp ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:KadastraleOnroerendeZaak ;
            owl:onProperty gbo:gevestigdOp ],
        gbo:KredietOvereenkomst ;
    skos:definition "Een kredietovereenkomst tot financiering van de eigen woning van de kredietnemer, waarbij een hypotheekrecht is gevestigd op die onroerende zaak, en waarvan op grond van het Algemeen Reglement CKI uitsluitend negatieve betalingservaringen aan het Centraal Krediet Informatiesysteem worden gemeld." ;
    skos:exactMatch gbobegrip:HypothecairKredietEigenWoning ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Afwijkend regime ten opzichte van de overige kredietvormen. Het krediet zelf verschijnt niet in CKI bij aangaan; alleen negatieve betalingservaringen worden geregistreerd. Voor het volledige beeld van de eigenwoning-portefeuille zijn aanvullende bronnen nodig zoals de Nationale Hypotheek Garantie-administratie of de eigen kredietadministratie van de geldverstrekker." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 19; aanvullend Wet op het financieel toezicht art. 4:34 (overkrediteringsverbod) en de richtlijn hypothecair krediet 2014/17/EU." ;
    mim:notation "HY" ;
    mim:populatie "Hypothecaire kredieten voor de eigen woning waarop een negatieve betalingservaring aan CKI is gemeld; reguliere kredieten zonder achterstand verschijnen niet in CKI." .

