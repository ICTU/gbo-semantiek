gbo:CodelijstNLQF a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

gbo:CodelijstRDWMerk a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

gbo:CodelijstRedenUitschrijving a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

gbo:CodelijstTOOI a rdfs:Datatype ;
