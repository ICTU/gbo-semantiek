        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:hoofdSbiCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Sector ;
            owl:onProperty gbo:sector ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:hoofdSbiCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:rsin ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:herkomst ],
        [ a owl:Restriction ;
