            owl:onProperty gbo:rechtsvormBuitenland ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:landVanOprichting ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstISO3166 ;
            owl:onProperty gbo:landVanOprichting ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:typeBuitenlandseEntiteit ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:typeBuitenlandseEntiteit ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:rechtsvormBuitenland ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:rechtsvormBuitenland ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:landVanOprichting ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:TypeBuitenlandseEntiteit ;
            owl:onProperty gbo:typeBuitenlandseEntiteit ],
        gbo:NietNatuurlijkPersoon ;
    skos:definition "Niet-natuurlijke persoon met hoofdvestiging buiten Nederland en één of meer Nederlandse vestigingen of aanwijzingen die inschrijving in het Handelsregister vereisen." ;
    skos:exactMatch gbobegrip:BuitenlandseEntiteit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "BuitenlandseEntiteit groepeert NNP's waarvan de juridische zetel in een ander land ligt. De buitenlandse rechtsvorm wordt als vrije tekst vastgelegd omdat er geen Nederlandse codelijst voor buitenlandse rechtsvormen bestaat; het Nederlandse type (filiaal, hoofdkantoor, permanente vestiging) wordt wel gecodeerd voor afnemers die op dat onderscheid filteren." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR" ;
    mim:herkomstDefinitie "Handelsregisterwet 2007 art. 5d (onderneming van een buitenlandse rechtspersoon met hoofd- of nevenvestiging in Nederland) en KVK Catalogus Basisprofiel voor het classificatie-deel." ;
    mim:populatie "Alle in Nederland actieve entiteiten met hoofdvestiging buiten Nederland en NHR-inschrijving op grond van een Nederlandse vestiging of aanwijzing." ;
    mim:uniekeAanduiding "ID (geërfd)" .

gbo:Buurt a owl:Class ;
    rdfs:label "Buurt" ;
