gbo:BijzonderheidsCodering a owl:Class ;
    rdfs:label "BijzonderheidsCodering" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:datumGebeurtenis ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumGebeurtenis ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:begeleidt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:bijzonderheidsCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumGebeurtenis ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BijzonderheidsCode ;
            owl:onProperty gbo:bijzonderheidsCode ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:bijzonderheidsCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:KredietOvereenkomst ;
            owl:onProperty gbo:betreft ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:begeleidt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:betreft ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:AchterstandRegistratie ;
            owl:onProperty gbo:begeleidt ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:betreft ],
        gbo:KredietFeit ;
    skos:definition "Een melding aan het Centraal Krediet Informatiesysteem dat een specifieke bijzonderheid is opgetreden bij de afhandeling van een kredietovereenkomst, gecodeerd volgens de waardenset van art. 13 Algemeen Reglement CKI." ;
    skos:exactMatch gbobegrip:BijzonderheidsCodering ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "De vijf codes verwijzen naar aflossingsregeling na achterstand, opgeeisen door zakelijke klant, afboeking door zakelijke klant, onbereikbaarheid van de consument en schriftelijke preventieve betaalregeling voor hypothecair krediet. Combinaties op één achterstand zijn toegestaan: één kredietovereenkomst kan meerdere bijzonderheids-coderingen kennen, elk met een eigen code en datum." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 13." ;
    mim:populatie "Alle aan CKI gemelde bijzonderheidscoderingen op kredietovereenkomsten, gedurende de bewaartermijn." .

gbo:Binnenlandsadres a owl:Class ;
