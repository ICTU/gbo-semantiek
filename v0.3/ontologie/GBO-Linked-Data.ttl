        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/restschuldhypothecairkredietmetnhg/voortgekomenuit> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/krediet/kredietvormcode> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/restschuldhypothecairkredietmetnhg/kredietvormcode> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/restschuldhypothecairkredietmetnhg/kredietvormcode> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/restschuldhypothecairkredietmetnhg/achterstandstermijn> ],
        <https://lod.gbo-semantiek.nl/krediet/kredietovereenkomst> ;
    skos:definition "Een resterende schuld na verkoop van een onroerende zaak waarop een hypothecair krediet rustte met dekking door de Nationale Hypotheek Garantie, voor zover de restschuld boven de meldingsdrempel valt en in CKI wordt geregistreerd." ;
    skos:exactMatch gbobegrip:RestschuldHypothecairKredietMetNHG,
        gbo:RestschuldHypothecairKredietMetNHG ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Met NHG-dekking kan de restschuld onder voorwaarden worden kwijtgescholden door het Waarborgfonds Eigen Woningen of worden overgenomen door derden binnen het NHG-stelsel. De CKI-registratie loopt gedurende dit proces door." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 21." ;
    mim:notation "RN" ;
    mim:populatie "Aan CKI gemelde restschulden boven EUR 250 na verkoop van een onroerende zaak waarop een hypothecair krediet rustte met dekking door de Nationale Hypotheek Garantie." .

<https://lod.gbo-semantiek.nl/krediet/restschuldhypothecairkredietzondernhg> a owl:Class ;
