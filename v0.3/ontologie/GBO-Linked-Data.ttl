        gbo:Schuld ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Box-3-Schuld is een fiscaal-administratief concept dat niet gelijk is aan KredietOvereenkomst in het deelmodel Krediet. Voorbeelden: onderhandse leningen, leningen bij familie, schenking-op-papier-schulden, SVn-leningen voor zover in Box 3 vallend." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SBR-NT NT20" ;
    mim:herkomstDefinitie "Wet IB 2001 art. 5.3 jo. art. 5.5 (schulddrempel); SBR-NT NT20." ;
    mim:notation "SC" ;
    mim:populatie "Alle in Box 3 opgegeven schulden van een natuurlijk persoon die boven de schulddrempel uitkomen en op peildatum 1 januari het Box-3-vermogen verminderen." .

<https://lod.gbo-semantiek.nl/belastingen/zorgtoeslag> a owl:Class ;
    rdfs:label "Zorgtoeslag" ;
