            owl:allValuesFrom gbo:Opleiding ;
            owl:onProperty gbo:voorOpleiding ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Resultaatsoort ;
            owl:onProperty gbo:resultaatsoort ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:volgtOpDeelname ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:behaaldatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:resultaatId ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:resultaatsoort ],
        [ a owl:Restriction ;
