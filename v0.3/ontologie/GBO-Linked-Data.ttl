            owl:minCardinality 1 ;
            owl:onProperty gbo:voorZakelijkRecht ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:gezamenlijkAandeel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:gezamenlijkAandeel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:aandeel ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:ZakelijkRecht ;
            owl:onProperty gbo:voorZakelijkRecht ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:tenaamgesteldOp ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Partij ;
            owl:onProperty gbo:tenaamgesteldOp ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:tenaamgesteldOp ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Indicatie ;
            owl:onProperty gbo:gezamenlijkAandeel ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:datumIngang ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:datumEinde ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:aandeel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumEinde ],
        gbo:Voorkomen ;
    owl:hasKey ( gbo:tenaamgesteldOp gbo:voorZakelijkRecht gbo:datumIngang ) ;
    skos:definition "De geregistreerde rechtsbetrekking tussen een rechthebbende partij en een zakelijk recht op een kadastraal onroerende zaak, met vermelding van het aandeel waarmee de partij in het recht deelneemt." ;
    skos:exactMatch gbobegrip:Tenaamstelling ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "MIM-element: Relatieklasse (verdinglijkte relatie).",
        "Tenaamstelling is een verbinding met eigen kenmerken tussen Partij en ZakelijkRecht. Meervoudige eigendomsverhoudingen worden expliciet gemodelleerd: een echtpaar in gemeenschap van goederen krijgt twee tenaamstellingen met gezamenlijkAandeel = ja, mede-eigendom van een vakantiehuis krijgt meerdere tenaamstellingen met elk een breuk-aandeel, en erfopvolging leidt tot een nieuwe tenaamstelling met latere datumIngang terwijl de oude een datumEinde krijgt. De Haal-Centraal-API consolideert Tenaamstelling × ZakelijkRecht × Partij tot één ZakelijkGerechtigde-resource; GBO houdt de drie zaken gescheiden omdat dat rijker is voor historie en meervoudige tenaamstelling." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK (basisregistratie)" ;
    mim:herkomstDefinitie "Kadasterwet; Burgerlijk Wetboek Boek 3 (registergoederen, mede-eigendom art. 166 e.v.); BRK-Catalogus (associatieklasse Tenaamstelling)." ;
    mim:populatie "Alle in de BRK geregistreerde tenaamstellingen, historisch en actueel, die een rechthebbende koppelen aan een zakelijk recht op een kadastraal onroerende zaak." ;
    mim:uniekeAanduiding "Samengesteld uit (Partij, ZakelijkRecht, datumIngang)" .

gbo:URI a rdfs:Datatype ;
