            owl:maxCardinality 1 ;
            owl:onProperty gbo:documentdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumIngang ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:aardZakelijkRecht ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:documentdatum ],
