            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/zakelijkkrediet/meldingsdrempel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeactiviteit> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/zakelijkkrediet/tenbehoevevan> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/zakelijkkrediet/tenbehoevevan> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/zakelijkkrediet/kredietvormcode> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/zakelijkkrediet/meldingsdrempel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/krediet/kredietvormcode> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/zakelijkkrediet/kredietvormcode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:duration ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/zakelijkkrediet/achterstandstermijn> ],
        <https://lod.gbo-semantiek.nl/krediet/kredietovereenkomst> ;
    skos:definition "Een kredietovereenkomst aangegaan ten behoeve van een onderneming waarbij sprake is van persoonlijke aansprakelijkheid van een of meer natuurlijke personen, en die boven de meldingsdrempel valt." ;
    skos:exactMatch gbobegrip:ZakelijkKrediet,
        gbo:ZakelijkKrediet ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Sleutel-criterium voor opname in CKI is persoonlijke aansprakelijkheid. Een BV of NV met eigen rechtspersoonlijkheid zonder borgstelling of medeschuldenaarschap van een natuurlijk persoon wordt niet gemeld. Bij ZZP-ondernemers en eenmanszaken is de aansprakelijkheid prive en zijn de kredieten dus wel meldingsplichtig." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 24." ;
    mim:notation "ZK" ;
    mim:populatie "Aan CKI gemelde zakelijke kredieten boven EUR 1.000 met persoonlijke aansprakelijkheid van een of meer natuurlijke personen (typisch ZZP en eenmanszaken, en BV/NV met persoonlijke borgstelling)." .

<https://lod.gbo-semantiek.nl/onderwijs/beroepspraktijkvormingperiode> a owl:Class ;
    rdfs:label "BeroepspraktijkvormingPeriode" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
