        gbo:Partij ;
    skos:definition "Een mens als drager van burgerlijke rechten en plichten." ;
    skos:exactMatch gbobegrip:NatuurlijkPersoon ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "De symmetrische partner-relatie loopt via Huwelijk.partners (kardinaliteit 2); zie het objecttype Huwelijk.",
        "NatuurlijkPersoon omvat zowel mensen die in een Nederlandse persoonsregistratie zijn opgenomen als mensen daarbuiten. Registratielagen (IngeschrevenPersoon, Ingezetene, NietIngezetene) zijn specifieke varianten binnen het natuurlijk-persoon-concept. Overlijden hangt als attribuut-cluster aan NatuurlijkPersoon zelf." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP cat 01 (basis); semantische verbreding voor personen buiten de Nederlandse persoonsregistratie" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek art. 1:1 BW (algemene grondslag voor het rechtssubject mens); Logisch Ontwerp BRP v4.3.0 §1 voor de operationele invulling binnen de basisregistratie." ;
    mim:kwaliteit "Voor BRP-ingeschrevenen geldt de BRP-bijhouding-status (opschortingBijhouding, inOnderzoek) als kwaliteitsindicator. Voor niet-ingeschrevenen ontbreekt zo'n centrale kwaliteitsstempel; bronvermelding per attribuut is dan leidend." ;
    mim:populatie "Alle natuurlijke personen die voor een overheidsorganisatie relevant zijn: ingeschrevenen in BRP-GBA en BRP-RNI, en niet-ingeschrevenen (buitenlandse partner van een ingezetene, historisch persoon zonder persoonslijst, buitenlandse eigenaar van een eenmanszaak)." ;
    mim:uniekeAanduiding "ID (geërfd van Partij)" .

gbo:KredietVormCode a owl:Class ;
    rdfs:label "KredietVormCode" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/KredietVormCode#AK> <https://lod.gbo-semantiek.nl/KredietVormCode#RK> <https://lod.gbo-semantiek.nl/KredietVormCode#SH> <https://lod.gbo-semantiek.nl/KredietVormCode#SK> <https://lod.gbo-semantiek.nl/KredietVormCode#HY> <https://lod.gbo-semantiek.nl/KredietVormCode#HO> <https://lod.gbo-semantiek.nl/KredietVormCode#RH> <https://lod.gbo-semantiek.nl/KredietVormCode#RN> <https://lod.gbo-semantiek.nl/KredietVormCode#OA> <https://lod.gbo-semantiek.nl/KredietVormCode#RO> <https://lod.gbo-semantiek.nl/KredietVormCode#ZK> <https://lod.gbo-semantiek.nl/KredietVormCode#ZO> ) ;
    skos:definition "De codelijst van kredietvormen die op grond van het Algemeen Reglement CKI in het Centraal Krediet Informatiesysteem worden geregistreerd, met per kredietvorm een unieke tweeletter-code." ;
    skos:exactMatch gbobegrip:KredietVormCode ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Gebruikt door: KredietOvereenkomst.kredietvormCode (en daarmee alle concrete subklassen).",
        "Twaalf vaste waarden. Kort krediet (art. 26) heeft geen vaste tweeletter-code." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 15 en art. 16 tot en met 26." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/KredietVormCode#AK>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#HO>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#HY>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#OA>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#RH>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#RK>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#RN>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#RO>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#SH>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#SK>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#ZK>,
        <https://lod.gbo-semantiek.nl/KredietVormCode#ZO> .

