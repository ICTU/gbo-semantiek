gbo:AchterstandRegistratie a owl:Class ;
    rdfs:label "AchterstandRegistratie" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:betreft ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumGebeurtenis ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:omvangAchterstand ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:betreft ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BijzonderheidsCodering ;
            owl:onProperty gbo:begeleidDoor ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:begeleidDoor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:opgelostDoor ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:HerstelMelding ;
            owl:onProperty gbo:opgelostDoor ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:opgelostDoor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:datumGebeurtenis ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:KredietOvereenkomst ;
            owl:onProperty gbo:betreft ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:omvangAchterstand ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:omvangAchterstand ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumGebeurtenis ],
        gbo:KredietFeit ;
    skos:definition "Een melding aan het Centraal Krediet Informatiesysteem dat een kredietnemer een achterstand heeft opgelopen in de nakoming van zijn verplichtingen onder een specifieke kredietovereenkomst, na het verstrijken van de voor die kredietvorm geldende achterstandstermijn." ;
    skos:exactMatch gbobegrip:AchterstandRegistratie ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "De achterstandstermijn start bij de eerste niet of niet-volledig voldane termijn en verschilt per kredietvorm: twee maanden voor aflopend krediet, hypothecair krediet overige onroerende zaken, saneringskrediet, zakelijk krediet en operational autolease; drie maanden voor doorlopend krediet, hypothecair krediet eigen woning en restschuld; vier maanden voor de overige financiele verplichtingen prive en zakelijk." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 12 lid 1 en 2; aanlevering door de erkende kredietverstrekker." ;
    mim:populatie "Alle aan CKI gemelde achterstanden op kredietovereenkomsten, inclusief inmiddels herstelde voor zover binnen de bewaartermijn van vijf jaar." .

gbo:Alfanumeriek a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( gbo:Tekst [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[A-Za-z0-9]*$" ] ) ] ) ] .

gbo:BelastingjaarAangifte a owl:Class ;
    rdfs:label "BelastingjaarAangifte" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:belastingsoort ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:NatuurlijkPersoon ;
            owl:onProperty gbo:ingediendDoor ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:belastingsoort ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ingangsdatumAangifte ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:ingangsdatumAangifte ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:einddatumAangifte ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ingediendDoor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:ingediendDoor ],
        [ owl:unionOf ( gbo:AangifteErf gbo:AangifteIH gbo:AangifteSchenk ) ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:einddatumAangifte ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:einddatumAangifte ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty gbo:belastingjaar ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:belastingjaar ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:belastingsoort ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:belastingjaar ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:ingangsdatumAangifte ],
        gbo:BelastingAangifte ;
    skos:definition "Een belastingaangifte die op een specifiek belastingjaar betrekking heeft en die de grondslag voor de aanslag over dat jaar vaststelt." ;
    skos:exactMatch gbobegrip:BelastingjaarAangifte ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Drie concrete varianten zijn opgenomen: AangifteIH (Wet IB), AangifteSchenk en AangifteErf (Successiewet 1956). Vennootschapsbelasting valt onder de bredere SBR-NT NT20 maar is voor de eerste batch buiten scope." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SBR-NT NT20" ;
    mim:herkomstDefinitie "AWR art. 9 jo. de materiele belastingwetten; SBR-NT NT20 entrypoints per belastingsoort en jaar." ;
    mim:populatie "Alle belastingaangiften die op een specifiek belastingjaar betrekking hebben, ongeacht de belastingsoort (IH, Schenk, Erf)." .

gbo:BoxCategorie a owl:Class ;
    rdfs:label "BoxCategorie" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/BoxCategorie#Box1WerkEnWoning> <https://lod.gbo-semantiek.nl/BoxCategorie#Box2AanmerkelijkBelang> <https://lod.gbo-semantiek.nl/BoxCategorie#Box3SparenEnBeleggen> ) ;
