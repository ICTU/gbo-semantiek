                        owl:withRestrictions ( [ xsd:pattern "^[1-9][0-9]{3} ?[A-Z]{2}$" ] ) ] ) ] .

gbo:SoortActiviteit a owl:Class ;
    rdfs:label "SoortActiviteit" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/SoortActiviteit#Hoofd> <https://lod.gbo-semantiek.nl/SoortActiviteit#Neven> ) ;
    skos:definition "Aanduiding of een geregistreerde activiteit een hoofd- of nevenactiviteit is binnen de inschrijving of vestiging waarop zij is vastgelegd." ;
    skos:exactMatch gbobegrip:SoortActiviteit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Per drager (Inschrijving of Vestiging) is op enig moment precies één activiteit met Hoofd toegestaan; nul of meer met Neven. Het attribuut isHoofdactiviteit op Activiteit is een booleaanse projectie van deze waarde." ;
