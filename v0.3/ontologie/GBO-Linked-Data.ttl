        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenopgave/ingehoudenloonheffing> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenopgave/aangifteperiode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenopgave/loonhuidigperiodebedrag> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenopgave/loonhuidigperiodebedrag> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/belastingen/inkomstenverhouding> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/inkomstenopgave/binneninkomstenverhouding> ] ;
    skos:definition "De aggregatie van loongegevens van een werknemer binnen een aangifte loonheffingen over een aangifteperiode, opgebouwd uit een of meer inkomstenperioden en alle daarop horende loonbestanddelen." ;
    skos:exactMatch gbobegrip:Inkomstenopgave,
        gbo:Inkomstenopgave ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Per inkomstenverhouding en per aangifteperiode is er een inkomstenopgave. De aangifteperiode is doorgaans een maand, vier weken of week, afhankelijk van de loonperiode van de inhoudingsplichtige." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Loonheffingen 2026" ;
    mim:herkomstDefinitie "Gegevensspecificaties aangifte loonheffingen 2026." ;
    mim:populatie "Alle aggregaties van loongegevens van een werknemer binnen een aangifte loonheffingen over een aangifteperiode (typisch maand, vier weken of week)." .

<https://lod.gbo-semantiek.nl/krediet/bijzonderheidscodering> a owl:Class ;
    rdfs:label "BijzonderheidsCodering" ;
