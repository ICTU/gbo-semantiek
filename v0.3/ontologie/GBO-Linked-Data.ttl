        <https://lod.gbo-semantiek.nl/hoofdmodel/partij> ;
    skos:definition "Een mens als drager van burgerlijke rechten en plichten." ;
    skos:exactMatch gbobegrip:NatuurlijkPersoon,
        gbo:NatuurlijkPersoon ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "De symmetrische partner-relatie loopt via Huwelijk.partners (kardinaliteit 2); zie het objecttype Huwelijk.",
        "NatuurlijkPersoon omvat zowel mensen die in een Nederlandse persoonsregistratie zijn opgenomen als mensen daarbuiten. Registratielagen (IngeschrevenPersoon, Ingezetene, NietIngezetene) zijn specifieke varianten binnen het natuurlijk-persoon-concept. Overlijden hangt als attribuut-cluster aan NatuurlijkPersoon zelf." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP cat 01 (basis); semantische verbreding voor personen buiten de Nederlandse persoonsregistratie" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek art. 1:1 BW (algemene grondslag voor het rechtssubject mens); Logisch Ontwerp BRP v4.3.0 §1 voor de operationele invulling binnen de basisregistratie." ;
    mim:kwaliteit "Voor BRP-ingeschrevenen geldt de BRP-bijhouding-status (opschortingBijhouding, inOnderzoek) als kwaliteitsindicator. Voor niet-ingeschrevenen ontbreekt zo'n centrale kwaliteitsstempel; bronvermelding per attribuut is dan leidend." ;
    mim:populatie "Alle natuurlijke personen die voor een overheidsorganisatie relevant zijn: ingeschrevenen in BRP-GBA en BRP-RNI, en niet-ingeschrevenen (buitenlandse partner van een ingezetene, historisch persoon zonder persoonslijst, buitenlandse eigenaar van een eenmanszaak)." ;
    mim:uniekeAanduiding "ID (geërfd van Partij)" .

<https://lod.gbo-semantiek.nl/krediet/kredietvormcode> a owl:Class ;
    rdfs:label "KredietVormCode" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#AK> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#RK> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#SH> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#SK> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#HY> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#HO> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#RH> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#RN> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#OA> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#RO> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#ZK> <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#ZO> ) ;
    skos:definition "De codelijst van kredietvormen die op grond van het Algemeen Reglement CKI in het Centraal Krediet Informatiesysteem worden geregistreerd, met per kredietvorm een unieke tweeletter-code." ;
    skos:exactMatch gbobegrip:KredietVormCode ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Gebruikt door: KredietOvereenkomst.kredietvormCode (en daarmee alle concrete subklassen).",
        "Twaalf vaste waarden. Kort krediet (art. 26) heeft geen vaste tweeletter-code." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 15 en art. 16 tot en met 26." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#AK>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#HO>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#HY>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#OA>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#RH>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#RK>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#RN>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#RO>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#SH>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#SK>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#ZK>,
        <https://lod.gbo-semantiek.nl/krediet/kredietvormcode#ZO> .

gbo:Numeriek a rdfs:Datatype ;
    owl:equivalentClass xsd:integer .

<https://lod.gbo-semantiek.nl/datatypes/bedrag> a owl:Class ;
    rdfs:label "Bedrag" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/datatypes/bedrag/waarde> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstISO4217 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/datatypes/bedrag/valuta> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/datatypes/bedrag/valuta> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Decimaal ;
            owl:onProperty <https://lod.gbo-semantiek.nl/datatypes/bedrag/waarde> ] ;
    skos:definition "Geldbedrag: numerieke waarde met expliciete valuta-aanduiding (ISO 4217). Voor binnenlandse toepassingen impliciet EUR; de valuta wordt expliciet bij internationale uitwisseling." ;
    skos:exactMatch gbo:Bedrag ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/datatypes> ;
    mim:herkomst "ISO 4217" ;
    mim:stereotype "DataType" .

gbo:Datum a rdfs:Datatype ;
    owl:equivalentClass xsd:date .

gbo:Tekst a rdfs:Datatype ;
    owl:equivalentClass xsd:string .


