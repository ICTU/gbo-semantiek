        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/indicatiebezwaarberoep> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/vastgesteldewaarde> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/indicatie> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/indicatiebezwaarberoep> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/waardepeildatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/ingangsdatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/beschikkingstatus> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/beschikkingsstatussen> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/beschikkingsnummer> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/vastgesteldewaarde> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/ingangsdatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Identificatie ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/beschikkingsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/einddatum> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/waardepeildatum> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/beschikkingsstatussen> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/statuswozwaarde> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde/statuswozwaarde> ],
