            owl:onProperty gbo:betreft ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:begindatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:betreft ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:begindatum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:sv_loonbedrag ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:sv_loonbedrag ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:begindatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:soortFeit ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:sv_loonbedrag ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:soortFeit ] ;
    skos:definition "Een afzonderlijk feit in het arbeids- of inkomensverleden van een natuurlijk persoon, zoals een periode in dienst, een periode met uitkering of een leerwerk-periode, dat relevant is voor de berekening van werknemersverzekerings-rechten." ;
    skos:exactMatch gbobegrip:ArbeidsverledenFeit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/werk-en-inkomen> ;
    skos:note "Arbeidsverleden bepaalt onder andere de WW-duur. ArbeidsverledenFeit dient als bouwsteen waarmee UWV een arbeidsverleden-overzicht kan opstellen, met feit-typen voor dienstverband, uitkeringsperiode, leerwerk-periode en periode van zelfstandig werk." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SGR cluster Arbeidsverhouding" ;
    mim:herkomstDefinitie "Werkloosheidswet (refertes 26-uit-36-weken en 4-uit-5-jaren); SGR cluster Arbeidsverhouding." ;
    mim:populatie "Alle afzonderlijke feiten in het arbeids- of inkomensverleden van een natuurlijk persoon (dienstverband, uitkeringsperiode, leerwerk-periode of periode zelfstandig werk) die relevant zijn voor de berekening van werknemersverzekerings-rechten." .

gbo:AuthentiekInkomen a owl:Class ;
    rdfs:label "AuthentiekInkomen" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:gegrondvestOp ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:inkomenBedrag ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:vaststellingsbron ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:gegrondvestOp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:inkomenBedrag ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:vaststellingsdatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:vaststellingsbron ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:belastingjaar ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:vaststellingsdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty gbo:belastingjaar ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:vaststellingsdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:NatuurlijkPersoon ;
            owl:onProperty gbo:gegrondvestOp ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:belastingjaar ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:vaststellingsbron ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:inkomenBedrag ] ;
    skos:definition "Het door de Belastingdienst vastgestelde verzamelinkomen of belastbaar loon van een natuurlijk persoon over een belastingjaar, aangewezen als authentiek gegeven in de Basisregistratie Inkomen." ;
    skos:exactMatch gbobegrip:AuthentiekInkomen ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "De BRI is een register met een enkel authentiek gegeven: het inkomen per persoon per belastingjaar. De waarde komt uit een definitief vastgestelde IH-aangifte, of, voor personen zonder IH-aangifte, uit de loonaangifteketen. Afnemers van inkomensgegevens in inkomensafhankelijke regelingen zijn verplicht het BRI-inkomen te gebruiken." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "BRI; Stelselcatalogus" ;
    mim:herkomstDefinitie "Wet basisregistratie inkomen; Stelselcatalogus BRI, begrip authentiek_inkomen_gegeven." ;
    mim:populatie "Alle door de Belastingdienst vastgestelde authentieke inkomensgegevens per natuurlijk persoon per belastingjaar, opgenomen in de Basisregistratie Inkomen." .

gbo:Belanghebbende a owl:Class ;
    rdfs:label "Belanghebbende" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:datumEinde ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:rolBelanghebbende ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:vanWOZObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:WOZObject ;
            owl:onProperty gbo:vanWOZObject ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:datumIngang ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumIngang ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumEinde ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:isPartij ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:isPartij ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Partij ;
            owl:onProperty gbo:isPartij ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:aandeel ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:rolBelanghebbende ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumEinde ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumIngang ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:aandeel ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:RolBelanghebbende ;
            owl:onProperty gbo:rolBelanghebbende ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:vanWOZObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Breuk ;
            owl:onProperty gbo:aandeel ] ;
    owl:hasKey ( gbo:isPartij gbo:vanWOZObject gbo:rolBelanghebbende gbo:datumIngang ) ;
    skos:definition "De geregistreerde rechtsbetrekking tussen een partij en een WOZ-object, waarbij de partij voor de Wet WOZ als eigenaar, gebruiker of beide rollen heeft en daarom de WOZ-beschikking ontvangt voor het object." ;
    skos:exactMatch gbobegrip:Belanghebbende ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/waarde-onroerende-zaken> ;
    skos:note "Belanghebbende is de fiscale tegenpartij die de WOZ-beschikking ontvangt en aanslagontvanger is voor afgeleide heffingen. De relatie kan afwijken van de BRK-tenaamstelling (juridisch eigenaar uit het Kadaster) bij erfpacht of opstal, en van de BAG-bewoner (feitelijk gebruiker uit BRP) die niet altijd fiscaal-gebruiker is. GBO gebruikt één relatie met een rol-aanduiding (Eigenaar, Gebruiker, EigenaarEnGebruiker), in plaats van twee afzonderlijke velden op het WOZ-object zoals in HC-WOZ." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "WOZ" ;
    mim:herkomstDefinitie "Wet WOZ art. 24 e.v. (bekendmaking beschikking), Algemene wet bestuursrecht art. 1:2 (algemeen belanghebbende-begrip) en de LV-WOZ-catalogus." ;
    mim:populatie "Alle in de LV-WOZ geregistreerde belanghebbende-relaties: eigenaars en gebruikers van WOZ-objecten, inclusief historische rollen." ;
