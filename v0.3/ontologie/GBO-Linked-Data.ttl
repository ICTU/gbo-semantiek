gbo:BeschikkingStatus a owl:Class ;
    rdfs:label "BeschikkingStatus" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/BeschikkingStatus#Beroep> <https://lod.gbo-semantiek.nl/BeschikkingStatus#Bezwaar> <https://lod.gbo-semantiek.nl/BeschikkingStatus#ConceptBeschikking> <https://lod.gbo-semantiek.nl/BeschikkingStatus#DefinitieveBeschikking> <https://lod.gbo-semantiek.nl/BeschikkingStatus#HogerBeroep> <https://lod.gbo-semantiek.nl/BeschikkingStatus#Onherroepelijk> ) ;
    skos:definition "Chronologische statussen die een WOZ-beschikking doorloopt vanaf concept tot onherroepelijk worden." ;
    skos:exactMatch gbobegrip:BeschikkingStatus ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/waarde-onroerende-zaken> ;
    skos:note "De keten legt het procesverloop per WOZ-waarde vast, zodat naast de actuele status ook eerdere stadia traceerbaar blijven. Een nieuwe beschikkingsstatus voegt een rij toe aan de keten en vervangt geen eerdere waarde." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "WOZ" ;
    mim:herkomstDefinitie "Wet WOZ art. 22 en art. 24 e.v. (beschikking en bekendmaking), Algemene wet bestuursrecht hoofdstuk 6 en 7 (bezwaar en beroep) en de LV-WOZ-catalogus." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/BeschikkingStatus#Beroep>,
        <https://lod.gbo-semantiek.nl/BeschikkingStatus#Bezwaar>,
        <https://lod.gbo-semantiek.nl/BeschikkingStatus#ConceptBeschikking>,
        <https://lod.gbo-semantiek.nl/BeschikkingStatus#DefinitieveBeschikking>,
        <https://lod.gbo-semantiek.nl/BeschikkingStatus#HogerBeroep>,
        <https://lod.gbo-semantiek.nl/BeschikkingStatus#Onherroepelijk> .

gbo:BeslissingSoort a owl:Class ;
    rdfs:label "BeslissingSoort" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/BeslissingSoort#Toekenning> <https://lod.gbo-semantiek.nl/BeslissingSoort#Herziening> <https://lod.gbo-semantiek.nl/BeslissingSoort#Beeindiging> <https://lod.gbo-semantiek.nl/BeslissingSoort#Afwijzing> <https://lod.gbo-semantiek.nl/BeslissingSoort#Bezwaar> <https://lod.gbo-semantiek.nl/BeslissingSoort#Sanctie> ) ;
    skos:definition "De soorten besluit die in het SUWI-stelsel door UWV of SVB kunnen worden genomen over uitkeringen en voorzieningen." ;
    skos:exactMatch gbobegrip:BeslissingSoort ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/werk-en-inkomen> ;
    skos:note "De waardenset onderscheidt de juridisch relevante beslissoorten die een uitkering doen ontstaan, wijzigen of laten eindigen, plus de procedurele soorten afwijzing, beslissing op bezwaar en sanctie. Per uitkering kan een keten van Beslissingen bestaan, beginnend bij een Toekenning en eventueel gevolgd door Herziening of Beeindiging.",
        "Gebruikt door: Beslissing.beslissingSoort." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SGR" ;
    mim:herkomstDefinitie "SGR cluster Beslissing." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/BeslissingSoort#Afwijzing>,
        <https://lod.gbo-semantiek.nl/BeslissingSoort#Beeindiging>,
        <https://lod.gbo-semantiek.nl/BeslissingSoort#Bezwaar>,
        <https://lod.gbo-semantiek.nl/BeslissingSoort#Herziening>,
        <https://lod.gbo-semantiek.nl/BeslissingSoort#Sanctie>,
        <https://lod.gbo-semantiek.nl/BeslissingSoort#Toekenning> .

gbo:Leerweg a owl:Class ;
    rdfs:label "Leerweg" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/Leerweg#BOL> <https://lod.gbo-semantiek.nl/Leerweg#BBL> <https://lod.gbo-semantiek.nl/Leerweg#BB> <https://lod.gbo-semantiek.nl/Leerweg#KB> <https://lod.gbo-semantiek.nl/Leerweg#GL> <https://lod.gbo-semantiek.nl/Leerweg#TL> ) ;
    skos:definition "De manier waarop een onderwijsdeelname is ingericht, voor zover de sectorregels die onderscheiden." ;
