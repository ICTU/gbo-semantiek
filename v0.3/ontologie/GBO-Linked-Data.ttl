            owl:onProperty gbo:gemeenteVanInschrijving ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:datumEersteInschrijving ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:opschortingBijhouding ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:tin ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:heeftNationaliteit ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:heeftImmigratie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Alfanumeriek ;
            owl:onProperty gbo:aNummer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:heeftImmigratie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:EuropeesKiesrecht ;
            owl:onProperty gbo:europeesKiesrecht ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:verificatie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:aNummer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:bsn ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:OpschortingBijhouding ;
            owl:onProperty gbo:opschortingBijhouding ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Nationaliteit ;
            owl:onProperty gbo:heeftNationaliteit ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumEersteInschrijving ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstLT33 ;
            owl:onProperty gbo:gemeenteVanInschrijving ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Alfanumeriek ;
            owl:onProperty gbo:tin ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:europeesKiesrecht ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:heeftVerblijfstitel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:uitsluitingKiesrecht ],
        [ owl:unionOf ( gbo:Ingezetene gbo:NietIngezetene ) ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:inOnderzoek ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:verificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:gezag ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:tin ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Gezagsverhouding ;
            owl:onProperty gbo:gezag ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:europeesKiesrecht ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:DatumIncompleet ;
            owl:onProperty gbo:datumEersteInschrijving ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:bsn ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:gezag ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:bsn ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:gemeenteVanInschrijving ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Indicatie ;
            owl:onProperty gbo:inOnderzoek ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Verificatie ;
            owl:onProperty gbo:verificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:aNummer ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Verblijfstitel ;
            owl:onProperty gbo:heeftVerblijfstitel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:heeftVerblijfstitel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:uitsluitingKiesrecht ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:inOnderzoek ],
        gbo:NatuurlijkPersoon,
        gbo:Voorkomen ;
    owl:hasKey ( gbo:bsn ) ;
    skos:definition "Een natuurlijke persoon die in de Basisregistratie Personen is opgenomen, hetzij als ingezetene van een Nederlandse gemeente, hetzij als niet-ingezetene in de Registratie Niet-Ingezetenen." ;
    skos:exactMatch gbobegrip:IngeschrevenPersoon ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "IngeschrevenPersoon is de drager van de BRP-persoonslijst-gegevens (identificatienummers, bijhouding-status, kiesrechtgegevens) en het aanknopingspunt voor de BRP-persoonslijst-categorieën (nationaliteit, huwelijk, verblijfstitel, gezagsverhouding, immigratie). Het objecttype draagt het Voorkomen-mixin zodat alle BRP-gegevens bitemporeel kunnen worden gevoerd. De twee concrete varianten Ingezetene en NietIngezetene staan onder dit objecttype." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP" ;
    mim:herkomstDefinitie "Wet BRP art. 1.2 en art. 2.1; Logisch Ontwerp BRP v4.3.0 §1 (registratiedomein BRP)." ;
    mim:kwaliteit "Geborgd via BRP-bijhouding-status: opschortingBijhouding, inOnderzoek, verificatie." ;
    mim:populatie "Alle natuurlijke personen met een actieve of opgeschorte BRP-inschrijving (BRP-GBA of BRP-RNI)." ;
    mim:uniekeAanduiding "bsn" .

gbo:InkomensOndersteuning a owl:Class ;
    rdfs:label "InkomensOndersteuning" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:bedragPeriode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:bedragPeriode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:bedragPeriode ],
        [ owl:unionOf ( gbo:Toeslag gbo:Uitkering ) ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:identificatie ] ;
    skos:definition "Een door of namens de overheid aan een natuurlijk persoon verstrekte financiele bijdrage met als doel inkomensondersteuning, in de vorm van een inkomensafhankelijke regeling of een sociale-zekerheidsuitkering." ;
    skos:exactMatch gbobegrip:InkomensOndersteuning ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/werk-en-inkomen> ;
    skos:note "Cross-domein algemene categorie boven Toeslag (in Belastingen) en Uitkering (in dit deelmodel). Beide takken delen de basis-eigenschappen rechthebbende natuurlijk persoon, toekenningsperiode, bedrag en grondslag-beschikking; de varianten verschillen in juridische basis, uitvoerings-organisatie en aanvraagprocedure.",
        "belastingen.md documenteert ditzelfde objecttype zonder attributen; de wiki-pagina's moeten nog worden geharmoniseerd (zie ook Toeslag in het deelmodel Belastingen, dat dit supertype deelt)." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Cross-domein abstractie" ;
    mim:herkomstDefinitie "Algemene wet inkomensafhankelijke regelingen (Awir) voor toeslagen; Wet SUWI en de afzonderlijke werknemers- en volksverzekeringswetten voor uitkeringen; GBO-Kern-abstractie." ;
    mim:populatie "Alle door of namens de overheid aan natuurlijke personen verstrekte financiele bijdragen met als doel inkomensondersteuning, omvattende zowel toeslagen (Awir) als sociale-zekerheidsuitkeringen (werknemers- en volksverzekeringen)." .

