        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/appartementsrechtsplitsing/datumsplitsing> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/appartementsrechtsplitsing/documentdatum> ],
        [ a owl:Restriction ;
