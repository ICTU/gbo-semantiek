        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/overigefinancieleverplichtingprive/achterstandstermijn> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/overigefinancieleverplichtingprive/kredietvormcode> ],
        <https://lod.gbo-semantiek.nl/krediet/kredietovereenkomst> ;
    skos:definition "Een overige privefinanciele verplichting van een natuurlijk persoon die niet onder een specifieke kredietvorm valt en waarvan op grond van het Algemeen Reglement CKI alleen negatieve betalingservaringen aan het Centraal Krediet Informatiesysteem worden gemeld." ;
    skos:exactMatch gbobegrip:OverigeFinancieleVerplichtingPrive,
        gbo:OverigeFinancieleVerplichtingPrive ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Restcategorie voor private verplichtingen die niet in een andere kredietvorm passen. Veelvoorkomende toepassing: borgstellingen (zie BorgstellingRol bij Schuldhulpverlening en borgstelling)." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 23." ;
    mim:notation "RO" ;
    mim:populatie "Aan CKI gemelde overige private financiele verplichtingen van natuurlijke personen die niet onder een andere kredietvorm vallen, voor zover een negatieve betalingservaring is gemeld." .

<https://lod.gbo-semantiek.nl/krediet/restschuldhypothecairkredietmetnhg> a owl:Class ;
    rdfs:label "RestschuldHypothecairKredietMetNHG" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:duration ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/restschuldhypothecairkredietmetnhg/achterstandstermijn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
