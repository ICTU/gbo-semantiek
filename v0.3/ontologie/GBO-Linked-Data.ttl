            owl:onProperty gbo:datumInsolventie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:actief ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ontbonden ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty gbo:insolventieCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Indicatie ;
            owl:onProperty gbo:ontbonden ],
        [ a owl:Restriction ;
