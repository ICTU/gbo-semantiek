            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/hypothecairkredietoverigeonroerendezaken/kredietvormcode> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/hypothecairkredietoverigeonroerendezaken/gevestigdop> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:duration ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/hypothecairkredietoverigeonroerendezaken/achterstandstermijn> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/hypothecairkredietoverigeonroerendezaken/meldingsdrempel> ],
        <https://lod.gbo-semantiek.nl/krediet/kredietovereenkomst> ;
    skos:definition "Een kredietovereenkomst waarbij een hypotheekrecht is gevestigd op een onroerende zaak die niet de eigen woning van de kredietnemer is, zoals een tweede woning, een verhuurde woning of een beleggingspand, en die boven de meldingsdrempel valt." ;
    skos:exactMatch gbobegrip:HypothecairKredietOverigeOnroerendeZaken,
        gbo:HypothecairKredietOverigeOnroerendeZaken ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Reguliere aanlevering bij aangaan, in tegenstelling tot hypothecair krediet eigen woning. De distinctie tussen HY en HO zit in de rol van de onroerende zaak." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 20." ;
    mim:notation "HO" ;
    mim:populatie "Alle aan CKI gemelde hypothecaire kredieten op onroerende zaken anders dan de eigen woning (tweede woning, verhuurpand, beleggingspand) boven de meldingsdrempel van EUR 250." .

<https://lod.gbo-semantiek.nl/krediet/kortkrediet> a owl:Class ;
    rdfs:label "KortKrediet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/kortkrediet/looptijdmaanden> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/kortkrediet/meldingsdrempel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/kortkrediet/meldingsdrempel> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/kortkrediet/looptijdmaanden> ],
        <https://lod.gbo-semantiek.nl/krediet/kredietovereenkomst> ;
    skos:definition "Een kredietovereenkomst met een korte looptijd, doorgaans korter dan drie maanden, met een betrekkelijk klein kredietbedrag, en die op grond van de specifieke bepalingen van het Algemeen Reglement CKI in CKI wordt geregistreerd." ;
    skos:exactMatch gbobegrip:KortKrediet,
        gbo:KortKrediet ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Anders dan de overige kredietvormen heeft kort krediet geen vaste tweeletter-code in de codelijst KredietVormCode. Het reglement bespreekt deze vorm afzonderlijk vanwege de afwijkende looptijd en informatie-eisen. Toepassings-context: dagkredieten en mini-leningen van enkele honderden euros met een termijn van weken.",
        "Let op: het van KredietOvereenkomst geërfde verplichte attribuut kredietvormCode kent voor deze vorm geen vaste waarde (geen tweeletter-code in de wiki)." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 26." ;
    mim:populatie "Aan CKI gemelde kortlopende kredieten (dagkredieten, mini-leningen) met een looptijd doorgaans korter dan drie maanden." .

