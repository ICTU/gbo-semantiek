            owl:minCardinality 1 ;
            owl:onProperty gbo:documentnummer ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:akteverwijzing ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:akteverwijzing ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:aardZakelijkRecht ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumEinde ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
