        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Vlak ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/wijk/geometrie> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/wijk/wijkcode> ] ;
    skos:definition "Een aaneengesloten gedeelte van een gemeente waarvan de grenzen primair zijn gebaseerd op sociaal-geografische kenmerken, vastgesteld door het Centraal Bureau voor de Statistiek." ;
    skos:exactMatch gbobegrip:Wijk,
        gbo:Wijk ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Wijk staat formeel buiten de BAG (CBS-data); opgenomen vanwege gangbaarheid bij beleids- en analyse-afnemers. CBS herziet de wijkgrenzen jaarlijks; mutaties komen via CBS Open Data." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "CBS Wijk- en Buurtkaart" ;
    mim:herkomstDefinitie "CBS Wijk- en Buurtkaart (jaarlijkse vaststelling); NEN 3610 voor het algemene patroon. BAG-formeel kent geen Wijk." ;
    mim:populatie "Alle CBS-wijken binnen Nederland zoals jaarlijks vastgesteld in de CBS Wijk- en Buurtkaart." ;
    mim:uniekeAanduiding "wijkcode (CBS-code)" .

<https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats> a owl:Class ;
    rdfs:label "Woonplaats" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/statuswoonplaats> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats/status> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Vlak ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats/geometrie> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BAGID ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats/identificatie> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats/status> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats/woonplaatsnaam> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats/ingemeente> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/gemeente> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats/ingemeente> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats/woonplaatsnaam> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats/identificatie> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/woonplaats/geometrie> ],
        <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit>,
        <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen> ;
    skos:definition "Een door het bevoegde gemeentelijke gezag als zodanig aangewezen en van een naam voorzien gedeelte van het grondgebied van de gemeente, dat dient als plaatsaanduiding voor adressen." ;
    skos:exactMatch gbobegrip:Woonplaats,
        gbo:Woonplaats ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Plaatsaanduiding voor adressen; levert de plaatsnaam voor het volledige adres. Niet gelijk aan Gemeente: één gemeente kan meerdere woonplaatsen bevatten (gemeente Súdwest-Fryslân heeft er 70+), en gemeentelijke herindelingen kunnen plaatsvinden zonder dat woonplaatsen wijzigen." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BAG (basisregistratie)" ;
    mim:herkomstDefinitie "Wet BAG art. 1; Catalogus BAG 2018 §2.1; IMBAG Woonplaats." ;
    mim:populatie "Alle door gemeenten aangewezen woonplaatsen in Nederland zoals geregistreerd in de BAG, inclusief aangewezen en ingetrokken woonplaatsen." ;
    mim:uniekeAanduiding "identificatie (BAGID)" .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/bedrijf> a owl:Class ;
    rdfs:label "Bedrijf" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/bedrijf/rechtsvorm> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstKVKBedrijf ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/bedrijf/rechtsvorm> ],
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/nietnatuurlijkpersoon> ;
    skos:definition "Privaatrechtelijke commerciële entiteit die als ondernemer in het Handelsregister staat ingeschreven. Omvat rechtspersonen (BV, NV, coöperatie, OWM) en niet-rechtspersonen (eenmanszaak, VOF, CV, maatschap)." ;
    skos:exactMatch gbobegrip:Bedrijf,
        gbo:Bedrijf ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Bedrijf is één van de vier functionele vormen van niet-natuurlijke persoon en groepeert commerciële entiteiten ongeacht of ze eigen rechtspersoonlijkheid hebben. De eenmanszaak hoort hier ook bij (rechtsvorm Eenmanszaak): het is administratief een niet-natuurlijke persoon, terwijl het eigenaarschap formeel via een natuurlijke persoon loopt die aan dezelfde inschrijving gekoppeld is." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR" ;
    mim:herkomstDefinitie "Handelsregisterwet 2007 art. 5 (inschrijving van ondernemingen) en Burgerlijk Wetboek boek 2 voor de privaatrechtelijke rechtspersonen. Rechtsvormen volgen de KVK Catalogus Basisprofiel." ;
    mim:populatie "Alle privaatrechtelijke commerciële entiteiten ingeschreven in het Handelsregister, met een rechtsvorm uit Codelijst~KVK_Bedrijf." ;
    mim:uniekeAanduiding "ID (geërfd)" .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/buitenlandseentiteit> a owl:Class ;
    rdfs:label "BuitenlandseEntiteit" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/buitenlandseentiteit/landvanoprichting> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/buitenlandseentiteit/rechtsvormbuitenland> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/buitenlandseentiteit/typebuitenlandseentiteit> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/typebuitenlandseentiteit> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/buitenlandseentiteit/typebuitenlandseentiteit> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/buitenlandseentiteit/rechtsvormbuitenland> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstISO3166 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/buitenlandseentiteit/landvanoprichting> ],
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/nietnatuurlijkpersoon> ;
    skos:definition "Niet-natuurlijke persoon met hoofdvestiging buiten Nederland en één of meer Nederlandse vestigingen of aanwijzingen die inschrijving in het Handelsregister vereisen." ;
    skos:exactMatch gbobegrip:BuitenlandseEntiteit,
        gbo:BuitenlandseEntiteit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "BuitenlandseEntiteit groepeert NNP's waarvan de juridische zetel in een ander land ligt. De buitenlandse rechtsvorm wordt als vrije tekst vastgelegd omdat er geen Nederlandse codelijst voor buitenlandse rechtsvormen bestaat; het Nederlandse type (filiaal, hoofdkantoor, permanente vestiging) wordt wel gecodeerd voor afnemers die op dat onderscheid filteren." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR" ;
    mim:herkomstDefinitie "Handelsregisterwet 2007 art. 5d (onderneming van een buitenlandse rechtspersoon met hoofd- of nevenvestiging in Nederland) en KVK Catalogus Basisprofiel voor het classificatie-deel." ;
    mim:populatie "Alle in Nederland actieve entiteiten met hoofdvestiging buiten Nederland en NHR-inschrijving op grond van een Nederlandse vestiging of aanwijzing." ;
    mim:uniekeAanduiding "ID (geërfd)" .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeinstelling> a owl:Class ;
    rdfs:label "MaatschappelijkeInstelling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeinstelling/typemaatschappelijk> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/indicatie> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeinstelling/anbistatus> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/typemaatschappelijk> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeinstelling/typemaatschappelijk> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/maatschappelijkeinstelling/anbistatus> ],
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/instelling> ;
    skos:definition "Privaatrechtelijke niet-natuurlijke persoon zonder winstoogmerk, werkzaam in een maatschappelijke sector zoals onderwijs, zorg, religie, sport en cultuur, welzijn of belangenbehartiging." ;
    skos:exactMatch gbobegrip:MaatschappelijkeInstelling,
        gbo:MaatschappelijkeInstelling ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "MaatschappelijkeInstelling is een concreet subtype van Instelling voor de privaatrechtelijke non-profit-entiteiten. Sectoraal onderscheid (onderwijs, zorg, religie, sport-cultuur, welzijn, branche-belangen, overig) wordt gevangen in een typering-attribuut; de ANBI-status van de Belastingdienst staat als indicatie omdat dat fiscaal relevant is voor giften en vrijstellingen." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR; BW2; Belastingdienst (ANBI)" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek boek 2 (rechtspersonen zonder winstoogmerk: stichting, vereniging, kerkgenootschap); ANBI-status volgt uit de Algemene wet inzake rijksbelastingen art. 5b." ;
    mim:populatie "Alle privaatrechtelijke non-profit-entiteiten ingeschreven in het Handelsregister met een rechtsvorm uit Codelijst~KVK_Instelling." ;
    mim:uniekeAanduiding "ID (geërfd)" .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving> a owl:Class ;
    rdfs:label "Naamgeving" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/handelsnamen> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/einddatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/startdatum> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/ookgenoemd> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/statutairenaam> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/einddatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/ookgenoemd> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/startdatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/statutairenaam> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/naam> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/naam> ] ;
    skos:definition "De meerlagige naamstructuur van een inschrijving in het Handelsregister, omvattend de statutaire naam, één of meer handelsnamen en eventueel alternatieve benamingen, elk met een eigen geldigheidstermijn." ;
    skos:exactMatch gbobegrip:Naamgeving,
        gbo:Naamgeving ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "De unieke aanduiding is samengesteld (naam + startdatum) en geldt per Inschrijving; die scoping is niet als LinkML-identifier of unique_keys uitdrukbaar, zie annotatie mim:uniekeAanduiding.",
        "Naamgeving is een gegevensgroep op Inschrijving-niveau die meerdere naam-componenten bundelt: statutaire naam (bij geregistreerde statuten), handelsnaam (onder welke naam de onderneming naar buiten treedt), en alternatieve benamingen zoals ookGenoemd voor verenigingen en stichtingen. Geldigheidsperiodes per naamrepresentatie maken historische naamvoering traceerbaar. Vestigings-handelsnamen worden in dit model niet op Vestiging zelf vastgelegd, maar afgedekt via Activiteit-context op Vestiging waar dat nodig is." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR" ;
    mim:herkomstDefinitie "Handelsregisterwet 2007 art. 9-11 (naamregistratie); KVK Naamgeving-API als operationele invulling van het meerlagige naamconcept." ;
    mim:populatie "Alle geldige en historische naamvoeringen per NHR-Inschrijving." ;
    mim:uniekeAanduiding "samengesteld (naam + startdatum per Inschrijving)" .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/naamgeving/handelsnamen> a owl:DatatypeProperty ;
    rdfs:label "handelsnamen" ;
    skos:definition "Eén of meer handelsnamen waaronder de onderneming naar buiten treedt." ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "KVK Naamgeving-API." ;
    mim:authentiek "Basisgegeven" ;
    mim:formeleHistorie true ;
    mim:herkomst "NHR" ;
    mim:materieleHistorie true .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/overheidsinstelling> a owl:Class ;
    rdfs:label "Overheidsinstelling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/overheidsinstelling/typeoverheid> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/overheidsinstelling/bevoegdgezagcode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/typeoverheid> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/overheidsinstelling/typeoverheid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstTOOI ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/overheidsinstelling/bevoegdgezagcode> ],
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/instelling> ;
    skos:definition "Publiekrechtelijke niet-natuurlijke persoon belast met een publieke taak, zoals Rijksoverheid, ministerie, provincie, gemeente, waterschap, zelfstandig bestuursorgaan (ZBO) of rechtspersoon met een wettelijke taak (RWT)." ;
    skos:exactMatch gbobegrip:Overheidsinstelling,
        gbo:Overheidsinstelling ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Overheidsinstelling is een concreet subtype van Instelling voor publieke organen. De bestuurlijke typering staat in typeOverheid; daarnaast is een optionele koppeling naar het TOOI-register beschikbaar via bevoegdGezagCode, voor URI-traceability naar het KOOP-register van overheidsorganisaties. Niet elke overheidsinstelling staat in TOOI; de koppeling is daarom optioneel." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR; TOOI (KOOP)" ;
    mim:herkomstDefinitie "Algemene wet bestuursrecht (definitie bestuursorgaan); organieke wetten (Gemeentewet, Provinciewet, Waterschapswet); Kaderwet zelfstandige bestuursorganen; TOOI-register (Thesaurus voor Overheids Informatie- en Organisatie-objecten) als operationele identificatiebron." ;
    mim:populatie "Alle Nederlandse bestuursorganen en publieke instellingen, NHR-ingeschreven of herkenbaar via TOOI." ;
    mim:uniekeAanduiding "ID (geërfd)" .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/overigenietnatuurlijkpersoon> a owl:Class ;
    rdfs:label "OverigeNietNatuurlijkPersoon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/overigenietnatuurlijkpersoon/omschrijving> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/overigenietnatuurlijkpersoon/omschrijving> ],
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/nietnatuurlijkpersoon> ;
    skos:definition "Restcategorie voor niet-natuurlijke personen die niet eenduidig onder bedrijf, instelling of buitenlandse entiteit vallen, bedoeld voor migratie- en historische gevallen." ;
    skos:exactMatch gbobegrip:OverigeNietNatuurlijkPersoon,
        gbo:OverigeNietNatuurlijkPersoon ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "OverigeNietNatuurlijkPersoon vangt entiteiten op die in de huidige modellering niet eenduidig in een van de drie hoofdcategorieën passen. Bedoeld voor migratie van legacy-bestanden, historische gevallen of nog niet geclassificeerde entiteiten. Het toelichtings-veld omschrijving is verplicht om reden van plaatsing in deze categorie expliciet te maken; nieuwe gevallen moeten zoveel mogelijk in een van de hoofdcategorieën landen." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "GBO" ;
    mim:herkomstDefinitie "GBO-eigen restcategorie, geen wettelijke definitie. Bewust catch-all met afbakening dat het gebruik spaarzaam moet zijn." ;
    mim:populatie "Niet-natuurlijke personen die niet eenduidig in een van de drie hoofdcategorieën vallen; bewust beperkt gebruik." ;
    mim:uniekeAanduiding "ID (geërfd)" .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/rechtstoestand> a owl:Class ;
    rdfs:label "Rechtstoestand" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/rechtstoestand/actief> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/rechtstoestand/datuminsolventie> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/rechtstoestand/ontbonden> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/rechtstoestand/insolventiecode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/indicatie> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/rechtstoestand/actief> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/indicatie> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/rechtstoestand/ontbonden> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/rechtstoestand/insolventiecode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/rechtstoestand/datuminsolventie> ] ;
    skos:definition "De juridische en administratieve status van een inschrijving in het Handelsregister, beschrijvend of de inschrijving actief is, of er insolventie-omstandigheden zijn en of de entiteit is ontbonden." ;
    skos:exactMatch gbobegrip:Rechtstoestand,
        gbo:Rechtstoestand ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "De unieke aanduiding \"per Inschrijving (precies één)\" is geen eigen attribuut en daarom niet als LinkML-identifier uitdrukbaar; zie annotatie mim:uniekeAanduiding.",
        "Rechtstoestand bundelt statusvelden die conceptueel samenhoren maar in de KVK-API geen zelfstandige resource vormen. Precies één rechtstoestand per inschrijving geeft het actuele beeld; historie loopt via de tweevoudige tijdregistratie op de inschrijving. Een eventuele insolventie-procedure (faillissement, surseance, schuldsanering) wordt in dit model niet als eigen objecttype gevolgd, alleen via de coderingsattribuut." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR" ;
    mim:herkomstDefinitie "Handelsregisterwet 2007 art. 17-20 (registratie van faillissement, surseance van betaling en schuldsanering); KVK Basisprofiel-API voor de statusvelden op inschrijving." ;
    mim:populatie "Eén actuele rechtstoestand per NHR-Inschrijving." ;
    mim:uniekeAanduiding "per Inschrijving (precies één)" .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging> a owl:Class ;
    rdfs:label "Vestiging" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/datumaanvang> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BAGID ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/adresseerbaarobjectid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/datumeinde> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/adresseerbaarobjectid> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Vestigingsnummer ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/vestigingsnummer> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/typevestiging> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/vestigingsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/datumeinde> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/activiteit> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/heeftactiviteit> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/typevestiging> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/typevestiging> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/datumaanvang> ] ;
    skos:definition "Een fysieke of functionele locatie waar een onderneming activiteiten uitvoert, geïdentificeerd door een vestigingsnummer en optioneel gekoppeld aan een BAG-adresseerbaar object." ;
    skos:exactMatch gbobegrip:Vestiging,
        gbo:Vestiging ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Vestiging is gekoppeld aan Inschrijving: één inschrijving heeft één of meer vestigingen, waarvan precies één hoofdvestiging op enig moment (typeVestiging = Hoofdvestiging). Adres-koppeling loopt via adresseerbaarObjectId naar het deelmodel Adressen en gebouwen; de vestiging zelf bevat geen adres-kenmerken. Activiteiten op vestigingsniveau (locatie-specifieke uitvoering, hoofd-of-neven-SBI per locatie) lopen via een nul-of-meer-relatie naar Activiteit. Verleden waarden van vestiging worden over de tijd bewaard, zodat verhuizing en typering door de tijd correct na te lopen zijn." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR; HRW 2007 art. 9-11" ;
    mim:herkomstDefinitie "Handelsregisterwet 2007 art. 9-11 (vestigingsregistratie); KVK Vestigingsprofiel-API als operationele invulling; BAG-koppeling via NEN 3610-identificatie voor het adresseerbaar object." ;
    mim:populatie "Alle vestigingen geregistreerd in het NHR, precies één hoofdvestiging per Inschrijving plus 0..n nevenvestigingen." ;
    mim:uniekeAanduiding "vestigingsnummer" .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/vestiging/heeftactiviteit> a owl:ObjectProperty ;
