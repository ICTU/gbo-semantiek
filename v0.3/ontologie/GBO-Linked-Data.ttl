            owl:allValuesFrom gbo:StatusWoonplaats ;
            owl:onProperty gbo:status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Gemeente ;
            owl:onProperty gbo:inGemeente ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:woonplaatsnaam ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:geometrie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:inGemeente ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:inGemeente ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:woonplaatsnaam ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:geometrie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        gbo:Datakwaliteit,
        gbo:Voorkomen ;
    skos:definition "Een door het bevoegde gemeentelijke gezag als zodanig aangewezen en van een naam voorzien gedeelte van het grondgebied van de gemeente, dat dient als plaatsaanduiding voor adressen." ;
    skos:exactMatch gbobegrip:Woonplaats ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Plaatsaanduiding voor adressen; levert de plaatsnaam voor het volledige adres. Niet gelijk aan Gemeente: één gemeente kan meerdere woonplaatsen bevatten (gemeente Súdwest-Fryslân heeft er 70+), en gemeentelijke herindelingen kunnen plaatsvinden zonder dat woonplaatsen wijzigen." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BAG (basisregistratie)" ;
    mim:herkomstDefinitie "Wet BAG art. 1; Catalogus BAG 2018 §2.1; IMBAG Woonplaats." ;
    mim:populatie "Alle door gemeenten aangewezen woonplaatsen in Nederland zoals geregistreerd in de BAG, inclusief aangewezen en ingetrokken woonplaatsen." ;
    mim:uniekeAanduiding "identificatie (BAGID)" .

gbo:ZakelijkKrediet a owl:Class ;
    rdfs:label "ZakelijkKrediet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:meldingsdrempel ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:tenBehoeveVan ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:duration ;
            owl:onProperty gbo:achterstandstermijn ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:KredietVormCode ;
            owl:onProperty gbo:kredietvormCode ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:meldingsdrempel ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:MaatschappelijkeActiviteit ;
            owl:onProperty gbo:tenBehoeveVan ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:kredietvormCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:kredietvormCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:tenBehoeveVan ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:meldingsdrempel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:achterstandstermijn ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:achterstandstermijn ],
        gbo:KredietOvereenkomst ;
    skos:definition "Een kredietovereenkomst aangegaan ten behoeve van een onderneming waarbij sprake is van persoonlijke aansprakelijkheid van een of meer natuurlijke personen, en die boven de meldingsdrempel valt." ;
    skos:exactMatch gbobegrip:ZakelijkKrediet ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Sleutel-criterium voor opname in CKI is persoonlijke aansprakelijkheid. Een BV of NV met eigen rechtspersoonlijkheid zonder borgstelling of medeschuldenaarschap van een natuurlijk persoon wordt niet gemeld. Bij ZZP-ondernemers en eenmanszaken is de aansprakelijkheid prive en zijn de kredieten dus wel meldingsplichtig." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 24." ;
    mim:notation "ZK" ;
    mim:populatie "Aan CKI gemelde zakelijke kredieten boven EUR 1.000 met persoonlijke aansprakelijkheid van een of meer natuurlijke personen (typisch ZZP en eenmanszaken, en BV/NV met persoonlijke borgstelling)." .

gbo:ZakelijkRecht a owl:Class ;
    rdfs:label "ZakelijkRecht" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:documentdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:AardZakelijkRecht ;
