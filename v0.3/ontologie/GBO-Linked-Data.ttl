gbo:FinancieleVerplichting a owl:Class ;
    rdfs:label "FinancieleVerplichting" ;
    rdfs:subClassOf [ owl:unionOf ( gbo:KredietOvereenkomst gbo:SchuldhulpverleningTraject ) ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:bewaartermijnPeriode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:bewaartermijnPeriode ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:einddatumWerkelijk ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:einddatumWerkelijk ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:einddatumWerkelijk ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:duration ;
            owl:onProperty gbo:bewaartermijnPeriode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:ingangsdatum ] ;
    skos:definition "Een verplichting van een natuurlijk persoon of niet-natuurlijk persoon tot het verrichten van een geldelijke prestatie aan een tegenpartij, ontstaan uit overeenkomst of uit een wettelijke regeling." ;
    skos:exactMatch gbobegrip:FinancieleVerplichting ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Abstract; concrete varianten zijn KredietOvereenkomst en SchuldhulpverleningTraject. De grens van het concept ligt bij verplichtingen die via een geformaliseerde registratie zichtbaar zijn voor derden. Privaatrechtelijke verplichtingen zonder registratie zoals een persoonlijke lening tussen familieleden vallen er niet onder." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI; Wgs" ;
    mim:herkomstDefinitie "GBO-Kern. Afgeleid uit het verbintenisrecht in het Burgerlijk Wetboek en uit de Wet op het financieel toezicht art. 4:32 (sectorregistratie kredietverlening). Operationele invulling: Algemeen Reglement CKI 2024-07-01 art. 1 voor het kredietdomein en Wet gemeentelijke schuldhulpverlening voor het schuldhulpverleningstraject." ;
    mim:populatie "Abstract. Concrete populatie wordt bepaald door de subklassen KredietOvereenkomst en SchuldhulpverleningTraject: alle in CKI of in een gemeentelijke beschikking geformaliseerde geldelijke verplichtingen van een natuurlijk of niet-natuurlijk persoon." .

gbo:FiscaalFeit a owl:Class ;
    rdfs:label "FiscaalFeit" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:peildatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:categorie ],
        [ owl:unionOf ( gbo:Aftrekpost gbo:VermogensBestanddeel ) ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:belastingjaar ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:peildatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:categorie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:categorie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty gbo:belastingjaar ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:belastingjaar ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:peildatum ] ;
    skos:definition "Een fiscaal relevant gegeven over een belastingplichtige dat in een specifiek belastingjaar als component in een belastingaangifte verschijnt, zoals een vermogensbestanddeel, een aftrekpost of een inkomensbestanddeel." ;
    skos:exactMatch gbobegrip:FiscaalFeit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Twee concrete families: VermogensBestanddeel (Box 3, peildatum 1 januari) en Aftrekpost (Box 1, gedurende belastingjaar)." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SBR-NT NT20" ;
    mim:herkomstDefinitie "SBR-NT NT20; Wet IB 2001 en Successiewet 1956 voor de inhoudelijke grondslag." ;
    mim:populatie "Alle fiscaal relevante componenten die in een belastingjaar als onderdeel van een belastingaangifte voorkomen: vermogensbestanddelen, aftrekposten en vergelijkbare inkomensbestanddelen." .

