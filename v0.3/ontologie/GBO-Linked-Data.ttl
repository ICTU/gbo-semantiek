<https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject> a owl:Class ;
    rdfs:label "WOZObject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
