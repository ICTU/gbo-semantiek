        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:aansprakelijkheid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:rsin ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:naam ],
        [ a owl:Restriction ;
