        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/openbareruimte/kortenaam> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BAGID ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/openbareruimte/identificatie> ],
