                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[A-Z0-9-]{6,8}$" ] ) ] ) ] .

gbo:ObjectAanduiding a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

gbo:Punt a rdfs:Datatype ;
