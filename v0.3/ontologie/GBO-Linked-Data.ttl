    owl:unionOf ( <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#Gerealiseerd> <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#NietGerealiseerd> <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#VerblijfsobjectInGebruikNietIngemeten> <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#VerblijfsobjectInGebruik> <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#VerbouwingVerblijfsobject> <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#VerblijfsobjectIngetrokken> <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#VerblijfsobjectBuitenGebruik> <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#PlaatsAangewezen> <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#PlaatsIngetrokken> ) ;
    skos:definition "Aanduiding van de levenscyclus-status van een verblijfsobject, ligplaats of standplaats." ;
    skos:exactMatch gbobegrip:StatusAdresseerbaarObject ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Bundelt de statussen van de drie concrete AdresseerbaarObject-vormen. Een verblijfsobject doorloopt een eigen reeks van bouw tot intrekking; ligplaatsen en standplaatsen kennen een kortere reeks rond aanwijzing en intrekking." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BAG" ;
    mim:herkomstDefinitie "Wet BAG; Catalogus BAG 2018 §2.5, §2.6, §2.7; IMBAG-attribuutdomein." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#Gerealiseerd>,
        <https://lod.gbo-semantiek.nl/StatusAdresseerbaarObject#NietGerealiseerd>,
