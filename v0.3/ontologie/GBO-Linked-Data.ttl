        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstISO3166 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/immigratie/landvanwaar> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/immigratie/landbinnenkomst> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/immigratie/datumvestiginginnederland> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstISO3166 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/immigratie/landbinnenkomst> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/immigratie/landvanwaar> ] ;
    skos:definition "De gebeurtenis waarbij een ingeschreven persoon zich vanuit het buitenland in Nederland vestigt en daarmee in de BRP wordt opgenomen of zijn inschrijving wordt geheractiveerd." ;
    skos:exactMatch gbobegrip:Immigratie,
        gbo:Immigratie ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "Immigratie hangt eenmalig (0..1) aan IngeschrevenPersoon en legt vast wanneer en waarvandaan de persoon zich in Nederland heeft gevestigd. Latere wijzigingen van adres binnen Nederland zijn geen immigratie." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP cat 08" ;
    mim:herkomstDefinitie "Wet BRP art. 2.39 (aangifte van vestiging vanuit het buitenland); BRP cat 08 grp 14 Inschrijving; Logisch Ontwerp BRP v4.3.0." ;
    mim:populatie "Alle ingeschreven personen die zich vanuit het buitenland in Nederland hebben gevestigd, voor zover die vestigingsgebeurtenis als immigratie is geregistreerd." .

