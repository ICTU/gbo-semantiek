gbo:Aansprakelijkheid a owl:Class ;
    rdfs:label "Aansprakelijkheid" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/Aansprakelijkheid#Beperkt> <https://lod.gbo-semantiek.nl/Aansprakelijkheid#Onbeperkt> <https://lod.gbo-semantiek.nl/Aansprakelijkheid#Hoofdelijk> <https://lod.gbo-semantiek.nl/Aansprakelijkheid#Publiek> ) ;
    skos:definition "Aanduiding van het aansprakelijkheidskarakter dat voor een rechtsvorm geldt: in welke mate eigenaren, bestuurders of vennoten persoonlijk instaan voor verplichtingen van de entiteit." ;
    skos:exactMatch gbobegrip:Aansprakelijkheid ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Het attribuut is een GBO-eigen afleiding op NietNatuurlijkPersoon die de rechtsvorm samenvat in vier brede klassen. Het ondersteunt vragen rond kredietrisico, contractering en publieke aansprakelijkheid zonder dat afnemers de volledige rechtsvorm-codelijst hoeven te interpreteren." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "GBO" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek boek 2 (rechtspersonen, beperkte aansprakelijkheid) en boek 7A (personenvennootschappen, hoofdelijke en onbeperkte aansprakelijkheid); GBO-classificatie afgeleid uit de rechtsvorm-codelijsten." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/Aansprakelijkheid#Beperkt>,
        <https://lod.gbo-semantiek.nl/Aansprakelijkheid#Hoofdelijk>,
        <https://lod.gbo-semantiek.nl/Aansprakelijkheid#Onbeperkt>,
        <https://lod.gbo-semantiek.nl/Aansprakelijkheid#Publiek> .

gbo:AardBeslag a owl:Class ;
    rdfs:label "AardBeslag" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/AardBeslag#Conservatoir> <https://lod.gbo-semantiek.nl/AardBeslag#Executoriaal> <https://lod.gbo-semantiek.nl/AardBeslag#Fiscaal> <https://lod.gbo-semantiek.nl/AardBeslag#OverigBeslag> ) ;
    skos:definition "Aard van een op een kadastraal onroerende zaak gelegd beslag, gerelateerd aan de juridische grondslag en het doel ervan." ;
    skos:exactMatch gbobegrip:AardBeslag ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Alleen van toepassing bij Zekerheidsrecht.typeZekerheidsrecht = Beslag. Conservatoir beslag dient ter zekerstelling vooruitlopend op een gerechtelijke uitspraak; executoriaal beslag volgt op een titel en strekt tot verhaal; fiscaal beslag wordt door de Belastingdienst gelegd op grond van de Invorderingswet." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK" ;
    mim:herkomstDefinitie "Wetboek van Burgerlijke Rechtsvordering (beslagregels); Invorderingswet 1990 (fiscaal beslag); BRK-Catalogus." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/AardBeslag#Conservatoir>,
        <https://lod.gbo-semantiek.nl/AardBeslag#Executoriaal>,
        <https://lod.gbo-semantiek.nl/AardBeslag#Fiscaal>,
        <https://lod.gbo-semantiek.nl/AardBeslag#OverigBeslag> .

gbo:Adres a owl:Class ;
    rdfs:label "Adres" ;
    rdfs:subClassOf [ owl:unionOf ( gbo:Binnenlandsadres gbo:Buitenlandsadres gbo:Locatie gbo:Postadres gbo:VerblijfplaatsOnbekend ) ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:adresId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:volledigAdres ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:adresId ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:UUID ;
            owl:onProperty gbo:adresId ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:volledigAdres ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:volledigAdres ] ;
    skos:definition "Een leesbare aanduiding van een locatie of correspondentiepunt waarmee een persoon of organisatie kan worden bereikt of waarop een rechtsbetrekking is gevestigd, samengesteld uit elementen van de bronregisters BAG, RSGB en BRP." ;
    skos:exactMatch gbobegrip:Adres ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Adres is een samengestelde, leesbare projectie boven BAG-data, niet een zelfstandig authentiek gegeven. BAG levert de authentieke onderliggende data; de adres-projectie is voor afnemers in één keer leesbaar. De functionele rol (woon, bezoek, post, zetel) staat in de verwijzing vanuit de gebruiker (NatuurlijkPersoon, Vestiging), niet als kenmerk van Adres zelf." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "GBO (samengestelde view boven BAG, RSGB en BRP)" ;
    mim:herkomstDefinitie "Wet basisregistraties adressen en gebouwen (binnenlandsadres via de BAG-keten Nummeraanduiding, OpenbareRuimte, Woonplaats); BRP Logisch Ontwerp §5.8 (woon- en briefadres-context); RSGB-Kern (overkoepelend type Adres)." ;
    mim:populatie "Alle adressen die voor een overheidsorganisatie als adresseerbaarheid of correspondentiepunt relevant zijn." ;
    mim:uniekeAanduiding "adresId (UUID, GBO-eigen)" .

gbo:AdresseerbaarObject a owl:Class ;
    rdfs:label "AdresseerbaarObject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:TypeAdresseerbaarObject ;
            owl:onProperty gbo:typeAdresseerbaarObject ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:typeAdresseerbaarObject ],
        [ owl:unionOf ( gbo:Ligplaats gbo:Standplaats gbo:Verblijfsobject ) ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ligtInBuurt ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:heeftNummeraanduiding ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:typeAdresseerbaarObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Buurt ;
            owl:onProperty gbo:ligtInBuurt ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Nummeraanduiding ;
            owl:onProperty gbo:heeftNummeraanduiding ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:ligtInBuurt ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BAGID ;
            owl:onProperty gbo:identificatie ],
        gbo:Datakwaliteit,
        gbo:Voorkomen ;
    skos:altLabel "AO" ;
    skos:definition "Een object waaraan formeel één of meer adressen kunnen worden toegekend door het bevoegde gemeentelijke gezag, ter identificatie van een eenheid van gebruik, ligging of verblijf." ;
    skos:exactMatch gbobegrip:AdresseerbaarObject ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Overkoepelend type voor de drie BAG-vormen die formeel een adres krijgen: Verblijfsobject (binnen pand), Ligplaats (water) en Standplaats (terrein). Een adresseerbaar object heeft minstens één Nummeraanduiding (het hoofdadres) en eventueel nevenadressen. Afnemers zoals HR (addresseerbaarObjectId), BRP (adresseerbaarObjectIdentificatie) en WOZ komen vaak via dit overkoepelende type binnen." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BAG (basisregistratie)" ;
    mim:herkomstDefinitie "Wet BAG; Catalogus BAG 2018 §2.5, §2.7; IMBAG (gedeeld patroon voor Verblijfsobject, Ligplaats en Standplaats)." ;
    mim:populatie "Alle adresseerbare objecten in Nederland zoals aangewezen en geregistreerd door de bevoegde gemeente in de BAG." ;
    mim:uniekeAanduiding "identificatie (BAGID)" .

gbo:Aftrekpost a owl:Class ;
    rdfs:label "Aftrekpost" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:bedragJaar ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:bedragJaar ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:AftrekpostCategorie ;
            owl:onProperty gbo:categorie ],
