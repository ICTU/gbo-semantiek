<https://lod.gbo-semantiek.nl/krediet/aflopendkrediet> a owl:Class ;
    rdfs:label "AflopendKrediet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/krediet/kredietvormcode> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/aflopendkrediet/kredietvormcode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/aflopendkrediet/looptijdmaanden> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/aflopendkrediet/achterstandstermijn> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/aflopendkrediet/looptijdmaanden> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/aflopendkrediet/kredietvormcode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:duration ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/aflopendkrediet/achterstandstermijn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/aflopendkrediet/meldingsdrempel> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/aflopendkrediet/meldingsdrempel> ],
        <https://lod.gbo-semantiek.nl/krediet/kredietovereenkomst> ;
    skos:definition "Een kredietovereenkomst met een vooraf vastgesteld kredietbedrag, een vaste looptijd en periodieke aflossingen die het krediet stapsgewijs verminderen tot nul aan het einde van de looptijd." ;
    skos:exactMatch gbobegrip:AflopendKrediet,
        gbo:AflopendKrediet ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "De klassieke persoonlijke lening met vaste maandtermijnen. Het verschil met doorlopend krediet zit in de looptijd en het eindbedrag: een aflopend krediet heeft een vaste looptijd en loopt aan het einde af tot nul; een doorlopend krediet kent geen vaste looptijd. Meldingsplichtig boven EUR 250." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 16." ;
    mim:notation "AK" ;
    mim:populatie "Alle aan CKI gemelde aflopende kredieten boven de meldingsdrempel van EUR 250, gedurende de looptijd plus de bewaartermijn na einddatum." .

<https://lod.gbo-semantiek.nl/krediet/doorlopendkrediet> a owl:Class ;
    rdfs:label "DoorlopendKrediet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/doorlopendkrediet/kredietlimiet> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/doorlopendkrediet/kredietvormcode> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/doorlopendkrediet/achterstandstermijn> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/doorlopendkrediet/meldingsdrempel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/doorlopendkrediet/kredietlimiet> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/doorlopendkrediet/meldingsdrempel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:duration ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/doorlopendkrediet/achterstandstermijn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/krediet/kredietvormcode> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/krediet/doorlopendkrediet/kredietvormcode> ],
        <https://lod.gbo-semantiek.nl/krediet/kredietovereenkomst> ;
    skos:definition "Een kredietovereenkomst waarbij de kredietnemer tot een afgesproken kredietlimiet steeds opnieuw kan opnemen en aflossen, zonder vaste looptijd en zonder verplicht aflossingsschema." ;
    skos:exactMatch gbobegrip:DoorlopendKrediet,
        gbo:DoorlopendKrediet ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Revolverend krediet tot de afgesproken kredietlimiet. De maandtermijn kan rente-only zijn of rente plus minimale aflossing. Onder deze categorie vallen ook kredietkaarten met spreidingsfunctie en sommige private leases." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 17." ;
    mim:notation "RK" ;
    mim:populatie "Alle aan CKI gemelde doorlopende kredieten boven de meldingsdrempel van EUR 250 als kredietlimiet, gedurende de looptijd plus de bewaartermijn." .

<https://lod.gbo-semantiek.nl/krediet/hypothecairkredietoverigeonroerendezaken> a owl:Class ;
