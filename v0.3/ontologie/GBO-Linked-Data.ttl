        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/pand/geometrie> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BAGID ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/pand/identificatie> ],
        [ a owl:Restriction ;
