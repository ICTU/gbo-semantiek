    mim:authentiek "Authentiek" ;
    mim:formeleHistorie true ;
    mim:kardinaliteit "1..* -> 1..*" ;
    mim:materieleHistorie true ;
    mim:relatienaam "in" .

gbo:ingeschrevenAls a owl:ObjectProperty ;
    rdfs:label "ingeschrevenAls" ;
