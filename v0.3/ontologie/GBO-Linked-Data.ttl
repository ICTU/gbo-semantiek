            owl:onProperty gbo:buurtnaam ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstCBSWijkBuurt ;
            owl:onProperty gbo:buurtcode ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:buurtnaam ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:geometrie ],
        [ a owl:Restriction ;
