<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/aansprakelijkheid> a owl:Class ;
    rdfs:label "Aansprakelijkheid" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/aansprakelijkheid#Beperkt> <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/aansprakelijkheid#Onbeperkt> <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/aansprakelijkheid#Hoofdelijk> <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/aansprakelijkheid#Publiek> ) ;
    skos:definition "Aanduiding van het aansprakelijkheidskarakter dat voor een rechtsvorm geldt: in welke mate eigenaren, bestuurders of vennoten persoonlijk instaan voor verplichtingen van de entiteit." ;
    skos:exactMatch gbobegrip:Aansprakelijkheid ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Het attribuut is een GBO-eigen afleiding op NietNatuurlijkPersoon die de rechtsvorm samenvat in vier brede klassen. Het ondersteunt vragen rond kredietrisico, contractering en publieke aansprakelijkheid zonder dat afnemers de volledige rechtsvorm-codelijst hoeven te interpreteren." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "GBO" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek boek 2 (rechtspersonen, beperkte aansprakelijkheid) en boek 7A (personenvennootschappen, hoofdelijke en onbeperkte aansprakelijkheid); GBO-classificatie afgeleid uit de rechtsvorm-codelijsten." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/aansprakelijkheid#Beperkt>,
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/aansprakelijkheid#Hoofdelijk>,
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/aansprakelijkheid#Onbeperkt>,
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/aansprakelijkheid#Publiek> .

<https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/sector> a owl:Class ;
    rdfs:label "Sector" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/sector#Commercieel> <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/sector#Maatschappelijk> <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/sector#Overheid> <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/sector#Overig> ) ;
    skos:definition "Functionele sector-classificatie van een niet-natuurlijke persoon, gericht op de maatschappelijke rol: commercieel, publiek, maatschappelijk of overig." ;
    skos:exactMatch gbobegrip:Sector ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Sector geeft afnemers één samenvattend kenmerk om de rol van een wederpartij te plaatsen, parallel aan de subtype-indeling. De waarde is dekkend voor de vier subtypen Bedrijf, Overheidsinstelling, MaatschappelijkeInstelling en OverigeNietNatuurlijkPersoon." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "GBO" ;
    mim:herkomstDefinitie "GBO-classificatie, afgeleid uit subtype, rechtsvorm en indicatie van commerciële activiteit." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/sector#Commercieel>,
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/sector#Maatschappelijk>,
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/sector#Overheid>,
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/sector#Overig> .

<https://lod.gbo-semantiek.nl/belastingen/aftrekpost> a owl:Class ;
    rdfs:label "Aftrekpost" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/aftrekpost/categorie> ],
        [ owl:unionOf ( <https://lod.gbo-semantiek.nl/belastingen/alimentatieaftrek> <https://lod.gbo-semantiek.nl/belastingen/giftenaftrek> <https://lod.gbo-semantiek.nl/belastingen/hypotheekrenteaftrek> <https://lod.gbo-semantiek.nl/belastingen/lijfrenteaftrek> ) ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/aftrekpost/bedragjaar> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/aftrekpost/bedragjaar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/belastingen/aftrekpostcategorie> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/aftrekpost/categorie> ],
        <https://lod.gbo-semantiek.nl/belastingen/fiscaalfeit> ;
    skos:definition "Een door de belastingplichtige in de IH-aangifte op te voeren betaalde uitgave die op grond van Wet IB 2001 het belastbaar inkomen verlaagt." ;
    skos:exactMatch gbobegrip:Aftrekpost,
        gbo:Aftrekpost ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Abstract. Vier concrete categorieen: hypotheekrente, alimentatie, lijfrente en giften." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SBR-NT NT20" ;
    mim:herkomstDefinitie "Wet IB 2001 hoofdstuk 6 (persoonsgebonden aftrek) en hoofdstuk 3 (eigenwoning); SBR Nederlandse Taxonomie NT20." ;
    mim:populatie "Alle in een IH-aangifte opgevoerde aftrekposten die het belastbaar inkomen verlagen, inclusief hypotheekrente, partneralimentatie, lijfrente en giften." .

<https://lod.gbo-semantiek.nl/belastingen/toeslag> a owl:Class ;
    rdfs:label "Toeslag" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/bedragmaand> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/bedragmaand> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/personen/natuurlijkpersoon> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/toegekendaan> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/isvoorlopig> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/einddatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/indicatie> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/isvoorlopig> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/toegekendaan> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/ingangsdatum> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/toeslagsoort> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/belastingen/toeslagsoort> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/toeslagsoort> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/ingangsdatum> ],
        [ owl:unionOf ( <https://lod.gbo-semantiek.nl/belastingen/huurtoeslag> <https://lod.gbo-semantiek.nl/belastingen/kinderopvangtoeslag> <https://lod.gbo-semantiek.nl/belastingen/kindgebondenbudget> <https://lod.gbo-semantiek.nl/belastingen/zorgtoeslag> ) ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/toeslag/einddatum> ],
        <https://lod.gbo-semantiek.nl/werk-en-inkomen/inkomensondersteuning> ;
    skos:definition "Een inkomensafhankelijke bijdrage die op grond van de Algemene wet inkomensafhankelijke regelingen door Belastingdienst en Toeslagen aan een natuurlijk persoon wordt toegekend voor een specifiek doel." ;
    skos:exactMatch gbobegrip:Toeslag,
        gbo:Toeslag ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Vier concrete varianten: huurtoeslag, zorgtoeslag, kinderopvangtoeslag en kindgebonden budget. Toekenning verloopt in twee fasen: voorlopige beschikking op basis van geschat inkomen, en definitieve vaststelling na vaststelling van het authentieke inkomen voor het betreffende jaar. Verschillen leiden tot bijbetaling of terugvordering." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Awir" ;
    mim:herkomstDefinitie "Awir; per toeslag de materiele wet (Wet op de huurtoeslag, Zorgverzekeringswet, Wet kinderopvang, Wet op het kindgebonden budget); SBR-NT NT20 Servicebericht Toeslagen." ;
    mim:populatie "Alle door Belastingdienst en Toeslagen aan natuurlijke personen toegekende inkomensafhankelijke bijdragen op grond van de Awir: huurtoeslag, zorgtoeslag, kinderopvangtoeslag en kindgebonden budget." .

<https://lod.gbo-semantiek.nl/belastingen/toeslagsoort> a owl:Class ;
    rdfs:label "ToeslagSoort" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/belastingen/toeslagsoort#Huurtoeslag> <https://lod.gbo-semantiek.nl/belastingen/toeslagsoort#Zorgtoeslag> <https://lod.gbo-semantiek.nl/belastingen/toeslagsoort#Kinderopvangtoeslag> <https://lod.gbo-semantiek.nl/belastingen/toeslagsoort#Kindgebondenbudget> ) ;
    skos:definition "De vier inkomensafhankelijke toeslagen die op grond van de Awir door Belastingdienst en Toeslagen worden uitgevoerd." ;
    skos:exactMatch gbobegrip:ToeslagSoort ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Awir" ;
    mim:herkomstDefinitie "Awir; per toeslag de materiele wet." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/belastingen/toeslagsoort#Huurtoeslag>,
        <https://lod.gbo-semantiek.nl/belastingen/toeslagsoort#Kinderopvangtoeslag>,
        <https://lod.gbo-semantiek.nl/belastingen/toeslagsoort#Kindgebondenbudget>,
        <https://lod.gbo-semantiek.nl/belastingen/toeslagsoort#Zorgtoeslag> .

<https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit> a owl:Class ;
    rdfs:label "Datakwaliteit" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:Identificatie ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/documentnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/documentnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/documentdatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/indicatie> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/inonderzoek> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/geconstateerd> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/documentdatum> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/inonderzoek> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/datakwaliteit/geconstateerd> ] ;
    skos:definition "Mixin met vier datakwaliteits-flags die los van Voorkomen kunnen leven maar er vaak mee gepaard gaan." ;
    skos:exactMatch gbo:Datakwaliteit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/hoofdmodel> ;
    gbo:graphql "uitsluiten" .

<https://lod.gbo-semantiek.nl/hoofdmodel/partij> a owl:Class ;
    rdfs:label "Partij" ;
    rdfs:subClassOf [ owl:unionOf ( <https://lod.gbo-semantiek.nl/personen/natuurlijkpersoon> <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/nietnatuurlijkpersoon> ) ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:UUID ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/partij/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/inschrijving> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/partij/ingeschrevenals> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/hoofdmodel/partij/id> ] ;
    skos:definition "Abstract supertype van natuurlijke en niet-natuurlijke personen: iedere actor die in een overheidsregistratie als rechts- of handelingssubject voorkomt." ;
    skos:exactMatch gbobegrip:Partij,
        gbo:Partij ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/hoofdmodel> ;
    skos:note "Conform de identifier-strategie in het hoofdmodel draagt Partij de GBO-eigen UUID (ID) als technische identifier waar geen externe authentieke identifier bestaat of meerdere bronnen samenkomen." ;
    mim:uniekeAanduiding "ID" .

<https://lod.gbo-semantiek.nl/onderwijs/beurssoort> a owl:Class ;
    rdfs:label "Beurssoort" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/onderwijs/beurssoort#Basisbeurs> <https://lod.gbo-semantiek.nl/onderwijs/beurssoort#AanvullendeBeurs> <https://lod.gbo-semantiek.nl/onderwijs/beurssoort#Studentenreisproduct> <https://lod.gbo-semantiek.nl/onderwijs/beurssoort#Bestuursbeurs> ) ;
    skos:definition "Type tegemoetkoming binnen de Wet studiefinanciering 2000 en de Wet tegemoetkoming onderwijsbijdrage en schoolkosten." ;
    skos:exactMatch gbobegrip:Beurssoort ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "De keuzelijst onderscheidt de hoofdvormen van beurs en reisproduct. De leencomponent is geen waarde in deze lijst; die wordt op het zelfstandige objecttype StudieLening bijgehouden." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "WSF 2000 en WTOS" ;
    mim:herkomstDefinitie "WSF 2000 hoofdstuk 3 (beurzen) en art. 3.7 (studentenreisproduct); WTOS voor de MBO-toelage." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/onderwijs/beurssoort#AanvullendeBeurs>,
        <https://lod.gbo-semantiek.nl/onderwijs/beurssoort#Basisbeurs>,
        <https://lod.gbo-semantiek.nl/onderwijs/beurssoort#Bestuursbeurs>,
        <https://lod.gbo-semantiek.nl/onderwijs/beurssoort#Studentenreisproduct> .

<https://lod.gbo-semantiek.nl/onderwijs/codestelsel> a owl:Class ;
    rdfs:label "Codestelsel" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/onderwijs/codestelsel#CROHO> <https://lod.gbo-semantiek.nl/onderwijs/codestelsel#CREBO> <https://lod.gbo-semantiek.nl/onderwijs/codestelsel#SchoolsoortPO> <https://lod.gbo-semantiek.nl/onderwijs/codestelsel#SchoolsoortVO> ) ;
    skos:definition "Identificatiestelsel waarvan een opleidingscode deel uitmaakt." ;
    skos:exactMatch gbobegrip:Codestelsel ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "Het stelsel bepaalt vorm en betekenis van de opleidingscode. CROHO geldt voor het hoger onderwijs, CREBO voor het middelbaar beroepsonderwijs; voor PO en VO is er geen unieke nationale opleidingscode, daar werkt het deelmodel met een schoolsoort-code." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "GBO-Kern" ;
    mim:herkomstDefinitie "GBO-Kern, op basis van de sectorpraktijk in RIO en de PvE ROD per sector." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/onderwijs/codestelsel#CREBO>,
        <https://lod.gbo-semantiek.nl/onderwijs/codestelsel#CROHO>,
        <https://lod.gbo-semantiek.nl/onderwijs/codestelsel#SchoolsoortPO>,
        <https://lod.gbo-semantiek.nl/onderwijs/codestelsel#SchoolsoortVO> .

<https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling> a owl:Class ;
    rdfs:label "OnderwijsInstelling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/nietnatuurlijkpersoon> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/heeftbestuur> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Identificatie ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/instellingscoderio> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/brincode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/onderwijs/opleiding> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/biedtaan> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BRINcode ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/brincode> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/instellingscoderio> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/naam> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/heeftbestuur> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/onderwijssector> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/naam> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/onderwijs/onderwijssector> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/onderwijssector> ],
        <https://lod.gbo-semantiek.nl/bedrijven-en-instellingen/nietnatuurlijkpersoon> ;
    owl:hasKey ( <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/instellingscoderio> ),
        ( <https://lod.gbo-semantiek.nl/onderwijs/onderwijsinstelling/brincode> ) ;
    skos:definition "Een door OCW erkende rechtspersoon of bestuurlijke entiteit die onderwijs aanbiedt in een of meer Nederlandse onderwijssectoren." ;
    skos:exactMatch gbobegrip:OnderwijsInstelling,
        gbo:OnderwijsInstelling ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "NietNatuurlijkPersoon: zie deelmodel Bedrijven en instellingen.",
        "Onderwijsinstelling is een NietNatuurlijkPersoon in een specifieke rol als bevoegd gezag. De registratie Instellingen en Opleidingen (RIO) kent een hiërarchie van onderwijsbestuur, instelling, vestiging en opleidingsaanbod-eenheid. Dit deelmodel bindt het Onderwijsinstelling-objecttype aan het instelling-niveau. Het bestuur-niveau correspondeert met de rechtspersoon in het Handelsregister; voor het instelling-niveau is BRIN de korte identifier en de RIO-instellingscode de uitgebreide." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "RIO (instellings-laag); Handelsregister (rechtspersoon-laag)" ;
    mim:herkomstDefinitie "Wet op het primair onderwijs (WPO) art. 1 (basisschool); Wet voortgezet onderwijs 2020 (WVO 2020) art. 1.1 (school voor voortgezet onderwijs); Wet educatie en beroepsonderwijs (WEB) art. 1.1.1 (instelling); Wet op het hoger onderwijs en wetenschappelijk onderzoek (WHW) art. 1.2 (instelling)." ;
    mim:kwaliteit "RIO is autoritatief; BRIN-codes worden door DUO uitgegeven; mutaties in bestuurs- of vestigingsstructuur zijn na publicatie in RIO bindend." ;
    mim:populatie "Alle in RIO geregistreerde Nederlandse onderwijsinstellingen, zowel bekostigde publieke instellingen als private aanbieders met erkenning." ;
    mim:uniekeAanduiding "brincode of instellingscodeRIO" .

<https://lod.gbo-semantiek.nl/onroerende-zaken/aardbeslag> a owl:Class ;
    rdfs:label "AardBeslag" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/onroerende-zaken/aardbeslag#Conservatoir> <https://lod.gbo-semantiek.nl/onroerende-zaken/aardbeslag#Executoriaal> <https://lod.gbo-semantiek.nl/onroerende-zaken/aardbeslag#Fiscaal> <https://lod.gbo-semantiek.nl/onroerende-zaken/aardbeslag#OverigBeslag> ) ;
    skos:definition "Aard van een op een kadastraal onroerende zaak gelegd beslag, gerelateerd aan de juridische grondslag en het doel ervan." ;
    skos:exactMatch gbobegrip:AardBeslag ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Alleen van toepassing bij Zekerheidsrecht.typeZekerheidsrecht = Beslag. Conservatoir beslag dient ter zekerstelling vooruitlopend op een gerechtelijke uitspraak; executoriaal beslag volgt op een titel en strekt tot verhaal; fiscaal beslag wordt door de Belastingdienst gelegd op grond van de Invorderingswet." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK" ;
    mim:herkomstDefinitie "Wetboek van Burgerlijke Rechtsvordering (beslagregels); Invorderingswet 1990 (fiscaal beslag); BRK-Catalogus." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/onroerende-zaken/aardbeslag#Conservatoir>,
        <https://lod.gbo-semantiek.nl/onroerende-zaken/aardbeslag#Executoriaal>,
        <https://lod.gbo-semantiek.nl/onroerende-zaken/aardbeslag#Fiscaal>,
        <https://lod.gbo-semantiek.nl/onroerende-zaken/aardbeslag#OverigBeslag> .

<https://lod.gbo-semantiek.nl/personen/opschortingbijhouding> a owl:Class ;
