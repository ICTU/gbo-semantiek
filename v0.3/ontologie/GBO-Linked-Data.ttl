<https://lod.gbo-semantiek.nl/onroerende-zaken/typepubliekrechtelijkebeperking> a owl:Class ;
    rdfs:label "TypePubliekrechtelijkeBeperking" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/onroerende-zaken/typepubliekrechtelijkebeperking#BodemBescherming> <https://lod.gbo-semantiek.nl/onroerende-zaken/typepubliekrechtelijkebeperking#Erfgoedwet> <https://lod.gbo-semantiek.nl/onroerende-zaken/typepubliekrechtelijkebeperking#Monumentenwet> <https://lod.gbo-semantiek.nl/onroerende-zaken/typepubliekrechtelijkebeperking#Onteigening> <https://lod.gbo-semantiek.nl/onroerende-zaken/typepubliekrechtelijkebeperking#Overig> <https://lod.gbo-semantiek.nl/onroerende-zaken/typepubliekrechtelijkebeperking#Wro_Voorkeursrecht> ) ;
    skos:definition "Type van een publiekrechtelijke beperking op een kadastraal onroerende zaak, bepalend voor de wettelijke grondslag en de aard van de beperking." ;
