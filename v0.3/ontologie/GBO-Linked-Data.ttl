    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ] ) ] ) ] .

gbo:UitkeringWIA a owl:Class ;
    rdfs:label "UitkeringWIA" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:Decimaal ;
            owl:onProperty gbo:arbeidsongeschiktheidspercentage ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:dagloonBedrag ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:arbeidsongeschiktheidspercentage ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:dagloonBedrag ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:dagloonBedrag ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:arbeidsongeschiktheidspercentage ],
        gbo:Uitkering ;
    skos:definition "Een door UWV op grond van de Wet werk en inkomen naar arbeidsvermogen toegekende periodieke uitkering aan een werknemer die na een wachttijd van twee jaar van ziekte gedeeltelijk of volledig arbeidsongeschikt is." ;
    skos:exactMatch gbobegrip:UitkeringWIA ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/werk-en-inkomen> ;
    skos:note "De WIA splitst zich in IVA (volledig duurzaam arbeidsongeschikt) en WGA (gedeeltelijk of niet-duurzaam arbeidsongeschikt). UitkeringWIA is in dit deelmodel de gemeenschappelijke aanwijzing; concrete varianten zijn UitkeringIVA en UitkeringWGA." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SGR cluster Uitkering" ;
    mim:herkomstDefinitie "Wet WIA." ;
    mim:notation "WIA" ;
    mim:populatie "Alle door UWV toegekende WIA-uitkeringen aan werknemers die na de wachttijd van twee jaar ziekte gedeeltelijk of volledig arbeidsongeschikt zijn; concreet uitgesplitst naar UitkeringIVA en UitkeringWGA." .

gbo:UitsluitingKiesrecht a owl:Class ;
    rdfs:label "UitsluitingKiesrecht" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/UitsluitingKiesrecht#Ja> <https://lod.gbo-semantiek.nl/UitsluitingKiesrecht#Nee> ) ;
    skos:definition "Indicatie of een persoon door rechterlijke uitspraak is uitgesloten van het kiesrecht voor de Tweede Kamer en provinciale staten." ;
    skos:exactMatch gbobegrip:UitsluitingKiesrecht ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "Opgezet als Ja/Nee-keuzelijst en niet als algemene Indicatie, omdat afnemers het onderscheid tussen \"geen waarde\" en \"Nee\" moeten kunnen maken. De einddatum van een rechterlijke uitsluiting wordt elders op de persoonslijst vastgelegd." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP cat 13 Kiesrecht" ;
    mim:herkomstDefinitie "Kieswet art. B 5 en J 25 (gronden voor uitsluiting kiesrecht); Logisch Ontwerp BRP v4.3.0 cat 13 Kiesrecht." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/UitsluitingKiesrecht#Ja>,
        <https://lod.gbo-semantiek.nl/UitsluitingKiesrecht#Nee> .

