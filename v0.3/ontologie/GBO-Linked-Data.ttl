            owl:maxCardinality 1 ;
            owl:onProperty gbo:meldingId ] ;
    skos:definition "Een wettelijk verplichte melding door een onderwijsinstelling van ongeoorloofd verzuim van een leerplichtige of kwalificatieplichtige leerling, of van verzuim van een achttienplus-deelnemer dat langer dan vier weken aaneengesloten duurt." ;
    skos:exactMatch gbobegrip:VerzuimMelding ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "VerzuimMelding zit niet in het PO-koppelvlak; het verzuimregime begint in het voortgezet onderwijs vanaf de leerplicht-leeftijd en loopt door tot achttien jaar via de kwalificatieplicht. Drie regimes: leerplicht voor leeftijd vijf tot zestien jaar, kwalificatieplicht voor zestien tot achttien jaar zonder startkwalificatie, en achttienplus-verzuim in MBO. DUO routeert de melding op grond van leeftijd en regime naar de leerplicht-ambtenaar van de gemeente of naar het Regionaal Meld- en Coördinatiepunt (RMC). Geoorloofd verzuim, zoals ziekte of vakantie met toestemming, valt niet onder de wettelijke meldingsplicht en daarmee niet onder dit objecttype." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Register Onderwijsdeelnemers, clusters VO en MBO" ;
    mim:herkomstDefinitie "Leerplichtwet 1969 art. 21a (meldingsplicht ongeoorloofd verzuim); WEB art. 8.1.7 (kwalificatieplicht en verzuim achttienplus); WVO 2020 art. 8.6.4." ;
    mim:kwaliteit "Aanlevering binnen wettelijke termijn (zeven dagen na constatering) bepaalt of de melding rechtsgeldig in ROD staat." ;
    mim:populatie "Alle door scholen en MBO-instellingen aan DUO gemelde verzuim-incidenten die voldoen aan de wettelijke drempel." ;
    mim:uniekeAanduiding "meldingId" .

gbo:Vooropleiding a owl:Class ;
    rdfs:label "Vooropleiding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstDiplomasoort ;
            owl:onProperty gbo:diplomasoort ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:landVerwerving ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:toelatingsbewijsBij ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:OpleidingDeelname ;
            owl:onProperty gbo:toelatingsbewijsBij ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:verstrekkendeInstellingscode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:landVerwerving ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:OpleidingResultaat ;
            owl:onProperty gbo:isBaseerd ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:diplomasoort ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:diplomasoort ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:isBaseerd ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:verstrekkendeInstellingscode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:behaaldatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:isBaseerd ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:behaaldatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:verstrekkendeInstellingscode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:behaaldatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstISO3166 ;
            owl:onProperty gbo:landVerwerving ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:toelatingsbewijsBij ],
        gbo:OpleidingResultaat ;
    owl:hasKey ( gbo:behaaldDoor gbo:diplomasoort gbo:behaaldatum gbo:verstrekkendeInstellingscode ) ;
    skos:definition "Een eerder behaald opleidingsresultaat dat bij een volgende onderwijsdeelname wordt aangereikt als bewijs voor de toelating tot of de instroompositionering in een opleiding." ;
    skos:exactMatch gbobegrip:Vooropleiding ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "Vooropleiding is hetzelfde objecttype als OpleidingResultaat, ingezet in een tweede rol. Een MBO-deelname met een HAVO-diploma als vooropleiding wordt in ROD doorgegeven met een verwijzing naar het VO-OpleidingResultaat; analoog voor een HO-deelname met een MBO-niveau-4-diploma als instroom. Buitenlandse vooropleidingen worden niet door ROD geverifieerd tegen een binnenlands resultaat; de instelling beoordeelt de gelijkstelling, doorgaans op basis van een gelijkwaardigheidsverklaring (door DUO of Nuffic afgegeven)." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Register Onderwijsdeelnemers per sector" ;
    mim:herkomstDefinitie "WHW art. 7.24 en volgende (toelatingseisen HO); WEB art. 8.2.1 (toelating MBO); WVO 2020 voor doorstroomeisen binnen VO." ;
    mim:kwaliteit "ROD valideert de combinatie persoon-vooropleiding tegen het bestaande OpleidingResultaat-record waar aanwezig. Buitenlandse vooropleidingen worden aangereikt zonder ROD-tegenpaar; de instelling staat in voor de gelijkstelling." ;
    mim:populatie "Alle door instellingen geregistreerde vooropleidingen bij ROD-inschrijvingen, inclusief in het buitenland behaalde gelijkstellingen." ;
    mim:uniekeAanduiding "Combinatie van persoon, diplomasoort, behaaldatum en verstrekkende instelling." .

gbo:Zekerheidsrecht a owl:Class ;
    rdfs:label "Zekerheidsrecht" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:bedrag ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:aardBeslag ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:aardBeslag ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:opKadastraleOnroerendeZaak ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumVestiging ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:TypeZekerheidsrecht ;
            owl:onProperty gbo:typeZekerheidsrecht ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:AardBeslag ;
            owl:onProperty gbo:aardBeslag ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:bedrag ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:datumVestiging ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:KadastraleOnroerendeZaak ;
            owl:onProperty gbo:opKadastraleOnroerendeZaak ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:bedrag ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumVestiging ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:typeZekerheidsrecht ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:typeZekerheidsrecht ],
        gbo:Voorkomen ;
    skos:definition "Een op een kadastraal onroerende zaak rustend recht dat strekt tot zekerheid van een schuldvordering, te weten een hypotheek of een beslag." ;
    skos:exactMatch gbobegrip:Zekerheidsrecht ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Zekerheidsrecht staat los van ZakelijkRecht omdat het geen eigendomstitel is maar een zekerstelling: bij hypotheek strekt het recht tot zekerheid van een geldlening, bij beslag tot zekerstelling van een vordering. Beide rusten op een kadastraal onroerende zaak en bestaan zelfstandig naast de zakelijke rechten op diezelfde zaak." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK (basisregistratie)" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek Boek 3 titel 9 (recht van pand en hypotheek); Wetboek van Burgerlijke Rechtsvordering (beslagregels); Kadasterwet; BRK-Catalogus." ;
    mim:populatie "Alle hypotheken en beslagen die in Nederland op kadastrale onroerende zaken zijn gevestigd en in de BRK zijn geregistreerd." ;
    mim:uniekeAanduiding "identificatie" .

<https://lod.gbo-semantiek.nl/informatiemodel/gbo.owl.ttl> a owl:Ontology ;
    rdfs:label "gbo" ;
    dcterms:license "https://joinup.ec.europa.eu/collection/eupl/eupl-text-eupl-12" ;
    dcterms:title "GBO-Informatiemodel" ;
    pav:version "0.2.0" ;
    skos:definition "Semantisch informatiemodel van de Gemeenschappelijke Bronontsluiting (GBO): een landelijke, sectoroverstijgende beschrijving van basisgegevens uit overheidsregistraties. Dit LinkML-schema is afgeleid van de documentatie in docs/informatiemodel/gbo-kern/; de documentatie is leidend." .

xsd:gYear a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[0-9]{4}$" ] ) ] ) ] .

gbo:AangifteErf a owl:Class ;
