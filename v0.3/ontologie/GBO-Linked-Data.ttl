            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/nummeraanduiding/postcode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/statusnummeraanduiding> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/nummeraanduiding/status> ],
        [ a owl:Restriction ;
