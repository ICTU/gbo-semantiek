    mim:datumOpname "2026-05-19" ;
    mim:herkomst "WSF 2000 en WTOS" ;
    mim:herkomstDefinitie "WSF 2000 hoofdstuk 3 (beurzen) en art. 3.7 (studentenreisproduct); WTOS voor de MBO-toelage." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/Beurssoort#AanvullendeBeurs>,
        <https://lod.gbo-semantiek.nl/Beurssoort#Basisbeurs>,
        <https://lod.gbo-semantiek.nl/Beurssoort#Bestuursbeurs>,
        <https://lod.gbo-semantiek.nl/Beurssoort#Studentenreisproduct> .

gbo:Codestelsel a owl:Class ;
    rdfs:label "Codestelsel" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/Codestelsel#CROHO> <https://lod.gbo-semantiek.nl/Codestelsel#CREBO> <https://lod.gbo-semantiek.nl/Codestelsel#SchoolsoortPO> <https://lod.gbo-semantiek.nl/Codestelsel#SchoolsoortVO> ) ;
    skos:definition "Identificatiestelsel waarvan een opleidingscode deel uitmaakt." ;
    skos:exactMatch gbobegrip:Codestelsel ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "Het stelsel bepaalt vorm en betekenis van de opleidingscode. CROHO geldt voor het hoger onderwijs, CREBO voor het middelbaar beroepsonderwijs; voor PO en VO is er geen unieke nationale opleidingscode, daar werkt het deelmodel met een schoolsoort-code." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "GBO-Kern" ;
    mim:herkomstDefinitie "GBO-Kern, op basis van de sectorpraktijk in RIO en de PvE ROD per sector." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/Codestelsel#CREBO>,
        <https://lod.gbo-semantiek.nl/Codestelsel#CROHO>,
        <https://lod.gbo-semantiek.nl/Codestelsel#SchoolsoortPO>,
        <https://lod.gbo-semantiek.nl/Codestelsel#SchoolsoortVO> .

gbo:Datakwaliteit a owl:Class ;
    rdfs:label "Datakwaliteit" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:inOnderzoek ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:geconstateerd ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:geconstateerd ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:documentdatum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:documentnummer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:documentdatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:geconstateerd ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Indicatie ;
            owl:onProperty gbo:inOnderzoek ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:inOnderzoek ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:documentnummer ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Identificatie ;
            owl:onProperty gbo:documentnummer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:documentdatum ] ;
    skos:definition "Mixin met vier datakwaliteits-flags die los van Voorkomen kunnen leven maar er vaak mee gepaard gaan." ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/hoofdmodel> ;
    gbo:graphql "uitsluiten" .

gbo:OnderwijsInstelling a owl:Class ;
    rdfs:label "OnderwijsInstelling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:heeftBestuur ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Alfanumeriek ;
            owl:onProperty gbo:brincode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:naam ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Onderwijssector ;
            owl:onProperty gbo:onderwijssector ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:brincode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:instellingscodeRIO ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:NietNatuurlijkPersoon ;
            owl:onProperty gbo:heeftBestuur ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:naam ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:heeftBestuur ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:instellingscodeRIO ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:onderwijssector ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:naam ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:biedtAan ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:brincode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:instellingscodeRIO ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Opleiding ;
            owl:onProperty gbo:biedtAan ],
        gbo:NietNatuurlijkPersoon ;
    owl:hasKey ( gbo:instellingscodeRIO ),
        ( gbo:brincode ) ;
    skos:definition "Een door OCW erkende rechtspersoon of bestuurlijke entiteit die onderwijs aanbiedt in een of meer Nederlandse onderwijssectoren." ;
    skos:exactMatch gbobegrip:OnderwijsInstelling ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "NietNatuurlijkPersoon: zie deelmodel Bedrijven en instellingen.",
        "Onderwijsinstelling is een NietNatuurlijkPersoon in een specifieke rol als bevoegd gezag. De registratie Instellingen en Opleidingen (RIO) kent een hiërarchie van onderwijsbestuur, instelling, vestiging en opleidingsaanbod-eenheid. Dit deelmodel bindt het Onderwijsinstelling-objecttype aan het instelling-niveau. Het bestuur-niveau correspondeert met de rechtspersoon in het Handelsregister; voor het instelling-niveau is BRIN de korte identifier en de RIO-instellingscode de uitgebreide." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "RIO (instellings-laag); Handelsregister (rechtspersoon-laag)" ;
    mim:herkomstDefinitie "Wet op het primair onderwijs (WPO) art. 1 (basisschool); Wet voortgezet onderwijs 2020 (WVO 2020) art. 1.1 (school voor voortgezet onderwijs); Wet educatie en beroepsonderwijs (WEB) art. 1.1.1 (instelling); Wet op het hoger onderwijs en wetenschappelijk onderzoek (WHW) art. 1.2 (instelling)." ;
    mim:kwaliteit "RIO is autoritatief; BRIN-codes worden door DUO uitgegeven; mutaties in bestuurs- of vestigingsstructuur zijn na publicatie in RIO bindend." ;
    mim:populatie "Alle in RIO geregistreerde Nederlandse onderwijsinstellingen, zowel bekostigde publieke instellingen als private aanbieders met erkenning." ;
    mim:uniekeAanduiding "brincode of instellingscodeRIO" .

gbo:OpschortingBijhouding a owl:Class ;
    rdfs:label "OpschortingBijhouding" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/OpschortingBijhouding#Overlijden> <https://lod.gbo-semantiek.nl/OpschortingBijhouding#Emigratie> <https://lod.gbo-semantiek.nl/OpschortingBijhouding#Vermissing> <https://lod.gbo-semantiek.nl/OpschortingBijhouding#FoutAangelegdOfFraude> ) ;
    skos:definition "Reden waarom de bijhouding van een persoonslijst in de basisregistratie is opgeschort." ;
    skos:exactMatch gbobegrip:OpschortingBijhouding ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "Een opgeschorte persoonslijst wordt niet langer bijgewerkt maar blijft beschikbaar voor historisch en juridisch gebruik. De reden van opschorting is een belangrijk datakwaliteits-signaal voor afnemers." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP cat 07 grp 67 Opschorting" ;
    mim:herkomstDefinitie "Logisch Ontwerp BRP v4.3.0 §4.6 cat 07 grp 67 Opschorting bijhouding; Wet BRP." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/OpschortingBijhouding#Emigratie>,
        <https://lod.gbo-semantiek.nl/OpschortingBijhouding#FoutAangelegdOfFraude>,
        <https://lod.gbo-semantiek.nl/OpschortingBijhouding#Overlijden>,
        <https://lod.gbo-semantiek.nl/OpschortingBijhouding#Vermissing> .

gbo:Partij a owl:Class ;
    rdfs:label "Partij" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ID ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:UUID ;
            owl:onProperty gbo:ID ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:ingeschrevenAls ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:ID ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Inschrijving ;
            owl:onProperty gbo:ingeschrevenAls ],
        [ owl:unionOf ( gbo:NatuurlijkPersoon gbo:NietNatuurlijkPersoon ) ] ;
    skos:definition "Abstract supertype van natuurlijke en niet-natuurlijke personen: iedere actor die in een overheidsregistratie als rechts- of handelingssubject voorkomt." ;
    skos:exactMatch gbobegrip:Partij ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/hoofdmodel> ;
    skos:note "Conform de identifier-strategie in het hoofdmodel draagt Partij de GBO-eigen UUID (ID) als technische identifier waar geen externe authentieke identifier bestaat of meerdere bronnen samenkomen." ;
    mim:uniekeAanduiding "ID" .

gbo:Sector a owl:Class ;
    rdfs:label "Sector" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/Sector#Commercieel> <https://lod.gbo-semantiek.nl/Sector#Maatschappelijk> <https://lod.gbo-semantiek.nl/Sector#Overheid> <https://lod.gbo-semantiek.nl/Sector#Overig> ) ;
    skos:definition "Functionele sector-classificatie van een niet-natuurlijke persoon, gericht op de maatschappelijke rol: commercieel, publiek, maatschappelijk of overig." ;
    skos:exactMatch gbobegrip:Sector ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Sector geeft afnemers één samenvattend kenmerk om de rol van een wederpartij te plaatsen, parallel aan de subtype-indeling. De waarde is dekkend voor de vier subtypen Bedrijf, Overheidsinstelling, MaatschappelijkeInstelling en OverigeNietNatuurlijkPersoon." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "GBO" ;
    mim:herkomstDefinitie "GBO-classificatie, afgeleid uit subtype, rechtsvorm en indicatie van commerciële activiteit." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/Sector#Commercieel>,
        <https://lod.gbo-semantiek.nl/Sector#Maatschappelijk>,
        <https://lod.gbo-semantiek.nl/Sector#Overheid>,
        <https://lod.gbo-semantiek.nl/Sector#Overig> .

gbo:Toeslag a owl:Class ;
    rdfs:label "Toeslag" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:ToeslagSoort ;
            owl:onProperty gbo:toeslagSoort ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:isVoorlopig ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:toegekendAan ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Indicatie ;
            owl:onProperty gbo:isVoorlopig ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:toeslagSoort ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:bedragMaand ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:NatuurlijkPersoon ;
            owl:onProperty gbo:toegekendAan ],
        [ owl:unionOf ( gbo:Huurtoeslag gbo:KinderopvangToeslag gbo:KindgebondenBudget gbo:Zorgtoeslag ) ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:isVoorlopig ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:toegekendAan ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:bedragMaand ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:bedragMaand ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:toeslagSoort ],
        gbo:InkomensOndersteuning ;
    skos:definition "Een inkomensafhankelijke bijdrage die op grond van de Algemene wet inkomensafhankelijke regelingen door Belastingdienst en Toeslagen aan een natuurlijk persoon wordt toegekend voor een specifiek doel." ;
    skos:exactMatch gbobegrip:Toeslag ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Vier concrete varianten: huurtoeslag, zorgtoeslag, kinderopvangtoeslag en kindgebonden budget. Toekenning verloopt in twee fasen: voorlopige beschikking op basis van geschat inkomen, en definitieve vaststelling na vaststelling van het authentieke inkomen voor het betreffende jaar. Verschillen leiden tot bijbetaling of terugvordering." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Awir" ;
    mim:herkomstDefinitie "Awir; per toeslag de materiele wet (Wet op de huurtoeslag, Zorgverzekeringswet, Wet kinderopvang, Wet op het kindgebonden budget); SBR-NT NT20 Servicebericht Toeslagen." ;
    mim:populatie "Alle door Belastingdienst en Toeslagen aan natuurlijke personen toegekende inkomensafhankelijke bijdragen op grond van de Awir: huurtoeslag, zorgtoeslag, kinderopvangtoeslag en kindgebonden budget." .

gbo:ToeslagSoort a owl:Class ;
    rdfs:label "ToeslagSoort" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/ToeslagSoort#Huurtoeslag> <https://lod.gbo-semantiek.nl/ToeslagSoort#Zorgtoeslag> <https://lod.gbo-semantiek.nl/ToeslagSoort#Kinderopvangtoeslag> <https://lod.gbo-semantiek.nl/ToeslagSoort#Kindgebondenbudget> ) ;
    skos:definition "De vier inkomensafhankelijke toeslagen die op grond van de Awir door Belastingdienst en Toeslagen worden uitgevoerd." ;
    skos:exactMatch gbobegrip:ToeslagSoort ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Awir" ;
    mim:herkomstDefinitie "Awir; per toeslag de materiele wet." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/ToeslagSoort#Huurtoeslag>,
        <https://lod.gbo-semantiek.nl/ToeslagSoort#Kinderopvangtoeslag>,
        <https://lod.gbo-semantiek.nl/ToeslagSoort#Kindgebondenbudget>,
        <https://lod.gbo-semantiek.nl/ToeslagSoort#Zorgtoeslag> .

gbo:TypeAdresseerbaarObject a owl:Class ;
    rdfs:label "TypeAdresseerbaarObject" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/TypeAdresseerbaarObject#Verblijfsobject> <https://lod.gbo-semantiek.nl/TypeAdresseerbaarObject#Ligplaats> <https://lod.gbo-semantiek.nl/TypeAdresseerbaarObject#Standplaats> ) ;
    skos:definition "Aanduiding van de concrete vorm van een adresseerbaar object: Verblijfsobject, Ligplaats of Standplaats." ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Discriminator, gebruikt door AdresseerbaarObject.typeAdresseerbaarObject en (als replica voor HC-conformiteit) Nummeraanduiding.typeAdresseerbaarObject." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BAG-Catalogus 2018" ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/TypeAdresseerbaarObject#Ligplaats>,
        <https://lod.gbo-semantiek.nl/TypeAdresseerbaarObject#Standplaats>,
        <https://lod.gbo-semantiek.nl/TypeAdresseerbaarObject#Verblijfsobject> .

gbo:kadastraleAanduiding a owl:DatatypeProperty ;
    rdfs:label "kadastraleAanduiding" ;
    skos:definition "Samengestelde aanduiding (kadastrale gemeente / sectie / perceelnummer / eventueel indexnummer)." ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Menselijk leesbare aanduiding." ;
    mim:authentiek "Authentiek" ;
    mim:formeleHistorie true ;
    mim:herkomst "BRK-Catalogus" ;
    mim:materieleHistorie true .

gbo:onderwijssector a owl:ObjectProperty .

gbo:BAGID a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[0-9]{16}$" ] ) ] ) ] .

gbo:BijzonderheidsCode a owl:Class ;
    rdfs:label "BijzonderheidsCode" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/BijzonderheidsCode#1> <https://lod.gbo-semantiek.nl/BijzonderheidsCode#2> <https://lod.gbo-semantiek.nl/BijzonderheidsCode#3> <https://lod.gbo-semantiek.nl/BijzonderheidsCode#4> <https://lod.gbo-semantiek.nl/BijzonderheidsCode#5> ) ;
    skos:definition "De waardenset van bijzonderheidscodes die op grond van art. 13 Algemeen Reglement CKI bij een kredietovereenkomst aan het Centraal Krediet Informatiesysteem kunnen worden gemeld." ;
    skos:exactMatch gbobegrip:BijzonderheidsCode ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Combinaties zijn toegestaan: een kredietovereenkomst kan meerdere bijzonderheids-coderingen kennen, elk met een eigen code en datum.",
        "Gebruikt door: BijzonderheidsCodering.bijzonderheidsCode." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 13." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/BijzonderheidsCode#1>,
        <https://lod.gbo-semantiek.nl/BijzonderheidsCode#2>,
        <https://lod.gbo-semantiek.nl/BijzonderheidsCode#3>,
        <https://lod.gbo-semantiek.nl/BijzonderheidsCode#4>,
        <https://lod.gbo-semantiek.nl/BijzonderheidsCode#5> .

gbo:Identificatie a rdfs:Datatype ;
    owl:equivalentClass gbo:Tekst .

gbo:IndicatieGezag a owl:Class ;
    rdfs:label "IndicatieGezag" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/IndicatieGezag#EenhoofdigOuder> <https://lod.gbo-semantiek.nl/IndicatieGezag#GezamenlijkOuders> <https://lod.gbo-semantiek.nl/IndicatieGezag#GezamenlijkOuderEnDerde> <https://lod.gbo-semantiek.nl/IndicatieGezag#Voogdij> <https://lod.gbo-semantiek.nl/IndicatieGezag#TijdelijkGeenGezag> ) ;
    skos:definition "Vorm van het ouderlijk gezag of de voogdij over een minderjarige." ;
    skos:exactMatch gbobegrip:IndicatieGezag ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "Platte keuzelijst die de gezagssituatie van een minderjarige typeert; cluster-modellering met datums en betrokkenen ligt op Gezagsverhouding zelf." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP cat 11 Gezagsverhouding" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek Boek 1 titel 14 (gezag over minderjarigen); Logisch Ontwerp BRP v4.3.0 cat 11 Gezagsverhouding." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/IndicatieGezag#EenhoofdigOuder>,
        <https://lod.gbo-semantiek.nl/IndicatieGezag#GezamenlijkOuderEnDerde>,
        <https://lod.gbo-semantiek.nl/IndicatieGezag#GezamenlijkOuders>,
        <https://lod.gbo-semantiek.nl/IndicatieGezag#TijdelijkGeenGezag>,
        <https://lod.gbo-semantiek.nl/IndicatieGezag#Voogdij> .

gbo:Resultaatsoort a owl:Class ;
    rdfs:label "Resultaatsoort" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/Resultaatsoort#Diploma> <https://lod.gbo-semantiek.nl/Resultaatsoort#Getuigschrift> <https://lod.gbo-semantiek.nl/Resultaatsoort#Certificaat> <https://lod.gbo-semantiek.nl/Resultaatsoort#Deelcertificaat> <https://lod.gbo-semantiek.nl/Resultaatsoort#Propedeuse> ) ;
    skos:definition "Het type onderwijsresultaat dat in ROD wordt geregistreerd." ;
    skos:exactMatch gbobegrip:Resultaatsoort ;
