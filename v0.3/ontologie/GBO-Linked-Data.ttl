gbo:Postadres a owl:Class ;
    rdfs:label "Postadres" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:plaats ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:postcode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:soortPostadres ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:soortPostadres ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:plaats ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:plaats ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Postcode ;
            owl:onProperty gbo:postcode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:SoortPostadres ;
            owl:onProperty gbo:soortPostadres ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:briefbusnummer ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:briefbusnummer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
