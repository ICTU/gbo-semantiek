        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumIngang ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:datumEinde ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:NEN3610ID ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:KadastraleOnroerendeZaak ;
            owl:onProperty gbo:opKadastraleOnroerendeZaak ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Identificatie ;
            owl:onProperty gbo:documentnummer ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:akteverwijzing ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        gbo:Voorkomen ;
    skos:definition "Een vermogensrecht op een zaak dat tegen iedereen kan worden uitgeoefend en dat in de Basisregistratie Kadaster wordt geregistreerd; voorbeelden zijn eigendom, erfpacht, opstal en vruchtgebruik." ;
    skos:exactMatch gbobegrip:ZakelijkRecht ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "ZakelijkRecht is de koppeling tussen rechthebbende (via Tenaamstelling) en kadastrale onroerende zaak. Het onderscheidt zich van een persoonlijk recht doordat het tegen iedereen kan worden uitgeoefend (zaaksgebondenheid). Vormen worden onderscheiden via de aard-aanduiding (Eigendom, Erfpacht, Opstal, Vruchtgebruik, GebruikEnBewoning, Beklemrecht, Erfdienstbaarheid heersend/lijdend). Hypotheek en beslag staan los in Zekerheidsrecht: die dienen ter zekerheid van een vordering, niet als eigendomstitel." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK (basisregistratie)" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek Boek 5 (zakelijke rechten, art. 1 e.v., art. 85 t/m 105); Burgerlijk Wetboek Boek 3 (registergoederen, art. 10 e.v.); Kadasterwet; BRK-Catalogus (objecttype ZakelijkRecht)." ;
    mim:populatie "Alle zakelijke rechten op kadastrale onroerende zaken in Nederland zoals geregistreerd in de BRK; vormen worden onderscheiden via AardZakelijkRecht." ;
    mim:uniekeAanduiding "identificatie" .

gbo:ZakelijkeOverigeFinancieleVerplichting a owl:Class ;
    rdfs:label "ZakelijkeOverigeFinancieleVerplichting" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:duration ;
            owl:onProperty gbo:achterstandstermijn ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:achterstandstermijn ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:achterstandstermijn ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:KredietVormCode ;
            owl:onProperty gbo:kredietvormCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:kredietvormCode ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:kredietvormCode ],
        gbo:KredietOvereenkomst ;
    skos:definition "Een overige zakelijke financiele verplichting die niet onder zakelijk krediet valt en waarvan op grond van het Algemeen Reglement CKI alleen negatieve betalingservaringen aan het Centraal Krediet Informatiesysteem worden gemeld." ;
    skos:exactMatch gbobegrip:ZakelijkeOverigeFinancieleVerplichting ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Zakelijke tegenhanger van de overige financiele verplichting prive. Net als RO alleen negatieve registratie. Bij combinatie van persoonlijke aansprakelijkheid en zakelijke verplichting kunnen zowel ZK als ZO van toepassing zijn." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 25." ;
    mim:notation "ZO" ;
    mim:populatie "Aan CKI gemelde overige zakelijke financiele verplichtingen boven EUR 1.000 die niet onder ZakelijkKrediet vallen, voor zover een negatieve betalingservaring is gemeld." .

gbo:Zorgtoeslag a owl:Class ;
    rdfs:label "Zorgtoeslag" ;
    rdfs:subClassOf gbo:Toeslag ;
    skos:definition "Een inkomensafhankelijke tegemoetkoming in de premie van de basiszorgverzekering, toegekend op grond van de Wet op de zorgtoeslag." ;
    skos:exactMatch gbobegrip:Zorgtoeslag ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Geen eigen attributen op GBO-Kern-niveau; alle eigenschappen geërfd van Toeslag.",
        "Hoogte hangt af van inkomen, vermogen en eventuele partner-status." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Awir" ;
    mim:herkomstDefinitie "Wet op de zorgtoeslag; Awir; SBR-NT NT20 Servicebericht Toeslagen." ;
    mim:notation "ZT" ;
    mim:populatie "Alle aan natuurlijke personen toegekende zorgtoeslagen op grond van de Wet op de zorgtoeslag, ter tegemoetkoming in de premie van de basiszorgverzekering." .

<https://lod.gbo-semantiek.nl/Aansprakelijkheid#Beperkt> a owl:Class ;
    rdfs:label "Beperkt" ;
    rdfs:subClassOf gbo:Aansprakelijkheid ;
    skos:definition "Aansprakelijkheid is beperkt tot het in de entiteit ingebrachte vermogen." ;
    skos:note "Typisch voor BV, NV, coöperatie." .

<https://lod.gbo-semantiek.nl/Aansprakelijkheid#Hoofdelijk> a owl:Class ;
    rdfs:label "Hoofdelijk" ;
    rdfs:subClassOf gbo:Aansprakelijkheid ;
    skos:definition "Vennoten zijn ieder voor het geheel aansprakelijk voor verplichtingen van de entiteit." ;
    skos:note "Typisch voor VOF en maatschap." .

<https://lod.gbo-semantiek.nl/Aansprakelijkheid#Onbeperkt> a owl:Class ;
    rdfs:label "Onbeperkt" ;
    rdfs:subClassOf gbo:Aansprakelijkheid ;
    skos:definition "Eigenaar staat met het volledige privévermogen in voor verplichtingen." ;
    skos:note "Typisch voor eenmanszaak." .

<https://lod.gbo-semantiek.nl/Aansprakelijkheid#Publiek> a owl:Class ;
    rdfs:label "Publiek" ;
    rdfs:subClassOf gbo:Aansprakelijkheid ;
    skos:definition "Aansprakelijkheid valt onder publiekrechtelijk regime, doorgaans met overheidsgarantie." ;
    skos:note "Typisch voor publiekrechtelijke rechtspersonen." .

<https://lod.gbo-semantiek.nl/AardBeslag#Conservatoir> a owl:Class ;
    rdfs:label "Conservatoir" ;
    rdfs:subClassOf gbo:AardBeslag ;
    skos:definition "Beslag ter zekerstelling vooruitlopend op een gerechtelijke uitspraak." ;
    skos:note "Bewaart de zaak voor verhaal tijdens een lopende procedure." .

<https://lod.gbo-semantiek.nl/AardBeslag#Executoriaal> a owl:Class ;
    rdfs:label "Executoriaal" ;
    rdfs:subClassOf gbo:AardBeslag ;
    skos:definition "Beslag op grond van een executoriale titel ter daadwerkelijke verhaal van een vordering." ;
    skos:note "Leidt typisch tot openbare verkoop." .

<https://lod.gbo-semantiek.nl/AardBeslag#Fiscaal> a owl:Class ;
    rdfs:label "Fiscaal" ;
    rdfs:subClassOf gbo:AardBeslag ;
    skos:definition "Beslag gelegd door de Belastingdienst ter invordering van een belastingschuld." ;
    skos:note "Grondslag in de Invorderingswet 1990." .

<https://lod.gbo-semantiek.nl/AardBeslag#OverigBeslag> a owl:Class ;
    rdfs:label "OverigBeslag" ;
    rdfs:subClassOf gbo:AardBeslag ;
    skos:definition "Beslag dat niet onder een van de andere categorieën valt." ;
    skos:note "Restcategorie." .

<https://lod.gbo-semantiek.nl/AardZakelijkRecht#Beklemrecht> a owl:Class ;
    rdfs:label "Beklemrecht" ;
    rdfs:subClassOf gbo:AardZakelijkRecht ;
    skos:definition "Eeuwigdurend, overerfbaar gebruiksrecht op grond tegen een vaste jaarlijkse vergoeding." ;
    skos:note "Historisch voornamelijk in Groningen en Friesland." .

<https://lod.gbo-semantiek.nl/AardZakelijkRecht#Eigendom> a owl:Class ;
    rdfs:label "Eigendom" ;
    rdfs:subClassOf gbo:AardZakelijkRecht ;
    skos:definition "Het meest omvattende recht dat een persoon op een zaak kan hebben." ;
    skos:note "BW Boek 5 art. 1." .

<https://lod.gbo-semantiek.nl/AardZakelijkRecht#ErfdienstbaarheidHeersend> a owl:Class ;
    rdfs:label "ErfdienstbaarheidHeersend" ;
    rdfs:subClassOf gbo:AardZakelijkRecht ;
    skos:definition "Erfdienstbaarheid ten gunste van het kadastraal onroerende zaak (het heersende erf)." ;
    skos:note "Bijvoorbeeld een recht van overpad over een buurperceel." .

<https://lod.gbo-semantiek.nl/AardZakelijkRecht#ErfdienstbaarheidLijdend> a owl:Class ;
    rdfs:label "ErfdienstbaarheidLijdend" ;
    rdfs:subClassOf gbo:AardZakelijkRecht ;
    skos:definition "Erfdienstbaarheid ten laste van het kadastraal onroerende zaak (het dienende erf)." ;
    skos:note "De tegenkant van de heersende erfdienstbaarheid." .

<https://lod.gbo-semantiek.nl/AardZakelijkRecht#Erfpacht> a owl:Class ;
    rdfs:label "Erfpacht" ;
    rdfs:subClassOf gbo:AardZakelijkRecht ;
    skos:definition "Recht om het kadastraal onroerende zaak van een ander te houden en te gebruiken, doorgaans tegen canon." ;
    skos:note "BW Boek 5 art. 85 e.v." .

<https://lod.gbo-semantiek.nl/AardZakelijkRecht#GebruikEnBewoning> a owl:Class ;
    rdfs:label "GebruikEnBewoning" ;
    rdfs:subClassOf gbo:AardZakelijkRecht ;
    skos:definition "Persoonlijk recht om een zaak te gebruiken en te bewonen voor zover nodig voor de gerechtigde en zijn gezin." ;
    skos:note "BW Boek 3 art. 226." .

<https://lod.gbo-semantiek.nl/AardZakelijkRecht#Opstal> a owl:Class ;
    rdfs:label "Opstal" ;
    rdfs:subClassOf gbo:AardZakelijkRecht ;
    skos:definition "Recht om in, op of boven een kadastraal onroerende zaak van een ander gebouwen, werken of beplantingen in eigendom te hebben." ;
    skos:note "BW Boek 5 art. 101 e.v." .

<https://lod.gbo-semantiek.nl/AardZakelijkRecht#Vruchtgebruik> a owl:Class ;
    rdfs:label "Vruchtgebruik" ;
    rdfs:subClassOf gbo:AardZakelijkRecht ;
    skos:definition "Recht om de zaken van een ander te gebruiken en daarvan de vruchten te genieten." ;
    skos:note "BW Boek 3 art. 201 e.v." .

gbo:Activiteit a owl:Class ;
    rdfs:label "Activiteit" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:soortActiviteit ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:sbiVersie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstCBSSBI ;
            owl:onProperty gbo:sbiCode ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstCBSSBI ;
            owl:onProperty gbo:sbiVersie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:omschrijving ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:SoortActiviteit ;
            owl:onProperty gbo:soortActiviteit ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:soortActiviteit ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:isHoofdactiviteit ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:omschrijving ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:isHoofdactiviteit ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Indicatie ;
            owl:onProperty gbo:isHoofdactiviteit ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:sbiCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:omschrijving ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:sbiCode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:sbiVersie ] ;
    skos:definition "Een geregistreerde bedrijfsactiviteit die in het Handelsregister wordt vastgelegd, gecodeerd volgens de CBS Standaard Bedrijfsindeling (SBI), met onderscheid tussen hoofd- en nevenactiviteit per inschrijving of per vestiging." ;
    skos:exactMatch gbobegrip:Activiteit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Activiteit is een zelfstandig gegeven omdat het bij meerdere registraties kan horen (Inschrijving én Vestiging), een eigen hoofd-neven-aanduiding heeft en versie-gebonden is via het SBI-codestelsel. Activiteit hangt aan een Inschrijving voor de onderneming als geheel (één of meer per Inschrijving) en optioneel aan een Vestiging voor de uitvoering op een locatie (nul of meer per Vestiging). Per drager geldt maximaal één activiteit met soortActiviteit = Hoofd op enig moment. SBI-codes komen uit een externe codelijst van het CBS.",
        "De unieke aanduiding is samengesteld en omvat ook de drager-context (Inschrijving of Vestiging); dat is niet als LinkML-identifier of unique_keys uitdrukbaar, zie annotatie mim:uniekeAanduiding." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR; CBS Standaard Bedrijfsindeling" ;
    mim:herkomstDefinitie "Handelsregisterwet 2007 art. 12 (registratie bedrijfsactiviteit); CBS Standaard Bedrijfsindeling (huidig SBI 2008, opvolger SBI 2025) als classificatiestandaard; KVK Basisprofiel- en Vestigingsprofiel-API als operationele invulling." ;
