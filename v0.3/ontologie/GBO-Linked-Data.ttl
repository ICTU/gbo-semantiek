        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:aansprakelijkheid ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:zetel ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:naam ],
        [ owl:unionOf ( gbo:Bedrijf gbo:BuitenlandseEntiteit gbo:Instelling gbo:OnderwijsInstelling gbo:OverigeNietNatuurlijkPersoon ) ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:herkomst ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:MaatschappelijkeActiviteit ;
            owl:onProperty gbo:voertUit ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Herkomst ;
            owl:onProperty gbo:herkomst ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Aansprakelijkheid ;
