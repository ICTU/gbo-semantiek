gbo:WOZWaarde a owl:Class ;
    rdfs:label "WOZWaarde" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:Identificatie ;
            owl:onProperty gbo:beschikkingsnummer ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:vastgesteldeWaarde ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:beschikkingsnummer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:statusWOZWaarde ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:indicatieBezwaarBeroep ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:waardepeildatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BeschikkingStatus ;
            owl:onProperty gbo:beschikkingsStatussen ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:beschikkingsnummer ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:StatusWOZWaarde ;
            owl:onProperty gbo:statusWOZWaarde ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:waardepeildatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:beschikkingsStatussen ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:indicatieBezwaarBeroep ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:waardepeildatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:vastgesteldeWaarde ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Indicatie ;
            owl:onProperty gbo:indicatieBezwaarBeroep ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:vastgesteldeWaarde ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:statusWOZWaarde ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ingangsdatum ] ;
    skos:altLabel "Waarde" ;
    skos:definition "De op grond van de Wet waardering onroerende zaken vastgestelde waarde van een WOZ-object op een waardepeildatum, voor een aaneengesloten periode van geldigheid, vastgelegd in een WOZ-beschikking." ;
    skos:exactMatch gbobegrip:WOZWaarde ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/waarde-onroerende-zaken> ;
    skos:note "Alias Waarde is de HC-WOZ-naam zonder WOZ-prefix.",
        "De unieke aanduiding (samengesteld uit WOZObject en waardepeildatum) is in LinkML niet als unique_keys uitdrukbaar: de relatie naar WOZObject is inkomend; zie annotatie mim:uniekeAanduiding.",
        "Op WOZ-waarde wordt geen historie binnen één registratie bijgehouden: het tijdsverloop ontstaat door opvolgende beschikkingen (nieuwe WOZ-waarden) en via de beschikkingsStatussen[]-keten.",
        "WOZ-waarde is een onveranderlijke feitstelling per peildatum: gegeven een waardepeildatum en een geldigheidsperiode geldt één vastgestelde waarde. Wijziging van die waarde, bijvoorbeeld na bezwaar of beroep, leidt tot een nieuwe WOZ-waarde, niet tot aanpassing van de bestaande. Eén WOZ-object kent door de tijd meerdere WOZ-waarden; historie staat centraal. De keten beschikkingsStatussen[] (ConceptBeschikking, DefinitieveBeschikking, Bezwaar, Beroep, HogerBeroep, Onherroepelijk) legt het procesverloop per WOZ-waarde vast.",
        "WOZWaarde kent geen eigen uitgaande relaties; de relaties zijn inkomend vanuit WOZObject.kent en WOZDeelobject.kent." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "WOZ" ;
    mim:herkomstDefinitie "Wet WOZ art. 17 en 18 (waardebepaling), art. 22 (beschikking), de Uitvoeringsregeling instructie waardebepaling Wet WOZ en de LV-WOZ-catalogus." ;
    mim:populatie "Alle voor WOZ-objecten in Nederland vastgestelde waarden: concept, voorlopig en definitief, inclusief bezwaar- en beroep-correcties." ;
    mim:uniekeAanduiding "Samengesteld uit (WOZObject, waardepeildatum)" .

