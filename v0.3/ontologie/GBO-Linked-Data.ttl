        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/appartementsrechtsplitsing/opperceel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/appartementsrechtsplitsing/datumsplitsing> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Identificatie ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/appartementsrechtsplitsing/documentnummer> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/appartementsrechtsplitsing/documentdatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/appartementsrechtsplitsing/akteverwijzing> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/onroerende-zaken/appartementsrecht> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/appartementsrechtsplitsing/splitstin> ] ;
    skos:definition "De notariële akte waarbij één of meer percelen worden gesplitst in één of meer appartementsrechten, met vermelding van de verdeling en de aandelen in de gemeenschap." ;
    skos:exactMatch gbobegrip:Appartementsrechtsplitsing,
        gbo:Appartementsrechtsplitsing ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "De splitsingsakte is een eenmalige rechtshandeling die het ontstaan van de appartementsrechten vastlegt. Het akte-object zelf kent geen levensloop met materiële of formele historie; nieuwe of gewijzigde rechtssituaties leiden tot nieuwe akten met eigen identificatie." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK (basisregistratie)" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek Boek 5 titel 9 (art. 106 e.v., splitsing in appartementsrechten); Kadasterwet; BRK-Catalogus." ;
    mim:populatie "Alle in Nederland verleden notariële splitsingsakten waarbij percelen worden gesplitst in appartementsrechten." ;
    mim:uniekeAanduiding "documentnummer" .

