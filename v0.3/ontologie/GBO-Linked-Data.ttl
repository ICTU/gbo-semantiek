        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/huwelijk/plaatsvoltrekking> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstBRP ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/huwelijk/redenontbinding> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstISO3166 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/huwelijk/landvoltrekking> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:DatumIncompleet ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/huwelijk/datumontbinding> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/huwelijk/plaatsvoltrekking> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/personen/soortverbintenis> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/personen/huwelijk/soortverbintenis> ] ;
    skos:definition "Een formele verbintenis tussen twee natuurlijke personen, hetzij een huwelijk in de zin van het burgerlijk recht, hetzij een geregistreerd partnerschap." ;
    skos:exactMatch gbobegrip:Huwelijk,
        gbo:Huwelijk ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "Huwelijk koppelt twee NatuurlijkPersonen symmetrisch via één partners-relatie (2..2), ongeacht hun BRP-inschrijfstatus. Het onderscheid tussen huwelijk en geregistreerd partnerschap loopt via soortVerbintenis. Ontbinding, inclusief overlijden van een partner of echtscheiding, zit als attribuut op het huwelijk zelf." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP cat 05" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek Boek 1 titel 5 (huwelijk) en titel 5A (geregistreerd partnerschap); BRP cat 05 Huwelijk/Geregistreerd Partnerschap; Logisch Ontwerp BRP v4.3.0." ;
    mim:populatie "Alle geregistreerde huwelijken en geregistreerde partnerschappen waarvan ten minste één partner in de BRP is opgenomen, plus huwelijken tussen niet-ingeschreven natuurlijke personen voor zover relevant." .

