gbo:Aantekening a owl:Class ;
    rdfs:label "Aantekening" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:aardAantekening ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumIngang ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:datumIngang ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:omschrijving ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumIngang ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:opKadastraleOnroerendeZaak ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:omschrijving ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:KadastraleOnroerendeZaak ;
            owl:onProperty gbo:opKadastraleOnroerendeZaak ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:omschrijving ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:opKadastraleOnroerendeZaak ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:aardAantekening ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstBRK ;
            owl:onProperty gbo:aardAantekening ],
        gbo:Voorkomen ;
    skos:definition "Een privaatrechtelijke vermelding bij een kadastraal onroerende zaak die een kwalitatieve verplichting, bewindstelling of soortgelijke notarieel ontstane last vastlegt en die via de Basisregistratie Kadaster kenbaar wordt gemaakt." ;
    skos:exactMatch gbobegrip:Aantekening ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Aantekening is de privaatrechtelijke tegenhanger van PubliekrechtelijkeBeperking: beide kunnen tegelijk op dezelfde kadastrale onroerende zaak rusten. Een aantekening ontstaat uit een notariële handeling (bijvoorbeeld de vestiging van een kwalitatieve verplichting of een bewindstelling), niet uit een bestuursbesluit." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK (basisregistratie)" ;
    mim:herkomstDefinitie "Kadasterwet art. 17; Burgerlijk Wetboek Boek 6 (kwalitatieve verplichting); BRK-Catalogus (objecttype Aantekening)." ;
    mim:populatie "Alle privaatrechtelijke aantekeningen die op grond van de Kadasterwet bij een kadastraal onroerende zaak in de BRK zijn geregistreerd." ;
    mim:uniekeAanduiding "identificatie" .

gbo:Appartementsrechtsplitsing a owl:Class ;
    rdfs:label "Appartementsrechtsplitsing" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:opPerceel ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:akteverwijzing ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:documentdatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:documentnummer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:documentdatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:akteverwijzing ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:documentnummer ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Perceel ;
            owl:onProperty gbo:opPerceel ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:splitstIn ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Appartementsrecht ;
            owl:onProperty gbo:splitstIn ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:akteverwijzing ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:datumSplitsing ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumSplitsing ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Identificatie ;
            owl:onProperty gbo:documentnummer ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:documentdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumSplitsing ] ;
    skos:definition "De notariële akte waarbij één of meer percelen worden gesplitst in één of meer appartementsrechten, met vermelding van de verdeling en de aandelen in de gemeenschap." ;
    skos:exactMatch gbobegrip:Appartementsrechtsplitsing ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "De splitsingsakte is een eenmalige rechtshandeling die het ontstaan van de appartementsrechten vastlegt. Het akte-object zelf kent geen levensloop met materiële of formele historie; nieuwe of gewijzigde rechtssituaties leiden tot nieuwe akten met eigen identificatie." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK (basisregistratie)" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek Boek 5 titel 9 (art. 106 e.v., splitsing in appartementsrechten); Kadasterwet; BRK-Catalogus." ;
    mim:populatie "Alle in Nederland verleden notariële splitsingsakten waarbij percelen worden gesplitst in appartementsrechten." ;
    mim:uniekeAanduiding "documentnummer" .

gbo:Arbeidsongeschiktheidspercentage a owl:Class ;
    rdfs:label "Arbeidsongeschiktheidspercentage" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:duurzaamIndicatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:percentage ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:bepaaldDoor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:bepaaldDoor ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:vaststellingsdatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:vaststellingsdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Decimaal ;
            owl:onProperty gbo:percentage ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:duurzaamIndicatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:vaststellingsdatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:percentage ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Beslissing ;
            owl:onProperty gbo:bepaaldDoor ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Indicatie ;
            owl:onProperty gbo:duurzaamIndicatie ] ;
    skos:definition "Het door een verzekeringsarts en arbeidsdeskundige vastgestelde percentage waarmee de verdiencapaciteit van een werknemer ten opzichte van zijn oude loon is verminderd, op grond waarvan de WIA-uitkering wordt geclassificeerd in IVA of WGA met hun fasen." ;
    skos:exactMatch gbobegrip:Arbeidsongeschiktheidspercentage ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/werk-en-inkomen> ;
    skos:note "Het percentage bepaalt de uitkeringstak: 80% of meer duurzaam geeft IVA; 35% tot 80% of 80% of meer niet-duurzaam geeft WGA; minder dan 35% geeft geen recht op WIA. Een herziening kan leiden tot een wijziging van uitkeringssoort en hoogte." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SGR cluster Beslissing" ;
    mim:herkomstDefinitie "Schattingsbesluit arbeidsongeschiktheidswetten; Wet werk en inkomen naar arbeidsvermogen." ;
    mim:populatie "Alle door UWV vastgestelde arbeidsongeschiktheidspercentages die de basis vormen voor classificatie van een WIA-uitkering in IVA of WGA, inclusief herzieningen." .

