        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/arbeidsverledenfeit/begindatum> ] ;
    skos:definition "Een afzonderlijk feit in het arbeids- of inkomensverleden van een natuurlijk persoon, zoals een periode in dienst, een periode met uitkering of een leerwerk-periode, dat relevant is voor de berekening van werknemersverzekerings-rechten." ;
    skos:exactMatch gbobegrip:ArbeidsverledenFeit,
        gbo:ArbeidsverledenFeit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/werk-en-inkomen> ;
    skos:note "Arbeidsverleden bepaalt onder andere de WW-duur. ArbeidsverledenFeit dient als bouwsteen waarmee UWV een arbeidsverleden-overzicht kan opstellen, met feit-typen voor dienstverband, uitkeringsperiode, leerwerk-periode en periode van zelfstandig werk." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SGR cluster Arbeidsverhouding" ;
    mim:herkomstDefinitie "Werkloosheidswet (refertes 26-uit-36-weken en 4-uit-5-jaren); SGR cluster Arbeidsverhouding." ;
    mim:populatie "Alle afzonderlijke feiten in het arbeids- of inkomensverleden van een natuurlijk persoon (dienstverband, uitkeringsperiode, leerwerk-periode of periode zelfstandig werk) die relevant zijn voor de berekening van werknemersverzekerings-rechten." .

<https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringiva> a owl:Class ;
    rdfs:label "UitkeringIVA" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:Decimaal ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringiva/uitkeringspercentage> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringiva/dagloonbedrag> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringiva/dagloonbedrag> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringiva/uitkeringspercentage> ],
        <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringwia> ;
    skos:definition "De Inkomensvoorziening Volledig Arbeidsongeschikten op grond van de WIA, toegekend aan werknemers die duurzaam minder dan twintig procent van hun oude loon kunnen verdienen." ;
    skos:exactMatch gbobegrip:UitkeringIVA,
        gbo:UitkeringIVA ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/werk-en-inkomen> ;
    skos:note "IVA-criterium: minder dan 20% van het oude loon kunnen verdienen en geen herstel verwacht. De uitkering is hoger en stabieler dan WGA omdat het duurzaamheids-criterium is gehaald." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SGR cluster Uitkering" ;
    mim:herkomstDefinitie "Wet WIA hoofdstuk IV (IVA-regeling)." ;
    mim:notation "IVA" ;
    mim:populatie "Alle door UWV toegekende IVA-uitkeringen aan werknemers die duurzaam minder dan twintig procent van hun oude loon kunnen verdienen, op grond van hoofdstuk IV van de Wet WIA." .

<https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringwga> a owl:Class ;
    rdfs:label "UitkeringWGA" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:Decimaal ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringwga/arbeidsongeschiktheidspercentage> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringwga/wgafase> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringwga/dagloonbedrag> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringwga/dagloonbedrag> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringwga/arbeidsongeschiktheidspercentage> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringwga/wgafase> ],
        <https://lod.gbo-semantiek.nl/werk-en-inkomen/uitkeringwia> ;
    skos:definition "De Werkhervatting Gedeeltelijk Arbeidsongeschikten op grond van de WIA, toegekend aan werknemers die vijfendertig procent tot tachtig procent arbeidsongeschikt zijn, of volledig arbeidsongeschikt maar niet duurzaam." ;
    skos:exactMatch gbobegrip:UitkeringWGA,
        gbo:UitkeringWGA ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/werk-en-inkomen> ;
    skos:note "Drie fasen: LGU (loongerelateerde uitkering, op basis van arbeidsverleden), LAU (loonaanvullingsuitkering, wanneer de uitkering minus resterende verdiencapaciteit boven een drempel uitkomt) en VVU (vervolguitkering, gerelateerd aan minimumloon-percentages)." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SGR cluster Uitkering" ;
    mim:herkomstDefinitie "Wet WIA hoofdstuk VII (WGA-regeling)." ;
    mim:notation "WGA" ;
    mim:populatie "Alle door UWV toegekende WGA-uitkeringen aan werknemers die 35 tot 80 procent arbeidsongeschikt zijn, of volledig maar niet duurzaam, verdeeld over de fasen LGU, LAU en VVU." .

xsd:gYear a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[0-9]{4}$" ] ) ] ) ] .

gbo:BRINcode a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( gbo:Tekst [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[0-9]{2}[A-Z]{2}$" ] ) ] ) ] .

gbo:BSN a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( gbo:Tekst [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[0-9]{9}$" ] ) ] ) ] .

