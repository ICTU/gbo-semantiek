gbo:StatusWOZWaarde a owl:Class ;
    rdfs:label "StatusWOZWaarde" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/StatusWOZWaarde#DefinitiefVastgesteld> <https://lod.gbo-semantiek.nl/StatusWOZWaarde#Vervallen> <https://lod.gbo-semantiek.nl/StatusWOZWaarde#VoorlopigVastgesteld> ) ;
