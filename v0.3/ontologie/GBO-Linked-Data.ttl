gbo:AftrekpostCategorie a owl:Class ;
    rdfs:label "AftrekpostCategorie" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/AftrekpostCategorie#Hypotheekrenteaftrek> <https://lod.gbo-semantiek.nl/AftrekpostCategorie#Partneralimentatie> <https://lod.gbo-semantiek.nl/AftrekpostCategorie#Lijfrente> <https://lod.gbo-semantiek.nl/AftrekpostCategorie#Giften> <https://lod.gbo-semantiek.nl/AftrekpostCategorie#Zorgkosten> <https://lod.gbo-semantiek.nl/AftrekpostCategorie#WeekenduitgavenGehandicaptKind> ) ;
    skos:definition "De categorieen van aftrekposten die op grond van Wet IB 2001 in de IH-aangifte kunnen worden opgevoerd." ;
    skos:exactMatch gbobegrip:AftrekpostCategorie ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Circa 20 categorieen; opgenomen is een top-selectie van de meest voorkomende." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Wet IB 2001 + SBR-NT" ;
    mim:herkomstDefinitie "Wet IB 2001 hoofdstuk 6 (persoonsgebonden aftrek) en hoofdstuk 3 (eigenwoning); SBR-NT NT20." ;
