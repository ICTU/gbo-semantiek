            owl:minCardinality 0 ;
            owl:onProperty gbo:toekenningsbedragMaand ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Beurssoort ;
            owl:onProperty gbo:beurssoort ],
        [ a owl:Restriction ;
