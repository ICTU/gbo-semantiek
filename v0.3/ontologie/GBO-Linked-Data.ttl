            owl:onProperty gbo:inOpenbareRuimte ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:huisnummer ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:TypeAdresseerbaarObject ;
            owl:onProperty gbo:typeAdresseerbaarObject ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:postcode ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:huisletter ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:huisnummertoevoeging ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:typeAdresseerbaarObject ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:identificatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:inOpenbareRuimte ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:typeAdresseerbaarObject ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty gbo:huisnummer ],
        [ a owl:Restriction ;
