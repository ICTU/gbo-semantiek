            owl:onProperty gbo:wijknaam ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:wijknaam ] ;
    skos:definition "Een aaneengesloten gedeelte van een gemeente waarvan de grenzen primair zijn gebaseerd op sociaal-geografische kenmerken, vastgesteld door het Centraal Bureau voor de Statistiek." ;
    skos:exactMatch gbobegrip:Wijk ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Wijk staat formeel buiten de BAG (CBS-data); opgenomen vanwege gangbaarheid bij beleids- en analyse-afnemers. CBS herziet de wijkgrenzen jaarlijks; mutaties komen via CBS Open Data." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "CBS Wijk- en Buurtkaart" ;
    mim:herkomstDefinitie "CBS Wijk- en Buurtkaart (jaarlijkse vaststelling); NEN 3610 voor het algemene patroon. BAG-formeel kent geen Wijk." ;
    mim:populatie "Alle CBS-wijken binnen Nederland zoals jaarlijks vastgesteld in de CBS Wijk- en Buurtkaart." ;
    mim:uniekeAanduiding "wijkcode (CBS-code)" .

gbo:Woonplaats a owl:Class ;
    rdfs:label "Woonplaats" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:BAGID ;
