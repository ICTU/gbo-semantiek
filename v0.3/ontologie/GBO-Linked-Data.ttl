            owl:onProperty gbo:overlijdensdatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:overlijdensdatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:aantalErfgenamen ],
        [ a owl:Restriction ;
