            owl:onProperty gbo:aangifteperiode ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:binnenInkomstenverhouding ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:loonSvBedrag ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:loonHuidigPeriodeBedrag ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ingehoudenLoonheffing ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:ingehoudenLoonheffing ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:loonSvBedrag ] ;
    skos:definition "De aggregatie van loongegevens van een werknemer binnen een aangifte loonheffingen over een aangifteperiode, opgebouwd uit een of meer inkomstenperioden en alle daarop horende loonbestanddelen." ;
    skos:exactMatch gbobegrip:Inkomstenopgave ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Per inkomstenverhouding en per aangifteperiode is er een inkomstenopgave. De aangifteperiode is doorgaans een maand, vier weken of week, afhankelijk van de loonperiode van de inhoudingsplichtige." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Loonheffingen 2026" ;
    mim:herkomstDefinitie "Gegevensspecificaties aangifte loonheffingen 2026." ;
    mim:populatie "Alle aggregaties van loongegevens van een werknemer binnen een aangifte loonheffingen over een aangifteperiode (typisch maand, vier weken of week)." .

gbo:Instelling a owl:Class ;
    rdfs:label "Instelling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:rechtsvorm ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:rechtsvorm ],
        [ owl:unionOf ( gbo:MaatschappelijkeInstelling gbo:Overheidsinstelling ) ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstKVKInstelling ;
            owl:onProperty gbo:rechtsvorm ],
        gbo:NietNatuurlijkPersoon ;
    skos:definition "Niet-commerciële niet-natuurlijke persoon, hetzij publiekrechtelijk (overheidsorgaan) hetzij privaatrechtelijk maar zonder winstoogmerk (zoals stichting, vereniging, kerkgenootschap)." ;
    skos:exactMatch gbobegrip:Instelling ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Instelling is het abstracte supertype boven twee concrete vormen: Overheidsinstelling (Rijk, Provincie, Gemeente, Waterschap, ZBO, RWT) en MaatschappelijkeInstelling (privaatrechtelijke non-profit). De rechtsvorm staat op het abstracte supertype omdat een stichting zowel een overheidsrol (ZBO of RWT) als een maatschappelijke rol kan vervullen; de sectorale typering komt op het concrete subtype." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "NHR; BW2" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek boek 2 voor de privaatrechtelijke rechtspersonen zonder winstoogmerk en publiekrechtelijke rechtspersoon-vormgeving uit de Algemene wet bestuursrecht en organieke wetgeving (Gemeentewet, Provinciewet, Waterschapswet, Kaderwet ZBO)." ;
    mim:populatie "Alle niet-commerciële niet-natuurlijke personen, ingeschreven in het Handelsregister of herkenbaar via een ander officieel register (TOOI, RIO)." ;
    mim:uniekeAanduiding "ID (geërfd)" .

gbo:KOZStatus a owl:Class ;
    rdfs:label "KOZStatus" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/KOZStatus#Actueel> <https://lod.gbo-semantiek.nl/KOZStatus#Historisch> ) ;
    skos:altLabel "kadastraalOnroerendeZaakStatus" ;
    skos:definition "Levenscyclus-status van een kadastrale onroerende zaak in de Basisregistratie Kadaster." ;
    skos:exactMatch gbobegrip:KOZStatus ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Een kadastrale onroerende zaak (perceel of appartementsrecht) heeft op elk moment één status. Bij overgang naar Historisch is de zaak niet langer geldig, typisch het gevolg van splitsing, samenvoeging of grenscorrectie. De identificatie blijft beschikbaar via BRK-Levering." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK" ;
    mim:herkomstDefinitie "BRK-Catalogus (Kadaster); Kadasterwet." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/KOZStatus#Actueel>,
        <https://lod.gbo-semantiek.nl/KOZStatus#Historisch> .

gbo:KredietFeit a owl:Class ;
    rdfs:label "KredietFeit" ;
    rdfs:subClassOf [ owl:unionOf ( gbo:AchterstandRegistratie gbo:BijzonderheidsCodering gbo:HerstelMelding ) ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumGebeurtenis ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumGebeurtenis ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:datumGebeurtenis ] ;
    skos:definition "Een tijdens de looptijd van een kredietovereenkomst opgetreden gebeurtenis die op grond van het Algemeen Reglement CKI aan het Centraal Krediet Informatiesysteem wordt gemeld, zoals het ontstaan van een achterstand, het herstel van een achterstand of het optreden van een bijzonderheid." ;
    skos:exactMatch gbobegrip:KredietFeit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "Abstract; concrete varianten zijn AchterstandRegistratie, HerstelMelding en BijzonderheidsCodering. Gebeurtenis-modellering is hier gekozen boven attribuut-modellering op de kredietovereenkomst zelf, omdat een overeenkomst in haar looptijd meerdere keren een achterstand kan kennen, gevolgd door herstel, gevolgd door opnieuw een achterstand." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 12 en art. 13." ;
    mim:populatie "Abstract. Concrete populatie wordt bepaald door de subklassen AchterstandRegistratie, HerstelMelding en BijzonderheidsCodering: alle gedurende de looptijd van een kredietovereenkomst aan CKI gemelde gebeurtenissen." .

gbo:NEN3610ID a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

