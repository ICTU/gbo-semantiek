            owl:onProperty gbo:vormt ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:huisnummertoevoeging ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:StatusNummeraanduiding ;
            owl:onProperty gbo:status ],
        [ a owl:Restriction ;
