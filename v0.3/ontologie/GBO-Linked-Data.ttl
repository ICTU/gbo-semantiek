            owl:onProperty gbo:geometrie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Wijk ;
            owl:onProperty gbo:inWijk ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:inWijk ] ;
    skos:definition "Een aaneengesloten gedeelte van een wijk waarvan de grenzen primair zijn gebaseerd op topografische elementen, vastgesteld door het Centraal Bureau voor de Statistiek." ;
    skos:exactMatch gbobegrip:Buurt ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Wijk en Buurt staan formeel buiten de BAG (CBS-data); ze zijn in dit deelmodel opgenomen vanwege hun gangbaarheid bij beleids- en analyse-afnemers (sociaal domein, demografie). CBS herziet de buurtgrenzen jaarlijks; mutaties komen via CBS Open Data." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "CBS Wijk- en Buurtkaart" ;
    mim:herkomstDefinitie "CBS Wijk- en Buurtkaart (jaarlijkse vaststelling); NEN 3610 voor het algemene patroon. BAG-formeel kent geen Buurt." ;
    mim:populatie "Alle CBS-buurten binnen Nederland zoals jaarlijks vastgesteld in de CBS Wijk- en Buurtkaart." ;
    mim:uniekeAanduiding "buurtcode (CBS-code)" .

