            owl:onProperty gbo:begeleidDoor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:aangegaanDoor ],
        [ owl:unionOf ( gbo:AflopendKrediet gbo:DoorlopendKrediet gbo:HypothecairKredietEigenWoning gbo:HypothecairKredietOverigeOnroerendeZaken gbo:KortKrediet gbo:OperationalAutolease gbo:OverigeFinancieleVerplichtingPrive gbo:RestschuldHypothecairKredietMetNHG gbo:RestschuldHypothecairKredietZonderNHG gbo:Saneringskrediet gbo:ZakelijkKrediet gbo:ZakelijkeOverigeFinancieleVerplichting ) ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:BijzonderheidsCodering ;
            owl:onProperty gbo:begeleidDoor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:achterstandstermijn ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:verstrektDoor ],
