            owl:allValuesFrom <https://lod.gbo-semantiek.nl/belastingen/vermogensbestanddeelcategorie> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/vermogensbestanddeel/categorie> ],
        [ owl:unionOf ( <https://lod.gbo-semantiek.nl/belastingen/bankspaartegoed> <https://lod.gbo-semantiek.nl/belastingen/belegging> <https://lod.gbo-semantiek.nl/belastingen/cryptovaluta> <https://lod.gbo-semantiek.nl/belastingen/onroerendezaakoverigbezit> <https://lod.gbo-semantiek.nl/belastingen/schuld> ) ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/datatypes/bedrag> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/vermogensbestanddeel/waardepeildatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/personen/natuurlijkpersoon> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/vermogensbestanddeel/houdervan> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/vermogensbestanddeel/houdervan> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/vermogensbestanddeel/waardepeildatum> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/belastingen/vermogensbestanddeel/categorie> ],
        <https://lod.gbo-semantiek.nl/belastingen/fiscaalfeit> ;
    skos:definition "Een bezitting of schuld die op de peildatum 1 januari onder Box 3 van de inkomstenbelasting valt en als zelfstandige post in de aangifte wordt opgevoerd." ;
    skos:exactMatch gbobegrip:VermogensBestanddeel,
