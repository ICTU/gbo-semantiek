<https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling> a owl:Class ;
    rdfs:label "Voertuigtenaamstelling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/voertuigen/tenaamstellingsrol> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/rol> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/datumtenaamstelling> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/datumtenaamstelling> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/tenaamgesteldeop> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/datumeinde> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/hoofdmodel/partij> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/tenaamgesteldeop> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/rol> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/voorvoertuig> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/datumeinde> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/voertuigen/voertuig> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/voorvoertuig> ],
        <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen> ;
    owl:hasKey ( <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/tenaamgesteldeop> <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/voorvoertuig> <https://lod.gbo-semantiek.nl/voertuigen/voertuigtenaamstelling/datumtenaamstelling> ) ;
    skos:definition "De geregistreerde rechtsbetrekking tussen een partij en een voertuig, waarmee de partij als eigenaar en/of houder van het voertuig is geregistreerd." ;
    skos:exactMatch gbobegrip:Voertuigtenaamstelling,
        gbo:Voertuigtenaamstelling ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/voertuigen> ;
    skos:note "MIM-element: Relatieklasse (verdinglijkte relatie).",
        "Voertuigtenaamstelling is een verbinding met eigen kenmerken tussen Partij en Voertuig, vergelijkbaar met Tenaamstelling in het deelmodel Onroerende zaken. Een overdracht leidt tot een nieuwe tenaamstelling met latere datumTenaamstelling terwijl de oude een datumEinde krijgt; zo blijven historie en eigendomsverloop modelleerbaar." ;
    mim:datumOpname "2026-06-16" ;
    mim:herkomst "BRV (basisregistratie)" ;
    mim:herkomstDefinitie "Wegenverkeerswet 1994 (tenaamstelling, art. 42 e.v.); Kentekenreglement; RDW Kentekenregister." ;
    mim:populatie "Alle in de Basisregistratie Voertuigen geregistreerde tenaamstellingen, historisch en actueel, die een partij aan een voertuig koppelen." ;
    mim:uniekeAanduiding "Samengesteld uit (Partij, Voertuig, datumTenaamstelling)" .

<https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozdeelobject> a owl:Class ;
    rdfs:label "WOZDeelobject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozwaarde> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozdeelobject/kentwozwaarde> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozdeelobject/deelobjectnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozdeelobject/deelobjectnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozdeelobject/omschrijving> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozdeelobject/omschrijving> ] ;
    skos:definition "Een afzonderlijk gewaardeerd onderdeel binnen een WOZ-object, dat een eigen gebruik of eigen waardering kent ten opzichte van het samengestelde hoofdobject." ;
    skos:exactMatch gbobegrip:WOZDeelobject,
        gbo:WOZDeelobject ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/waarde-onroerende-zaken> ;
    skos:note "De unieke aanduiding (deelobjectnummer binnen WOZObject) is in LinkML niet uitdrukbaar: deelobjectnummer is alleen uniek binnen het omvattende WOZ-object en de relatie naar WOZObject is inkomend (WOZObject.bevat); zie annotatie mim:uniekeAanduiding.",
        "Deelobjecten komen voor bij gemengd gebruik of gedifferentieerde waardering binnen één fiscale eenheid, bijvoorbeeld wonen en bedrijf in één pand. Deelobjecten zijn niet in scope van HC-WOZ v1.0; alleen via StUF-WOZ beschikbaar. In dit deelmodel staat de klasse opgenomen voor bron-compatibiliteit; verdere attribuut-uitwerking volgt bij een concrete use-case." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "WOZ" ;
    mim:herkomstDefinitie "Uitvoeringsregeling instructie waardebepaling Wet WOZ en de Waarderingsinstructie van de Waarderingskamer." ;
    mim:populatie "Alle in de LV-WOZ via StUF-WOZ geregistreerde deelobjecten binnen WOZ-objecten met gedifferentieerde waardering." ;
    mim:uniekeAanduiding "deelobjectnummer binnen WOZObject" .

