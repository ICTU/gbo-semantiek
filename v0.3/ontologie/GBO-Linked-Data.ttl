gbo:TypeZekerheidsrecht a owl:Class ;
    rdfs:label "TypeZekerheidsrecht" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/TypeZekerheidsrecht#Beslag> <https://lod.gbo-semantiek.nl/TypeZekerheidsrecht#Hypotheek> ) ;
    skos:definition "Type van een op een kadastraal onroerende zaak rustend zekerheidsrecht, onderscheidend tussen hypotheek en beslag." ;
    skos:exactMatch gbobegrip:TypeZekerheidsrecht ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Bepaalt of het zekerheidsrecht voortvloeit uit een hypotheekvestiging dan wel uit een gerechtelijk of fiscaal beslag. Bij waarde Beslag wordt het aanvullende attribuut aardBeslag ingevuld (zie enumeratie AardBeslag)." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek Boek 3 titel 9 (recht van pand en hypotheek); Wetboek van Burgerlijke Rechtsvordering (beslag); BRK-Catalogus." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/TypeZekerheidsrecht#Beslag>,
        <https://lod.gbo-semantiek.nl/TypeZekerheidsrecht#Hypotheek> .

