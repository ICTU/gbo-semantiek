            owl:onProperty gbo:specialisatie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:uitgereiktDoor ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstDiplomasoort ;
            owl:onProperty gbo:diplomasoort ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:graad ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:behaaldDoor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:uitgereiktDoor ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:resultaatId ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:behaaldatum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:specialisatie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:specialisatie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:OnderwijsInstelling ;
            owl:onProperty gbo:uitgereiktDoor ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:voorOpleiding ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:voorOpleiding ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:behaaldatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:graad ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:resultaatsoort ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:graad ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:diplomasoort ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:OpleidingDeelname ;
            owl:onProperty gbo:volgtOpDeelname ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:behaaldDoor ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:resultaatId ] ;
    skos:definition "Het door een natuurlijk persoon behaalde resultaat voor een opleiding of onderdeel daarvan bij een onderwijsinstelling, blijkend uit een diploma, certificaat, deelcertificaat of vergelijkbaar bewijsstuk." ;
    skos:exactMatch gbobegrip:OpleidingResultaat ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "OpleidingResultaat ontstaat na succesvolle afronding of bij een deelresultaat zoals een propedeuse in HO of een deelcertificaat in MBO. Een uitschrijving zonder resultaat leidt niet tot een OpleidingResultaat-record. Hetzelfde resultaat-record speelt twee rollen in het deelmodel: als afsluiting van een OpleidingDeelname via leidtTot en als Vooropleiding bij een volgende deelname. In het HO is \"Getuigschrift\" de wettelijke benaming voor het bachelor- of master-bewijsstuk; dat is een voorkomen met resultaatsoort = Getuigschrift." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Register Onderwijsdeelnemers per sector" ;
    mim:herkomstDefinitie "WHW art. 7.10a (HO-getuigschrift); WEB art. 7.4.6 (MBO-diploma); WVO 2020 art. 2.61 (VO-eindexamen); Wet op het onderwijsnummer voor de meldingsplicht naar DUO." ;
    mim:kwaliteit "Resultaatmelding is verplicht na uitreiken. Authenticiteit is geborgd doordat alleen erkende instellingen mogen melden via Edukoppeling. Een ten onrechte verstrekt diploma kan via een terugkoppelmelding worden ingetrokken; de bijhouding registreert dat als correctie." ;
    mim:populatie "Alle resultaten die op grond van de sectorregels in ROD worden gemeld: diploma's, certificaten, deelcertificaten en in HO afsluitende getuigschriften plus tussentijdse propedeuse-uitkomsten." ;
    mim:uniekeAanduiding "resultaatId" .

gbo:Perceel a owl:Class ;
    rdfs:label "Perceel" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:perceelnummer ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty gbo:sectie ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:oppervlakte ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:sectie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty gbo:perceelnummer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:kadastraleGemeente ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty gbo:oppervlakte ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:perceelnummer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:oppervlakte ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:sectie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstKadaster ;
            owl:onProperty gbo:kadastraleGemeente ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:kadastraleGemeente ],
        gbo:KadastraleOnroerendeZaak ;
    owl:hasKey ( gbo:kadastraleAanduiding ) ;
    skos:altLabel "Kadastraal perceel" ;
    skos:definition "Een kadastraal afgebakend en als zelfstandige eenheid in de Basisregistratie Kadaster geregistreerd stuk grond, identificeerbaar via de kadastrale aanduiding (kadastrale gemeente, sectie, perceelnummer)." ;
    skos:exactMatch gbobegrip:Perceel ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Alias Kadastraal perceel is de BRK-LO volledige naam.",
        "Perceel beschrijft de kadastraal-juridische werkelijkheid: een afgebakend stuk grond als registratie-eenheid, los van de fysieke bebouwing (Pand in BAG) en los van de fiscale waardering (WOZ-object). Een perceel kan onbebouwd zijn, één pand dragen, of door meerdere panden gedeeltelijk worden bedekt; een pand kan over meerdere percelen liggen." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK (basisregistratie)" ;
    mim:herkomstDefinitie "Kadasterwet art. 1; BRK-Catalogus (objecttype KadastraalPerceel); IMKAD." ;
    mim:populatie "Alle kadastraal afgebakende stukken grond in Nederland zoals geregistreerd in de BRK door het Kadaster, inclusief actuele en historische percelen." ;
    mim:uniekeAanduiding "kadastraleAanduiding" .

gbo:Postcode a rdfs:Datatype ;
