    rdfs:label "kadastraleAanduiding" ;
    skos:definition "Samengestelde aanduiding (kadastrale gemeente / sectie / perceelnummer / eventueel indexnummer)." ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Menselijk leesbare aanduiding." ;
    mim:authentiek "Authentiek" ;
    mim:formeleHistorie true ;
    mim:herkomst "BRK-Catalogus" ;
