gbo:HerstelMelding a owl:Class ;
    rdfs:label "HerstelMelding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:datumGebeurtenis ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:datumGebeurtenis ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:datumGebeurtenis ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:AchterstandRegistratie ;
            owl:onProperty gbo:volgtOp ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:volgtOp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:volgtOp ],
        gbo:KredietFeit ;
    skos:definition "Een melding aan het Centraal Krediet Informatiesysteem dat een eerder gemelde achterstand op een kredietovereenkomst is opgelost doordat de kredietnemer zijn betalingsverplichtingen weer volledig nakomt of de gehele schuld heeft voldaan." ;
    skos:exactMatch gbobegrip:HerstelMelding ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/krediet> ;
    skos:note "De melding markeert het einde van de actieve achterstand. Het moment is bindend voor de bewaartermijn van de oorspronkelijke achterstandsregistratie. Voor de kredietwaardigheidsbeoordeling door derden blijft een gemelde maar herstelde achterstand zichtbaar, doch telt zachter mee dan een lopende." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "CKI" ;
    mim:herkomstDefinitie "Algemeen Reglement CKI van 1 juli 2024, art. 12 lid 3." ;
    mim:populatie "Alle aan CKI gemelde herstellen van eerder geregistreerde achterstanden, gedurende de bewaartermijn van de oorspronkelijke achterstand." .

