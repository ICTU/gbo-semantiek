        <https://lod.gbo-semantiek.nl/Resultaatsoort#Propedeuse> .

gbo:TypeBuitenlandseEntiteit a owl:Class ;
    rdfs:label "TypeBuitenlandseEntiteit" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/TypeBuitenlandseEntiteit#Filiaal> <https://lod.gbo-semantiek.nl/TypeBuitenlandseEntiteit#Hoofdkantoor> <https://lod.gbo-semantiek.nl/TypeBuitenlandseEntiteit#Zustermaatschappij> <https://lod.gbo-semantiek.nl/TypeBuitenlandseEntiteit#PermanenteVestiging> <https://lod.gbo-semantiek.nl/TypeBuitenlandseEntiteit#OverigBuitenlands> ) ;
    skos:definition "Typering van de Nederlandse aanwezigheid van een entiteit met hoofdvestiging buiten Nederland." ;
    skos:exactMatch gbobegrip:TypeBuitenlandseEntiteit ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/bedrijven-en-instellingen> ;
    skos:note "Omdat een Nederlandse codelijst voor buitenlandse rechtsvormen ontbreekt, gebruikt GBO deze enumeratie voor het filterbare onderscheid in de aard van de Nederlandse aanwezigheid. De buitenlandse juridische vorm zelf staat als vrije tekst in rechtsvormBuitenland." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "GBO" ;
    mim:herkomstDefinitie "Handelsregisterwet 2007 art. 5d (onderneming van een buitenlandse rechtspersoon met hoofd- of nevenvestiging in Nederland); KVK Catalogus Basisprofiel voor het classificatie-deel." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/TypeBuitenlandseEntiteit#Filiaal>,
        <https://lod.gbo-semantiek.nl/TypeBuitenlandseEntiteit#Hoofdkantoor>,
        <https://lod.gbo-semantiek.nl/TypeBuitenlandseEntiteit#OverigBuitenlands>,
        <https://lod.gbo-semantiek.nl/TypeBuitenlandseEntiteit#PermanenteVestiging>,
        <https://lod.gbo-semantiek.nl/TypeBuitenlandseEntiteit#Zustermaatschappij> .

gbo:Uitkering a owl:Class ;
    rdfs:label "Uitkering" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:basisVoor ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:RedenEindeUitkering ;
            owl:onProperty gbo:redenEinde ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:soortUitkering ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:redenEinde ],
        [ owl:unionOf ( gbo:UitkeringAOW gbo:UitkeringWIA gbo:UitkeringWW gbo:UitkeringWajong gbo:UitkeringZW ) ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:toegekendAan ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:basisVoor ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:redenEinde ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Dagloon ;
            owl:onProperty gbo:basisVoor ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:bedragMaand ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:bedragMaand ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:gegrondvestOp ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:gegrondvestOp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:soortUitkering ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Beslissing ;
            owl:onProperty gbo:gegrondvestOp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:bedragMaand ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:toegekendAan ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:SoortUitkering ;
            owl:onProperty gbo:soortUitkering ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty gbo:ingangsdatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:NatuurlijkPersoon ;
            owl:onProperty gbo:toegekendAan ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:ingangsdatum ],
        gbo:InkomensOndersteuning ;
    skos:definition "Een door of namens de overheid aan een natuurlijk persoon toegekende periodieke uitkering op grond van een werknemersverzekering of volksverzekering, ter vervanging of aanvulling van loon." ;
    skos:exactMatch gbobegrip:Uitkering ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/werk-en-inkomen> ;
    skos:note "Zeven concrete varianten, uitgevoerd door UWV (WW, ZW, WIA, IVA, WGA, Wajong) of SVB (AOW)." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SGR cluster Uitkering" ;
    mim:herkomstDefinitie "Wet SUWI plus de afzonderlijke werknemers- en volksverzekeringswetten (Werkloosheidswet, Ziektewet, Wet WIA, Wajong, AOW)." ;
    mim:populatie "Alle aan natuurlijke personen toegekende periodieke uitkeringen op grond van een werknemersverzekering (WW, ZW, WIA, IVA, WGA, Wajong) of volksverzekering (AOW), uitgevoerd door UWV of SVB." .

gbo:VermogensBestanddeel a owl:Class ;
    rdfs:label "VermogensBestanddeel" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:categorie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:houderVan ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:waardePeildatum ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:VermogensBestanddeelCategorie ;
            owl:onProperty gbo:categorie ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Bedrag ;
            owl:onProperty gbo:waardePeildatum ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:categorie ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:waardePeildatum ],
        [ owl:unionOf ( gbo:BankSpaartegoed gbo:Belegging gbo:Cryptovaluta gbo:OnroerendeZaakOverigBezit gbo:Schuld ) ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:NatuurlijkPersoon ;
            owl:onProperty gbo:houderVan ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:houderVan ],
        gbo:FiscaalFeit ;
    skos:definition "Een bezitting of schuld die op de peildatum 1 januari onder Box 3 van de inkomstenbelasting valt en als zelfstandige post in de aangifte wordt opgevoerd." ;
    skos:exactMatch gbobegrip:VermogensBestanddeel ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/belastingen> ;
    skos:note "Abstract. Vijf concrete categorieen: bank- of spaartegoed, belegging, cryptovaluta, onroerende zaak overig bezit en schuld. Per categorie gelden eigen waarderings-regels." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SBR-NT NT20" ;
    mim:herkomstDefinitie "Wet IB 2001 hoofdstuk 5; SBR-NT NT20." ;
    mim:populatie "Alle bezittingen en schulden die op peildatum 1 januari onder Box 3 vallen en als zelfstandige post in een IH-aangifte worden opgevoerd." .

