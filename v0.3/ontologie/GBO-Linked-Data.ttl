            owl:allValuesFrom <https://lod.gbo-semantiek.nl/onderwijs/resultaatstatus> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/resultaatstatus> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/binnen> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/inschrijfdatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/onderwijs/opleidingdeelname> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/binnen> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/resultaatstatus> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/moduleidentificatie> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Datum ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/inschrijfdatum> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Decimaal ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/ects> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/cijfer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/moduleidentificatie> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/ects> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/cijfer> ] ;
    owl:hasKey ( gbo:binnen <https://lod.gbo-semantiek.nl/onderwijs/moduleinschrijving/moduleidentificatie> ) ;
    skos:definition "De inschrijving van een student voor een onderwijseenheid binnen een lopende opleiding-deelname in het hoger onderwijs, met een vastgestelde studielast in ECTS." ;
    skos:exactMatch gbobegrip:ModuleInschrijving,
        gbo:ModuleInschrijving ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "ModuleInschrijving is een fijnmazige gebeurtenis binnen een OpleidingDeelname: één deelname kan meerdere moduleinschrijvingen omvatten. Eén EC komt overeen met circa achtentwintig studieuren. Een moduleinschrijving levert geen zelfstandig bewijsstuk; het cumulatief behalen van modules leidt tot een getuigschrift, gemodelleerd als OpleidingResultaat." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Register Onderwijsdeelnemers, cluster HO" ;
    mim:herkomstDefinitie "Wet op het hoger onderwijs en wetenschappelijk onderzoek (WHW) art. 7.3 (opleiding) en art. 7.3a (onderwijseenheden en studiepunten); studielast uitgedrukt in EC, conform het Europese ECTS-systeem." ;
    mim:kwaliteit "Aangeleverd door de HO-instelling; resultaatstatus volgt de instellings-administratie." ;
    mim:populatie "Inschrijvingen van HO-studenten voor onderwijseenheden die de instelling op grond van de WHW als examenonderdeel registreert." ;
    mim:uniekeAanduiding "moduleIdentificatie binnen OpleidingDeelname" .

