        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/aanduiding> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/kentwozwaarde> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/statuswozobject> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/refereert> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/grondoppervlakte> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adresseerbaarobject> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/refereert> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/ligtop> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/verantwoordelijkegemeente> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstWOZ ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/gebruikscode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozdeelobject> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/bevat> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/onroerende-zaken/perceel> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/ligtop> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:ObjectAanduiding ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/aanduiding> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstLT33 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/waarde-onroerende-zaken/wozobject/verantwoordelijkegemeente> ],
        <https://lod.gbo-semantiek.nl/hoofdmodel/voorkomen> ;
    skos:definition "De fiscale eenheid van onroerende zaak waarop de Wet waardering onroerende zaken van toepassing is: het kleinste samengestelde geheel dat als één eenheid wordt gewaardeerd voor de onroerendezaakbelasting en andere op de WOZ-waarde gebaseerde heffingen." ;
    skos:exactMatch gbobegrip:WOZObject,
        gbo:WOZObject ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/waarde-onroerende-zaken> ;
    skos:note "Draagt het Voorkomen-mixin (bitemporeel patroon; zie hoofdmodel, sectie Patronen).",
        "WOZ-object is een derde werkelijkheid naast de juridische (BRK-perceel of appartementsrecht) en de fysieke (BAG-pand of verblijfsobject) werkelijkheid. Een WOZ-object kan uit meerdere percelen en/of meerdere adresseerbare objecten zijn samengesteld, bijvoorbeeld kantoor met parkeerplaats, of juist uit een deel daarvan. Het wozObjectnummer is niet uniek tussen gemeenten; aanduiding (gestandaardiseerde gemeentecode plus objectnummer) of de combinatie met verantwoordelijkeGemeente levert de stabiele globale aanduiding." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "WOZ" ;
    mim:herkomstDefinitie "Wet WOZ art. 16 (object-afbakening), Uitvoeringsbesluit Wet WOZ en de LV-WOZ-catalogus." ;
    mim:populatie "Alle in Nederland door gemeenten of belastingsamenwerkingen in de Landelijke Voorziening WOZ geregistreerde WOZ-objecten, inclusief actuele en historische objecten." ;
    mim:uniekeAanduiding "aanduiding (gestandaardiseerde gemeentecode + wozObjectnummer)" .

