            owl:minCardinality 0 ;
            owl:onProperty gbo:overnameIndicatie ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:heeftWerkgever ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:codeRedenEinde ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:komtTotUitingIn ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:einddatum ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:codeRedenEinde ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty gbo:proeftijdEinddatum ] ;
    skos:definition "De juridische en feitelijke relatie tussen een natuurlijk persoon als werknemer en een werkgever op grond waarvan arbeid wordt verricht tegen beloning, gedurende een bepaalde of onbepaalde periode." ;
    skos:exactMatch gbobegrip:Arbeidsverhouding ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/werk-en-inkomen> ;
    skos:note "Arbeidsverhouding ligt boven Inkomstenverhouding in Belastingen: één arbeidsverhouding kan in de tijd meerdere inkomstenverhoudingen genereren (na contractvernieuwing of bij wisseling van loonperiode-type). De Arbeidsverhouding-attributen leggen de afspraak vast; de bijbehorende inkomstenverhoudingen leggen de uitvoering en de aangifte loonheffingen vast." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "SGR cluster Arbeidsverhouding" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek Boek 7 titel 10 (arbeidsovereenkomst); Wet SUWI voor het SUWI-aspect." ;
    mim:populatie "Alle juridische en feitelijke arbeidsrelaties tussen een natuurlijk persoon als werknemer en een onderneming als werkgever die zichtbaar zijn in het Suwi Gegevensregister." .

gbo:ArbeidsverledenFeit a owl:Class ;
    rdfs:label "ArbeidsverledenFeit" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty gbo:betreft ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty gbo:soortFeit ],
        [ a owl:Restriction ;
