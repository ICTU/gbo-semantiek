gbo:AardZakelijkRecht a owl:Class ;
    rdfs:label "AardZakelijkRecht" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/AardZakelijkRecht#Beklemrecht> <https://lod.gbo-semantiek.nl/AardZakelijkRecht#Eigendom> <https://lod.gbo-semantiek.nl/AardZakelijkRecht#ErfdienstbaarheidHeersend> <https://lod.gbo-semantiek.nl/AardZakelijkRecht#ErfdienstbaarheidLijdend> <https://lod.gbo-semantiek.nl/AardZakelijkRecht#Erfpacht> <https://lod.gbo-semantiek.nl/AardZakelijkRecht#GebruikEnBewoning> <https://lod.gbo-semantiek.nl/AardZakelijkRecht#Opstal> <https://lod.gbo-semantiek.nl/AardZakelijkRecht#Vruchtgebruik> ) ;
    skos:definition "Vorm van een zakelijk recht op een kadastraal onroerende zaak, bepalend voor de inhoud en de bevoegdheden van de rechthebbende." ;
    skos:exactMatch gbobegrip:AardZakelijkRecht ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Onderscheidt eigendomsrechten van beperkt zakelijke rechten. Erfdienstbaarheid komt voor in twee varianten: heersend (ten gunste van het eigen perceel) en lijdend (ten laste van het eigen perceel). Beklemrecht is een eeuwigdurend gebruiksrecht op grond met een vaste vergoeding, voornamelijk historisch in Groningen en Friesland." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK" ;
    mim:herkomstDefinitie "Burgerlijk Wetboek Boek 5 (zakelijke rechten, art. 1 e.v., art. 85 t/m 105); Burgerlijk Wetboek Boek 3 (registergoederen); BRK-Catalogus." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/AardZakelijkRecht#Beklemrecht>,
        <https://lod.gbo-semantiek.nl/AardZakelijkRecht#Eigendom>,
        <https://lod.gbo-semantiek.nl/AardZakelijkRecht#ErfdienstbaarheidHeersend>,
        <https://lod.gbo-semantiek.nl/AardZakelijkRecht#ErfdienstbaarheidLijdend>,
        <https://lod.gbo-semantiek.nl/AardZakelijkRecht#Erfpacht>,
        <https://lod.gbo-semantiek.nl/AardZakelijkRecht#GebruikEnBewoning>,
        <https://lod.gbo-semantiek.nl/AardZakelijkRecht#Opstal>,
        <https://lod.gbo-semantiek.nl/AardZakelijkRecht#Vruchtgebruik> .

gbo:Brandstof a owl:Class ;
    rdfs:label "Brandstof" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/Brandstof#Benzine> <https://lod.gbo-semantiek.nl/Brandstof#Diesel> <https://lod.gbo-semantiek.nl/Brandstof#LPG> <https://lod.gbo-semantiek.nl/Brandstof#CNG> <https://lod.gbo-semantiek.nl/Brandstof#Elektriciteit> <https://lod.gbo-semantiek.nl/Brandstof#Waterstof> <https://lod.gbo-semantiek.nl/Brandstof#Alcohol> <https://lod.gbo-semantiek.nl/Brandstof#Overige> ) ;
