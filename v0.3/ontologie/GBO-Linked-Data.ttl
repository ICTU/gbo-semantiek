<https://lod.gbo-semantiek.nl/onroerende-zaken/soortgrootte> a owl:Class ;
    rdfs:label "SoortGrootte" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/onroerende-zaken/soortgrootte#Vastgesteld> <https://lod.gbo-semantiek.nl/onroerende-zaken/soortgrootte#Vermoedelijk> <https://lod.gbo-semantiek.nl/onroerende-zaken/soortgrootte#VoorlopigeKadastraleGrens> ) ;
    skos:definition "Vaststellingsstatus van de oppervlakte van een kadastrale onroerende zaak." ;
    skos:exactMatch gbobegrip:SoortGrootte ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Geeft aan met welk niveau van zekerheid de oppervlakte is bepaald. Een vastgestelde grootte volgt uit een kadastrale meting en is definitief; een vermoedelijke grootte is een eerste indicatie zonder meting (typisch direct na splitsing); een voorlopige kadastrale grens betreft een nog niet definitief vastgestelde perceelgrens, waardoor ook de oppervlakte voorlopig is." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK" ;
    mim:herkomstDefinitie "BRK-Catalogus (Kadaster); Kadasterwet." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/onroerende-zaken/soortgrootte#Vastgesteld>,
        <https://lod.gbo-semantiek.nl/onroerende-zaken/soortgrootte#Vermoedelijk>,
        <https://lod.gbo-semantiek.nl/onroerende-zaken/soortgrootte#VoorlopigeKadastraleGrens> .

<https://lod.gbo-semantiek.nl/personen/geslacht> a owl:Class ;
    rdfs:label "Geslacht" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/personen/geslacht#Man> <https://lod.gbo-semantiek.nl/personen/geslacht#Vrouw> <https://lod.gbo-semantiek.nl/personen/geslacht#VastgesteldOnbekend> ) ;
    skos:definition "Geregistreerde geslachtsaanduiding van een natuurlijk persoon." ;
    skos:exactMatch gbobegrip:Geslacht ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "Driewaardige keuzelijst conform BRP-praktijk. GBO volgt expliciet BRP en niet ISO 5218. VastgesteldOnbekend is een BRP-specifieke waarde voor situaties waarin het geslacht expliciet als onbekend is vastgesteld, niet voor het ontbreken van registratie." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP cat 01 grp 04 Geslacht" ;
    mim:herkomstDefinitie "Logisch Ontwerp BRP v4.3.0 §4.6 element 04.10 (groep 04 Geslacht op de persoonslijst); juridische grondslag Wet BRP en Burgerlijk Wetboek Boek 1." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/personen/geslacht#Man>,
        <https://lod.gbo-semantiek.nl/personen/geslacht#VastgesteldOnbekend>,
        <https://lod.gbo-semantiek.nl/personen/geslacht#Vrouw> .

<https://lod.gbo-semantiek.nl/personen/verificatie> a owl:Class ;
    rdfs:label "Verificatie" ;
