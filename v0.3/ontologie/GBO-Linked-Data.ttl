    skos:altLabel "kadastraalOnroerendeZaakStatus" ;
    skos:definition "Levenscyclus-status van een kadastrale onroerende zaak in de Basisregistratie Kadaster." ;
    skos:exactMatch gbobegrip:KOZStatus ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Een kadastrale onroerende zaak (perceel of appartementsrecht) heeft op elk moment één status. Bij overgang naar Historisch is de zaak niet langer geldig, typisch het gevolg van splitsing, samenvoeging of grenscorrectie. De identificatie blijft beschikbaar via BRK-Levering." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK" ;
    mim:herkomstDefinitie "BRK-Catalogus (Kadaster); Kadasterwet." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/onroerende-zaken/kozstatus#Actueel>,
        <https://lod.gbo-semantiek.nl/onroerende-zaken/kozstatus#Historisch> .

<https://lod.gbo-semantiek.nl/onroerende-zaken/perceel> a owl:Class ;
    rdfs:label "Perceel" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/perceel/kadastralegemeente> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/perceel/perceelnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/perceel/oppervlakte> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/perceel/oppervlakte> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/perceel/sectie> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:CodelijstKadaster ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/perceel/kadastralegemeente> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/perceel/perceelnummer> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/onroerende-zaken/perceel/sectie> ],
        <https://lod.gbo-semantiek.nl/onroerende-zaken/kadastraleonroerendezaak> ;
    owl:hasKey ( <https://lod.gbo-semantiek.nl/onroerende-zaken/kadastraleonroerendezaak/kadastraleaanduiding> ) ;
    skos:altLabel "Kadastraal perceel" ;
    skos:definition "Een kadastraal afgebakend en als zelfstandige eenheid in de Basisregistratie Kadaster geregistreerd stuk grond, identificeerbaar via de kadastrale aanduiding (kadastrale gemeente, sectie, perceelnummer)." ;
    skos:exactMatch gbobegrip:Perceel,
        gbo:Perceel ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onroerende-zaken> ;
    skos:note "Alias Kadastraal perceel is de BRK-LO volledige naam.",
        "Perceel beschrijft de kadastraal-juridische werkelijkheid: een afgebakend stuk grond als registratie-eenheid, los van de fysieke bebouwing (Pand in BAG) en los van de fiscale waardering (WOZ-object). Een perceel kan onbebouwd zijn, één pand dragen, of door meerdere panden gedeeltelijk worden bedekt; een pand kan over meerdere percelen liggen." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRK (basisregistratie)" ;
    mim:herkomstDefinitie "Kadasterwet art. 1; BRK-Catalogus (objecttype KadastraalPerceel); IMKAD." ;
    mim:populatie "Alle kadastraal afgebakende stukken grond in Nederland zoals geregistreerd in de BRK door het Kadaster, inclusief actuele en historische percelen." ;
    mim:uniekeAanduiding "kadastraleAanduiding" .

