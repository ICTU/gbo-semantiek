    mim:herkomst "Wet IB 2001" ;
    mim:herkomstDefinitie "Wet IB 2001 hoofdstuk 3, hoofdstuk 4 en hoofdstuk 5." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/BoxCategorie#Box1WerkEnWoning>,
        <https://lod.gbo-semantiek.nl/BoxCategorie#Box2AanmerkelijkBelang>,
        <https://lod.gbo-semantiek.nl/BoxCategorie#Box3SparenEnBeleggen> .

gbo:CodelijstCBSSBI a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

gbo:Geometrie a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

gbo:Geslacht a owl:Class ;
    rdfs:label "Geslacht" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/Geslacht#Man> <https://lod.gbo-semantiek.nl/Geslacht#Vrouw> <https://lod.gbo-semantiek.nl/Geslacht#VastgesteldOnbekend> ) ;
    skos:definition "Geregistreerde geslachtsaanduiding van een natuurlijk persoon." ;
    skos:exactMatch gbobegrip:Geslacht ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/personen> ;
    skos:note "Driewaardige keuzelijst conform BRP-praktijk. GBO volgt expliciet BRP en niet ISO 5218. VastgesteldOnbekend is een BRP-specifieke waarde voor situaties waarin het geslacht expliciet als onbekend is vastgesteld, niet voor het ontbreken van registratie." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BRP cat 01 grp 04 Geslacht" ;
    mim:herkomstDefinitie "Logisch Ontwerp BRP v4.3.0 §4.6 element 04.10 (groep 04 Geslacht op de persoonslijst); juridische grondslag Wet BRP en Burgerlijk Wetboek Boek 1." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/Geslacht#Man>,
        <https://lod.gbo-semantiek.nl/Geslacht#VastgesteldOnbekend>,
        <https://lod.gbo-semantiek.nl/Geslacht#Vrouw> .

gbo:Grondslag a owl:Class ;
    rdfs:label "Grondslag" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/Grondslag#Leerplicht> <https://lod.gbo-semantiek.nl/Grondslag#Kwalificatieplicht> <https://lod.gbo-semantiek.nl/Grondslag#Achttienplus> ) ;
    skos:definition "Het regime op grond waarvan een VerzuimMelding moet worden gedaan." ;
    skos:exactMatch gbobegrip:GrondslagVerzuim ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "Een melding valt onder precies één regime. Het regime bepaalt naar welke partij DUO de melding routeert (gemeente voor leerplicht, RMC voor kwalificatieplicht en achttienplus)." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "Leerplichtwet 1969; WEB" ;
    mim:herkomstDefinitie "Leerplichtwet 1969 (leerplicht en kwalificatieplicht); WEB art. 8.1.7 (verzuim achttienplus)." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/Grondslag#Achttienplus>,
        <https://lod.gbo-semantiek.nl/Grondslag#Kwalificatieplicht>,
        <https://lod.gbo-semantiek.nl/Grondslag#Leerplicht> .

gbo:LeenstelselCohort a owl:Class ;
    rdfs:label "LeenstelselCohort" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/LeenstelselCohort#OudeRegeling> <https://lod.gbo-semantiek.nl/LeenstelselCohort#Leenstelsel> <https://lod.gbo-semantiek.nl/LeenstelselCohort#Hervormd> ) ;
    skos:definition "Het studiefinancieringsregime waaronder een studielening is opgebouwd." ;
    skos:exactMatch gbobegrip:LeenstelselCohort ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/onderwijs> ;
    skos:note "Het cohort bepaalt aflostermijn en regelingen rond prestatiebeurs-omzetting. Een student die zowel in een oud als in een nieuw regime heeft geleend kan over meer dan één cohort beschikken in zijn lening-administratie; in dit deelmodel geldt per studielening het hoofdcohort, met de overige cohorten als toelichting bij DUO zelf." ;
    mim:datumOpname "2026-05-19" ;
    mim:herkomst "WSF 2000" ;
    mim:herkomstDefinitie "WSF 2000 met de aanpassingen van het leenstelsel (Wet studievoorschot hoger onderwijs, 2015) en van de hervorming basisbeurs (Wet hervorming studiefinanciering, 2023)." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/LeenstelselCohort#Hervormd>,
        <https://lod.gbo-semantiek.nl/LeenstelselCohort#Leenstelsel>,
        <https://lod.gbo-semantiek.nl/LeenstelselCohort#OudeRegeling> .

