gbo:Alfanumeriek a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( gbo:Tekst [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[A-Za-z0-9]*$" ] ) ] ) ] .

gbo:CodelijstLT33 a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[0-9]{4}$" ] ) ] ) ] .

gbo:NEN3610ID a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

gbo:Postcode a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( gbo:Tekst [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[1-9][0-9]{3} ?[A-Z]{2}$" ] ) ] ) ] .

gbo:UUID a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ] ) ] ) ] .

<https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres> a owl:Class ;
    rdfs:label "Binnenlandsadres" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/huisnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/postcode> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/woonplaatsnaam> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/straatnaam> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Postcode ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/postcode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Numeriek ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/huisnummer> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/straatnaam> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/huisletter> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/huisnummertoevoeging> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/huisnummertoevoeging> ],
        [ a owl:Restriction ;
            owl:cardinality 1 ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/wordtgevormddoor> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/huisletter> ],
        [ a owl:Restriction ;
            owl:allValuesFrom gbo:Tekst ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/woonplaatsnaam> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/nummeraanduiding> ;
            owl:onProperty <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/binnenlandsadres/wordtgevormddoor> ],
        <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/adres> ;
    skos:definition "Een Nederlands adres dat via een BAG-Nummeraanduiding en de bijbehorende openbare ruimte en woonplaats wordt opgebouwd." ;
    skos:exactMatch gbobegrip:Binnenlandsadres,
        gbo:Binnenlandsadres ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "BAG-gekoppeld adres met een eigen instantie per Nummeraanduiding (geen afgeleide view), geconstrueerd uit de Nummeraanduiding en de bovenliggende keten op moment van vorming." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BAG (afgeleid uit de Nummeraanduiding-keten)" ;
    mim:herkomstDefinitie "Wet BAG art. 1 (Nummeraanduiding, OpenbareRuimte, Woonplaats); Catalogus BAG 2018; RSGB-Kern Binnenlandsadres." ;
    mim:populatie "Alle Nederlandse adressen waarvoor een Nummeraanduiding is uitgegeven en die als woon-, bezoek- of correspondentieadres voor een afnemer relevant zijn." ;
    mim:uniekeAanduiding "adresId (geërfd)" .

<https://lod.gbo-semantiek.nl/adressen-en-gebouwen/statusnummeraanduiding> a owl:Class ;
    rdfs:label "StatusNummeraanduiding" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/statusnummeraanduiding#NaamgevingUitgegeven> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/statusnummeraanduiding#NaamgevingIngetrokken> ) ;
    skos:definition "Aanduiding van de levenscyclus-status van een nummeraanduiding." ;
    skos:exactMatch gbobegrip:StatusNummeraanduiding ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Een nummeraanduiding kent twee statussen: uitgegeven of ingetrokken. Materiële historie blijft beschikbaar via het Voorkomen-mixin." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BAG" ;
    mim:herkomstDefinitie "Wet BAG; Catalogus BAG 2018 §2.3; IMBAG-attribuutdomein." ;
    linkml:permissible_values <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/statusnummeraanduiding#NaamgevingIngetrokken>,
        <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/statusnummeraanduiding#NaamgevingUitgegeven> .

<https://lod.gbo-semantiek.nl/adressen-en-gebouwen/statusopenbareruimte> a owl:Class ;
    rdfs:label "StatusOpenbareRuimte" ;
    owl:unionOf ( <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/statusopenbareruimte#NaamgevingUitgegeven> <https://lod.gbo-semantiek.nl/adressen-en-gebouwen/statusopenbareruimte#NaamgevingIngetrokken> ) ;
    skos:definition "Aanduiding van de levenscyclus-status van een openbare ruimte." ;
    skos:exactMatch gbobegrip:StatusOpenbareRuimte ;
    skos:inScheme <https://lod.gbo-semantiek.nl/informatiemodel/adressen-en-gebouwen> ;
    skos:note "Een openbare ruimte kent twee statussen: uitgegeven of ingetrokken. De waarden delen het naamgeving-patroon met Nummeraanduiding maar vormen een eigen attribuutdomein." ;
    mim:datumOpname "2026-04-28" ;
    mim:herkomst "BAG" ;
