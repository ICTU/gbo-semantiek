            sh:minCount 0 ;
            sh:name "adresBuitenland" ;
            sh:path <https://lod.gbo-semantiek.nl/kern%20rgbz/object/adresbuitenland> ],
        [ sh:datatype xsd:string ;
            sh:description "<font color=\"#610e6a\">De benaming van het OBJECT indien dit een SUBJECT of specialisatie daarvan is.</font>" ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:name "naam" ;
            sh:path <https://lod.gbo-semantiek.nl/kern%20rgbz/object/naam> ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicatie van de risico's van (de uitvoering van activiteiten in) het handhavingsobject op gevolgen voor het handhavingsobject zelf, de daarin aanwezige personen, de omgeving van het handhavingsobject en/of de samenleving." ;
