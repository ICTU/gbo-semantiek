<https://lod.gbo-semantiek.nl/kern%20rsgb/buurt> a owl:Class ;
    rdfs:label "Buurt" ;
    dcterms:identifier "EAID_67CC2144_6B88_433c_853D_07379C66D6CF" ;
    rdfs:comment "Een aaneengesloten gedeelte van een wijk, waarvan de grenzen zo veel mogelijk gebaseerd zijn op topografische elementen." .

<https://lod.gbo-semantiek.nl/bag/gemeente> a owl:Class ;
