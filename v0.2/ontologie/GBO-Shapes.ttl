            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path gbo:statusWOZWaarde ],
        [ sh:description "Geeft aan of een bezwaar of beroep loopt tegen de beschikking." ;
            sh:in ( "Ja" "Nee" "Onbekend" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path gbo:indicatieBezwaarBeroep ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop de waarde vervalt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gbo:einddatum ],
        [ sh:description "Chronologische statussen die de beschikking heeft doorlopen." ;
            sh:in ( "Beroep" "Bezwaar" "ConceptBeschikking" "DefinitieveBeschikking" "HogerBeroep" "Onherroepelijk" ) ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path gbo:beschikkingsStatussen ],
        [ sh:class gbo:Bedrag ;
            sh:description "De vastgestelde waarde van het WOZ-object op de peildatum." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path gbo:vastgesteldeWaarde ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum vanaf wanneer de waarde geldigheid heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gbo:ingangsdatum ],
        [ sh:datatype <xsd:string> ;
            sh:description "Identificatie van de WOZ-beschikking." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path gbo:beschikkingsnummer ],
        [ sh:datatype <xsd:date> ;
