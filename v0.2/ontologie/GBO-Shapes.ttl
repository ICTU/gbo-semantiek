            sh:order 4 ;
            sh:path gbo:datumGebeurtenis ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop de bijzonderheid is opgetreden." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gbo:datumGebeurtenis ],
        [ sh:class gbo:KredietOvereenkomst ;
