            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gbo:betreft ],
        [ sh:description "Een van 1 t/m 5." ;
            sh:in ( "1" "2" "3" "4" "5" ) ;
