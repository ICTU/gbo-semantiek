gbo:LijfrenteAftrek a sh:NodeShape ;
    rdfs:comment "De op grond van Wet IB 2001 art. 3.124 aftrekbare lijfrente-premies en stortingen op bancaire lijfrente-rekeningen die de belastingplichtige in een belastingjaar heeft betaald binnen de jaarruimte- of reserveringsruimte." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:integer> ;
            sh:description "Het belastingjaar van toepassing." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path gbo:belastingjaar ],
        [ sh:class gbo:Bedrag ;
            sh:description "Maximaal aftrekbaar in dit jaar." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path gbo:jaarruimte ],
        [ sh:class gbo:Bedrag ;
            sh:description "Bedrag van de aftrek in het belastingjaar." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path gbo:bedragJaar ],
        [ sh:class gbo:Bedrag ;
            sh:description "Maximaal benutbaar uit voorgaande zeven jaar." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path gbo:reserveringsruimte ],
        [ sh:datatype <xsd:date> ;
            sh:description "Voor Box-3-bestanddelen 1 januari." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gbo:peildatum ],
        [ sh:description "Categorie-aanduiding." ;
