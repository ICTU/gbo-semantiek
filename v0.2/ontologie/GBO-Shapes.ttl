gbo:Locatie a sh:NodeShape ;
    rdfs:comment "Een adresseerbare plek zonder eigen Nummeraanduiding, beschreven met een vrije omschrijving en optioneel een landaanduiding." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "Vrije tekstuele omschrijving van de locatie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gbo:omschrijving ],
        [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen sleutel voor één adres-instantie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gbo:adresId ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen sleutel voor één adres-instantie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gbo:adresId ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Landaanduiding volgens ISO 3166." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gbo:land ;
            sh:pattern "^[A-Z]{2}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Gedenormaliseerde, leesbare projectie van het adres." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gbo:volledigAdres ],
        [ sh:datatype <xsd:string> ;
            sh:description "Vrije tekstuele omschrijving van de locatie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gbo:omschrijving ],
        [ sh:datatype <xsd:string> ;
            sh:description "Gedenormaliseerde, leesbare projectie van het adres." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gbo:volledigAdres ],
        [ sh:datatype <xsd:string> ;
            sh:description "Landaanduiding volgens ISO 3166." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gbo:land ;
            sh:pattern "^[A-Z]{2}$" ] ;
    sh:targetClass gbo:Locatie .

gbo:LoonAangifte a sh:NodeShape ;
    rdfs:comment "De periodieke aangifte loonheffingen die een inhoudingsplichtige op grond van de Wet LB 1964 indient bij de Belastingdienst over een aangifteperiode, met alle inkomsten-verhoudingen en de daaruit voortvloeiende loonbestanddelen en in te houden bedragen." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Reguliere aangifte of correctie op een eerdere." ;
            sh:in ( "Ja" "Nee" "Onbekend" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path gbo:isCorrectieAangifte ],
