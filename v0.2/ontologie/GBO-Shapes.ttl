gbo:KredietFeit a sh:NodeShape ;
    rdfs:comment "Een tijdens de looptijd van een kredietovereenkomst opgetreden gebeurtenis die op grond van het Algemeen Reglement CKI aan het Centraal Krediet Informatiesysteem wordt gemeld, zoals het ontstaan van een achterstand, het herstel van een achterstand of het optreden van een bijzonderheid." ;
    sh:closed false ;
    sh:ignoredProperties ( gbo:betreft gbo:omvangAchterstand gbo:begeleidDoor gbo:volgtOp gbo:begeleidt gbo:bijzonderheidsCode gbo:opgelostDoor rdf:type ) ;
