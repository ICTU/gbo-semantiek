gbo:Nationaliteit a sh:NodeShape ;
    rdfs:comment "Een nationaliteit die aan een ingeschreven persoon is toegekend, inclusief de gebeurtenis van verkrijging en eventueel verlies." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "De datum waarop de nationaliteit is verkregen." ;
            sh:maxCount 1 ;
