gbo:Partij a sh:NodeShape ;
    rdfs:comment "Abstract supertype van natuurlijke en niet-natuurlijke personen: iedere actor die in een overheidsregistratie als rechts- of handelingssubject voorkomt." ;
    sh:closed false ;
    sh:ignoredProperties ( gbo:bsn gbo:brincode gbo:heeftBestuur gbo:datumInschrijvingGemeente gbo:voornamen gbo:deelnemerCodeRNI gbo:opschortingBijhouding gbo:anbiStatus gbo:voorvoegsel gbo:heeftVerblijfstitel gbo:naam gbo:landVanVerblijf gbo:typeMaatschappelijk gbo:rsin gbo:verificatie gbo:gezag gbo:herkomst gbo:tin gbo:rechtsvormBuitenland gbo:typeOverheid gbo:rechtsvorm gbo:onderwijssector gbo:biedtAan gbo:landVanOprichting gbo:versie gbo:heeftImmigratie gbo:aansprakelijkheid gbo:adellijkeTitelPredicaat rdf:type gbo:geslacht gbo:europeesKiesrecht gbo:hoofdSbiCode gbo:geboorteplaats gbo:geboortedatum gbo:plaatsOverlijden gbo:sector gbo:eindGeldigheid gbo:uitsluitingKiesrecht gbo:geboorteland gbo:datumEersteInschrijving gbo:omschrijving gbo:instellingscodeRIO gbo:heeftOuder gbo:voertUit gbo:datumInschrijvingRNI gbo:gemeenteVanInschrijving gbo:indicatieGeheim gbo:typeBuitenlandseEntiteit gbo:beginGeldigheid gbo:tijdstipRegistratie gbo:eindRegistratie gbo:heeftBriefadres gbo:geslachtsnaam gbo:aNummer gbo:woontOp gbo:heeftNationaliteit gbo:zetel gbo:landOverlijden gbo:inOnderzoek gbo:bevoegdGezagCode gbo:datumOverlijden ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen identifier voor een partij; gebruikt waar geen externe authentieke identifier bestaat of meerdere bronnen samenkomen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gbo:partijnummer ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:class gbo:Inschrijving ;
            sh:description "De inschrijving(en) van deze partij in het Handelsregister." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gbo:ingeschrevenAls ],
        [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen identifier voor een partij; gebruikt waar geen externe authentieke identifier bestaat of meerdere bronnen samenkomen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gbo:partijnummer ;
