            sh:description "Formele tijdlijn: start van de registratie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gbo:tijdstipRegistratie ],
        [ sh:datatype <xsd:dateTime> ;
            sh:description "Formele tijdlijn: einde van de registratie; open betekent actueel." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path gbo:eindRegistratie ],
        [ sh:datatype <xsd:dateTime> ;
            sh:description "Formele tijdlijn: start van de registratie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path gbo:tijdstipRegistratie ],
        [ sh:datatype <xsd:string> ;
            sh:description "Objectidentificatie volgens NEN 3610." ;
