            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gbo:einddatum ;
            sh:pattern "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$" ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van de oprichtingsakte of meest recente wijzigingsakte." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path gbo:documentdatum ],
        [ sh:datatype <xsd:string> ;
            sh:description "Startdatum van de inschrijving." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path gbo:startdatum ;
            sh:pattern "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$" ],
        [ sh:class gbo:Activiteit ;
            sh:description "SBI-gecodeerde activiteiten op onderneming-brede classificatie." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path gbo:heeftActiviteit ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Primaire identifier van de inschrijving." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gbo:kvkNummer ],
        [ sh:datatype <xsd:string> ;
            sh:description "Akte-nummer van de oprichtings- of wijzigingsakte." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path gbo:documentnummer ],
        [ sh:class gbo:Vestiging ;
            sh:description "Eén Inschrijving heeft één of meer Vestigingen, waaronder precies één hoofdvestiging op enig moment." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path gbo:heeftVestiging ],
        [ sh:class gbo:Naamgeving ;
            sh:description "Naamlagen (statutair, handelsnaam, alternatief) per Inschrijving." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path gbo:heeftNaamgeving ],
        [ sh:datatype <xsd:string> ;
            sh:description "Einddatum van de inschrijving." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path gbo:einddatum ;
            sh:pattern "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Akte-nummer van de oprichtings- of wijzigingsakte." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gbo:documentnummer ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop de inschrijving voor het eerst bij KVK is geregistreerd." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gbo:datumEersteInschrijving ],
        [ sh:class gbo:Rechtstoestand ;
            sh:description "Precies één actuele rechtstoestand per Inschrijving." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path gbo:heeftRechtstoestand ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop de inschrijving voor het eerst bij KVK is geregistreerd." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path gbo:datumEersteInschrijving ],
        [ sh:class gbo:Naamgeving ;
            sh:description "Naamlagen (statutair, handelsnaam, alternatief) per Inschrijving." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path gbo:heeftNaamgeving ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Primaire identifier van de inschrijving." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path gbo:kvkNummer ],
        [ sh:datatype <xsd:date> ;
