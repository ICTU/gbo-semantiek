gbo:Binnenlandsadres a sh:NodeShape ;
    rdfs:comment "Een Nederlands adres dat via een BAG-Nummeraanduiding en de bijbehorende openbare ruimte en woonplaats wordt opgebouwd." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "Gedenormaliseerde, leesbare projectie van het adres." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gbo:volledigAdres ],
        [ sh:datatype <xsd:string> ;
            sh:description "Volledige naam van de openbare ruimte." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path gbo:straatnaam ;
            sh:pattern "^[A-Za-z0-9]{0,80}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "De huisnummertoevoeging (bv. 2hg, bis)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path gbo:huisnummertoevoeging ],
        [ sh:datatype <xsd:string> ;
            sh:description "Volledige naam van de openbare ruimte." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gbo:straatnaam ;
            sh:pattern "^[A-Za-z0-9]{0,80}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Het huisnummer-deel van de Nummeraanduiding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gbo:huisnummer ;
            sh:pattern "^[0-9]{5}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "De postcode behorend bij het huisnummer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path gbo:postcode ;
            sh:pattern "^[1-9][0-9]{3} ?[A-Z]{2}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "De huisnummertoevoeging (bv. 2hg, bis)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gbo:huisnummertoevoeging ],
        [ sh:datatype <xsd:string> ;
            sh:description "Naam van de bovenliggende woonplaats." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gbo:woonplaatsnaam ;
            sh:pattern "^[A-Za-z0-9]{0,80}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Het huisnummer-deel van de Nummeraanduiding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path gbo:huisnummer ;
            sh:pattern "^[0-9]{5}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Naam van de bovenliggende woonplaats." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path gbo:woonplaatsnaam ;
            sh:pattern "^[A-Za-z0-9]{0,80}$" ],
        [ sh:class gbo:Nummeraanduiding ;
            sh:description "Spiegel van Nummeraanduiding vormt Binnenlandsadres." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path gbo:wordtGevormdDoor ],
        [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen sleutel voor één adres-instantie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gbo:adresId ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "De huisletter bij het huisnummer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gbo:huisletter ],
        [ sh:class gbo:Nummeraanduiding ;
