gbo:Activiteit a sh:NodeShape ;
    rdfs:comment "Een geregistreerde bedrijfsactiviteit die in het Handelsregister wordt vastgelegd, gecodeerd volgens de CBS Standaard Bedrijfsindeling (SBI), met onderscheid tussen hoofd- en nevenactiviteit per inschrijving of per vestiging." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Booleaanse projectie van soortActiviteit = Hoofd." ;
            sh:in ( "Ja" "Nee" "Onbekend" ) ;
