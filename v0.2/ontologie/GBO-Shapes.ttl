            sh:description "Indien de achterstand is ingehaald." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path gbo:opgelostDoor ],
        [ sh:class gbo:Bedrag ;
            sh:description "Het bedrag van de achterstand op moment van melding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
