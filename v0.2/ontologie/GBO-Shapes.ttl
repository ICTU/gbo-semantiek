        [ sh:description "Onderscheid tussen hoofd- en nevenactiviteit." ;
            sh:in ( "Hoofd" "Neven" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path gbo:soortActiviteit ],
        [ sh:datatype <xsd:string> ;
