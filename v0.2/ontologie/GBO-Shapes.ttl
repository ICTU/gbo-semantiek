gbo:OnderwijsInstelling a sh:NodeShape ;
    rdfs:comment "Een door OCW erkende rechtspersoon of bestuurlijke entiteit die onderwijs aanbiedt in een of meer Nederlandse onderwijssectoren." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gbo:MaatschappelijkeActiviteit ;
            sh:description "Eén NNP voert één of meer ondernemingen." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 28 ;
