            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path gbo:voertUit ],
        [ sh:datatype <xsd:string> ;
            sh:description "Werknaam." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path gbo:naam ],
        [ sh:description "Functionele sector-classificatie." ;
            sh:in ( "Commercieel" "Maatschappelijk" "Overheid" "Overig" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 16 ;
            sh:path gbo:sector ],
        [ sh:class gbo:Inschrijving ;
            sh:description "De inschrijving(en) van deze partij in het Handelsregister." ;
