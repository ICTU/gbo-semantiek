            sh:path gbo:categorie ],
        [ sh:class gbo:Bedrag ;
            sh:description "Betaalde lijfrente-premie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path gbo:bedragJaar ],
        [ sh:class gbo:Bedrag ;
            sh:description "Betaalde lijfrente-premie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path gbo:bedragJaar ],
        [ sh:class gbo:Bedrag ;
            sh:description "Maximaal aftrekbaar in dit jaar." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gbo:jaarruimte ],
        [ sh:class gbo:Bedrag ;
            sh:description "Maximaal benutbaar uit voorgaande zeven jaar." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path gbo:reserveringsruimte ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Het belastingjaar van toepassing." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gbo:belastingjaar ],
        [ sh:datatype <xsd:date> ;
            sh:description "Voor Box-3-bestanddelen 1 januari." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path gbo:peildatum ],
        [ sh:description "Categorie-aanduiding." ;
