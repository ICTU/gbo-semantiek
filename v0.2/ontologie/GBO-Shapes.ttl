            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path gbo:waardePeildatum ],
        [ sh:datatype <xsd:string> ;
            sh:description "Valuta-code." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gbo:valuta ],
        [ sh:datatype <xsd:string> ;
            sh:description "Internationaal banknummer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gbo:iban ],
        [ sh:datatype <xsd:date> ;
