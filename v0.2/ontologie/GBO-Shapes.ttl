            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gbo:beginGeldigheid ],
        [ sh:description "Kwaliteit van de geometrische afbakening." ;
