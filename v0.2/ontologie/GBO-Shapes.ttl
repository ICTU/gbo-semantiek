        [ sh:class gbo:NatuurlijkPersoon ;
            sh:description "De natuurlijk persoon door of namens wie de aangifte is ingediend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path gbo:ingediendDoor ],
        [ sh:description "Toepasselijke boxen." ;
            sh:in ( "Box1WerkEnWoning" "Box2AanmerkelijkBelang" "Box3SparenEnBeleggen" ) ;
            sh:order 12 ;
            sh:path gbo:boxCategorie ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van feitelijke indiening." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gbo:indieningsdatum ],
        [ sh:class gbo:Bedrag ;
            sh:description "Inkomen uit werk en woning." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path gbo:box1Inkomen ],
        [ sh:datatype <xsd:string> ;
            sh:description "IH, Schenk, Erf." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
