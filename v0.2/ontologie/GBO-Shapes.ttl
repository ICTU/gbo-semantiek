            sh:order 8 ;
            sh:path gbo:datumGebeurtenis ],
        [ sh:class gbo:AchterstandRegistratie ;
            sh:description "Optioneel; sommige bijzonderheden staan los van een lopende achterstand." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path gbo:begeleidt ],
        [ sh:class gbo:KredietOvereenkomst ;
            sh:description "De overeenkomst waarop de bijzonderheid betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path gbo:betreft ],
        [ sh:description "Een van 1 t/m 5." ;
