            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gbo:beschikkingsnummer ],
        [ sh:description "Toekenning, herziening of beeindiging." ;
            sh:in ( "Toekenning" "Herziening" "Beeindiging" "Afwijzing" "Bezwaar" "Sanctie" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path gbo:beslissingSoort ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van de beschikking." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gbo:beschikkingsdatum ],
        [ sh:class gbo:MaatschappelijkeActiviteit ;
            sh:description "De uitvoerings-instelling die het besluit heeft genomen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path gbo:genomenDoor ],
        [ sh:description "Op welke uitkering de beschikking ziet." ;
            sh:in ( "WW" "ZW" "WIA" "IVA" "WGA" "Wajong" "AOW" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path gbo:betrefftSoortUitkering ],
        [ sh:datatype <xsd:string> ;
            sh:description "Identifier van de beschikking." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gbo:beschikkingsnummer ] ;
    sh:targetClass gbo:Beslissing .

gbo:BijzonderheidsCodering a sh:NodeShape ;
    rdfs:comment "Een melding aan het Centraal Krediet Informatiesysteem dat een specifieke bijzonderheid is opgetreden bij de afhandeling van een kredietovereenkomst, gecodeerd volgens de waardenset van art. 13 Algemeen Reglement CKI." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop de bijzonderheid is opgetreden." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
