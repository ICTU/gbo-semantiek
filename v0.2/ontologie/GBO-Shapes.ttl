gbo:Beslissing a sh:NodeShape ;
    rdfs:comment "Een door een uitvoerings-instelling in het SUWI-stelsel genomen besluit over het recht op, de hoogte van of de beeindiging van een uitkering of een andere voorziening voor een natuurlijk persoon." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class gbo:NatuurlijkPersoon ;
            sh:description "De natuurlijk persoon op wie het besluit betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path gbo:betreft ],
        [ sh:description "Op welke uitkering de beschikking ziet." ;
            sh:in ( "WW" "ZW" "WIA" "IVA" "WGA" "Wajong" "AOW" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path gbo:betrefftSoortUitkering ],
        [ sh:description "Toekenning, herziening of beeindiging." ;
            sh:in ( "Toekenning" "Herziening" "Beeindiging" "Afwijzing" "Bezwaar" "Sanctie" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path gbo:beslissingSoort ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van de beschikking." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
