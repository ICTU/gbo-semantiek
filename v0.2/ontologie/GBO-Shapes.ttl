@prefix gbo: <https://lod.gbo-semantiek.nl/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

gbo:AangifteErf a sh:NodeShape ;
    rdfs:comment "De aangifte erfbelasting waarin de nalatenschap van een overledene en de verdeling daarvan over de erfgenamen wordt opgegeven." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:integer> ;
            sh:description "Aantal erfgenamen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path gbo:aantalErfgenamen ],
        [ sh:datatype <xsd:string> ;
            sh:description "Identificatie van de aangifte." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path gbo:aangifteIdentificatie ],
        [ sh:datatype <xsd:date> ;
            sh:description "Einde van de aangifteperiode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gbo:einddatumAangifte ],
        [ sh:class gbo:Bedrag ;
            sh:description "Fiscale waarde van de nalatenschap." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path gbo:omvangNalatenschap ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Het jaar waarop de aangifte betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path gbo:belastingjaar ],
        [ sh:class gbo:NatuurlijkPersoon ;
            sh:description "De natuurlijk persoon door of namens wie de aangifte is ingediend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path gbo:ingediendDoor ],
        [ sh:datatype <xsd:string> ;
            sh:description "Identificatie van de aangifte." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gbo:aangifteIdentificatie ],
        [ sh:datatype <xsd:date> ;
            sh:description "Einde van de aangifteperiode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path gbo:einddatumAangifte ],
        [ sh:datatype <xsd:date> ;
            sh:description "Begin van de aangifteperiode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path gbo:ingangsdatumAangifte ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van feitelijke indiening." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path gbo:indieningsdatum ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Aantal erfgenamen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path gbo:aantalErfgenamen ],
        [ sh:datatype <xsd:string> ;
            sh:description "Bijvoorbeeld Ingediend, Aangeslagen, Bezwaar lopend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gbo:status ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van overlijden." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path gbo:overlijdensdatum ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van overlijden." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gbo:overlijdensdatum ],
        [ sh:class gbo:Bedrag ;
            sh:description "Fiscale waarde van de nalatenschap." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path gbo:omvangNalatenschap ],
        [ sh:datatype <xsd:string> ;
            sh:description "IH, Schenk, Erf." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path gbo:belastingsoort ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Het jaar waarop de aangifte betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gbo:belastingjaar ],
        [ sh:datatype <xsd:date> ;
            sh:description "Begin van de aangifteperiode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gbo:ingangsdatumAangifte ],
        [ sh:datatype <xsd:string> ;
            sh:description "Bijvoorbeeld Ingediend, Aangeslagen, Bezwaar lopend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path gbo:status ],
        [ sh:datatype <xsd:string> ;
            sh:description "IH, Schenk, Erf." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gbo:belastingsoort ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum van feitelijke indiening." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path gbo:indieningsdatum ],
        [ sh:class gbo:NatuurlijkPersoon ;
            sh:description "De natuurlijk persoon door of namens wie de aangifte is ingediend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path gbo:ingediendDoor ] ;
    sh:targetClass gbo:AangifteErf .

gbo:AangifteIH a sh:NodeShape ;
    rdfs:comment "De jaaraangifte inkomstenbelasting van een natuurlijk persoon waarin het verzamelinkomen over een belastingjaar wordt opgegeven, opgebouwd uit Box 1 (werk en woning), Box 2 (aanmerkelijk belang) en Box 3 (sparen en beleggen)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:date> ;
            sh:description "Datum van feitelijke indiening." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path gbo:indieningsdatum ],
        [ sh:datatype <xsd:string> ;
            sh:description "Bijvoorbeeld Ingediend, Aangeslagen, Bezwaar lopend." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path gbo:status ],
        [ sh:datatype <xsd:string> ;
            sh:description "Identificatie van de aangifte." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path gbo:aangifteIdentificatie ],
        [ sh:class gbo:Bedrag ;
            sh:description "Inkomen uit sparen en beleggen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path gbo:box3Inkomen ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Het jaar waarop de aangifte betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gbo:belastingjaar ],
        [ sh:class gbo:Bedrag ;
            sh:description "Inkomen uit aanmerkelijk belang." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path gbo:box2Inkomen ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Het jaar waarop de aangifte betrekking heeft." ;
