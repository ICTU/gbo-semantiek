            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gbo:omschrijving ],
        [ sh:datatype <xsd:string> ;
            sh:description "SBI-codering volgens CBS Standaard Bedrijfsindeling." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
