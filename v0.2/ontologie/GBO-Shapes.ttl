            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path gbo:begeleidDoor ],
        [ sh:class gbo:KredietOvereenkomst ;
            sh:description "De overeenkomst waarop de achterstand betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path gbo:betreft ],
        [ sh:class gbo:KredietOvereenkomst ;
            sh:description "De overeenkomst waarop de achterstand betrekking heeft." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path gbo:betreft ],
        [ sh:datatype <xsd:date> ;
            sh:description "De startdatum van de achterstand." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gbo:datumGebeurtenis ],
        [ sh:datatype <xsd:date> ;
