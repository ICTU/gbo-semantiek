        [ sh:class gbo:Inschrijving ;
            sh:description "De inschrijving(en) van deze partij in het Handelsregister." ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path gbo:ingeschrevenAls ] ;
    sh:targetClass gbo:Partij .

