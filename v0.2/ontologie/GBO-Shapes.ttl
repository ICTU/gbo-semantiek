gbo:Bedrijf a sh:NodeShape ;
    rdfs:comment "Privaatrechtelijke commerciële entiteit die als ondernemer in het Handelsregister staat ingeschreven. Omvat rechtspersonen (BV, NV, coöperatie, OWM) en niet-rechtspersonen (eenmanszaak, VOF, CV, maatschap)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "Werknaam." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gbo:naam ],
        [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen identifier voor een partij; gebruikt waar geen externe authentieke identifier bestaat of meerdere bronnen samenkomen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path gbo:partijnummer ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Rechtspersonen- en Samenwerkingsverbanden Identificatie Nummer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path gbo:rsin ;
            sh:pattern "^[0-9]{9}$" ],
        [ sh:datatype <xsd:string> ;
            sh:description "Statutaire vestigingsplaats." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gbo:zetel ],
        [ sh:datatype <xsd:string> ;
            sh:description "Afgeleide SBI-hoofdactiviteit." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path gbo:hoofdSbiCode ],
        [ sh:datatype <xsd:string> ;
