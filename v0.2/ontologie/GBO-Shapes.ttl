            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path gbo:kredietbedragActueel ],
        [ sh:class gbo:NatuurlijkPersoon ;
            sh:description "De kredietnemer; zie deelmodel Personen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path gbo:aangegaanDoor ],
