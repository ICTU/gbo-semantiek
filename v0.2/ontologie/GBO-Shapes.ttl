            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gbo:documentdatum ] ;
    sh:targetClass gbo:Inschrijving .

gbo:MaatschappelijkeActiviteit a sh:NodeShape ;
    rdfs:comment "Een onderneming binnen een niet-natuurlijke persoon, het samenhangend geheel van bedrijfsactiviteiten dat onder één economische identiteit wordt gevoerd en dat tot precies één inschrijving in het Handelsregister leidt." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "SBI van de hoofdactiviteit van deze onderneming." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path gbo:hoofdSbiCode ],
        [ sh:datatype <xsd:string> ;
            sh:description "Korte beschrijving van de ondernemings-activiteit." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path gbo:omschrijving ],
        [ sh:datatype <xsd:string> ;
            sh:description "GBO-eigen sleutel voor de ondernemings-eenheid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gbo:identificatie ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ],
        [ sh:class gbo:Inschrijving ;
            sh:description "Elke MA leidt tot precies één HR-Inschrijving." ;
            sh:maxCount 1 ;
