            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path gbo:rechtsvorm ],
        [ sh:description "Functionele sector-classificatie." ;
            sh:in ( "Commercieel" "Maatschappelijk" "Overheid" "Overig" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path gbo:sector ],
        [ sh:description "Aansprakelijkheidskarakter van de rechtsvorm." ;
            sh:in ( "Beperkt" "Onbeperkt" "Hoofdelijk" "Publiek" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path gbo:aansprakelijkheid ],
        [ sh:datatype <xsd:string> ;
            sh:description "Rechtspersonen- en Samenwerkingsverbanden Identificatie Nummer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path gbo:rsin ;
            sh:pattern "^[0-9]{9}$" ],
        [ sh:description "Binnen- of buitenlandse herkomst." ;
            sh:in ( "Binnenland" "Buitenland" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 17 ;
            sh:path gbo:herkomst ],
        [ sh:description "Binnen- of buitenlandse herkomst." ;
            sh:in ( "Binnenland" "Buitenland" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path gbo:herkomst ],
        [ sh:datatype <xsd:string> ;
            sh:description "Statutaire vestigingsplaats." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path gbo:zetel ],
        [ sh:datatype <xsd:string> ;
            sh:description "Afgeleide SBI-hoofdactiviteit." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gbo:hoofdSbiCode ],
        [ sh:class gbo:MaatschappelijkeActiviteit ;
