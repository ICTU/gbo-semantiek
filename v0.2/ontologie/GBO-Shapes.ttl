gbo:Aantekening a sh:NodeShape ;
    rdfs:comment "Een privaatrechtelijke vermelding bij een kadastraal onroerende zaak die een kwalitatieve verplichting, bewindstelling of soortgelijke notarieel ontstane last vastlegt en die via de Basisregistratie Kadaster kenbaar wordt gemaakt." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:dateTime> ;
            sh:description "Formele tijdlijn: einde van de registratie; open betekent actueel." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path gbo:eindRegistratie ],
        [ sh:datatype <xsd:dateTime> ;
            sh:description "Formele tijdlijn: start van de registratie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path gbo:tijdstipRegistratie ],
        [ sh:class gbo:KadastraleOnroerendeZaak ;
            sh:description "Kadastrale onroerende zaak waarop de aantekening rust." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path gbo:opKadastraleOnroerendeZaak ],
        [ sh:datatype <xsd:date> ;
            sh:description "Datum waarop de aantekening van kracht is geworden." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path gbo:datumIngang ],
        [ sh:datatype <xsd:date> ;
            sh:description "Materiële tijdlijn: start van de geldigheid." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path gbo:beginGeldigheid ],
        [ sh:datatype <xsd:date> ;
            sh:description "Materiële tijdlijn: einde van de geldigheid; open betekent lopend." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path gbo:eindGeldigheid ],
        [ sh:datatype <xsd:date> ;
            sh:description "Materiële tijdlijn: start van de geldigheid." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path gbo:beginGeldigheid ],
        [ sh:datatype <xsd:string> ;
            sh:description "Korte vrije omschrijving van de inhoud van de aantekening." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path gbo:omschrijving ],
        [ sh:datatype <xsd:integer> ;
            sh:description "Monotone versieteller." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gbo:versie ],
        [ sh:datatype <xsd:date> ;
            sh:description "Materiële tijdlijn: einde van de geldigheid; open betekent lopend." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path gbo:eindGeldigheid ],
        [ sh:datatype <xsd:string> ;
            sh:description "Aard van de aantekening, bijvoorbeeld kwalitatieve verplichting of bewindstelling." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path gbo:aardAantekening ],
        [ sh:datatype <xsd:dateTime> ;
            sh:description "Formele tijdlijn: start van de registratie." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path gbo:tijdstipRegistratie ],
        [ sh:class gbo:KadastraleOnroerendeZaak ;
            sh:description "Kadastrale onroerende zaak waarop de aantekening rust." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path gbo:opKadastraleOnroerendeZaak ],
        [ sh:datatype <xsd:string> ;
            sh:description "Aard van de aantekening, bijvoorbeeld kwalitatieve verplichting of bewindstelling." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path gbo:aardAantekening ],
        [ sh:datatype <xsd:dateTime> ;
            sh:description "Formele tijdlijn: einde van de registratie; open betekent actueel." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path gbo:eindRegistratie ],
