            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path gbo:betreft ],
        [ sh:class gbo:MaatschappelijkeActiviteit ;
            sh:description "De uitvoerings-instelling die het besluit heeft genomen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path gbo:genomenDoor ],
        [ sh:datatype <xsd:string> ;
