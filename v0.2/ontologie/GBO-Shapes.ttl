            sh:order 17 ;
            sh:path gbo:peildatum ],
        [ sh:datatype <xsd:string> ;
            sh:description "Internationaal banknummer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path gbo:iban ],
        [ sh:datatype <xsd:string> ;
            sh:description "Land van de bankvestiging." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path gbo:land ;
            sh:pattern "^[A-Z]{2}$" ],
        [ sh:description "Categorie-aanduiding." ;
            sh:in ( "BanktegoedBinnenland" "BanktegoedBuitenland" "Aandelen" "Obligaties" "Beleggingsfondsen" "Derivaten" "Cryptovaluta" "OnroerendeZaakOverig" "Vordering" "Schuld" ) ;
            sh:maxCount 1 ;
